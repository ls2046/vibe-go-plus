export function uploadMobileFile(
	filePath: string,
	sourceUri: string,
	mimeType: string,
	done: (ok: boolean, record: UploadRecord | null, error: string) => void,
): void {
	const url = apiUrl('/api/mobile/uploads')
	if (url.length == 0) {
		done(false, null, '请先填写 vibe-go server 地址')
		return
	}

	uni.uploadFile({
		url,
		filePath,
		name: 'file',
		header: {
			'x-vibego-server-url': getServerUrl(),
		},
		formData: {
			sourceUri,
			mimeType,
		},
		success: (res) => {
			if (res.statusCode < 200 || res.statusCode >= 300) {
				done(false, null, 'HTTP ' + res.statusCode.toString())
				return
			}
			try {
				const data = JSON.parse(res.data) as UTSJSONObject
				if (data.getBoolean('ok') == true) {
					const record: UploadRecord = {
						name: data.getString('name') ?? '',
						path: data.getString('path') ?? '',
						url: data.getString('url') ?? '',
						mimeType: data.getString('mimeType') ?? mimeType,
						size: data.getNumber('size') ?? 0,
						sourceUri: data.getString('sourceUri') ?? sourceUri,
						createdAt: data.getString('createdAt') ?? new Date().toISOString(),
					}
					saveUploadRecord(record)
					done(true, record, '')
				} else {
					done(false, null, data.getString('error') ?? '上传失败')
				}
			} catch (error) {
				console.log('uploadMobileFile parse failed', error)
				done(false, null, '响应解析失败')
			}
		},
		fail: (err) => {
			done(false, null, err.errMsg)
		},
	})
}

export function transcribeMobileAudio(filePath: string, done: (ok: boolean, text: string, error: string) => void): void {
	const url = apiUrl('/api/mobile/transcribe-audio')
	if (url.length == 0) {
		done(false, '', '请先填写 vibe-go server 地址')
		return
	}
	uni.uploadFile({
		url,
		filePath,
		name: 'audio',
		header: {
			'x-vibego-server-url': getServerUrl(),
		},
		formData: {
			mimeType: 'audio/mp4',
		},
		success: (res) => {
			if (res.statusCode < 200 || res.statusCode >= 300) {
				done(false, '', 'HTTP ' + res.statusCode.toString())
				return
			}
			try {
				const data = JSON.parse(res.data) as UTSJSONObject
				if (data.getBoolean('ok') == true) {
					done(true, data.getString('text') ?? '', '')
				} else {
					done(false, '', data.getString('error') ?? '转写失败')
				}
			} catch (error) {
				console.log('transcribeMobileAudio parse failed', error)
				done(false, '', '响应解析失败')
			}
		},
		fail: (err) => {
			done(false, '', err.errMsg)
		},
	})
}

export function uploadAnnotation(
	imagePath: string,
	payload: string,
	done: (ok: boolean, record: AnnotationRecord | null, error: string) => void,
): void {
	const url = apiUrl('/api/mobile/annotations')
	if (url.length == 0) {
		done(false, null, '请先填写 vibe-go server 地址')
		return
	}

	uni.uploadFile({
		url,
		filePath: imagePath,
		name: 'image',
		header: {
			'x-vibego-server-url': getServerUrl(),
		},
		formData: {
			payload,
		},
		success: (res) => {
			if (res.statusCode < 200 || res.statusCode >= 300) {
				done(false, null, 'HTTP ' + res.statusCode.toString())
				return
			}
			try {
				const data = JSON.parse(res.data) as UTSJSONObject
				if (data.getBoolean('ok') == true) {
					const record: AnnotationRecord = {
						imagePath: data.getString('imagePath') ?? '',
						jsonPath: data.getString('jsonPath') ?? '',
						createdAt: data.getString('createdAt') ?? new Date().toISOString(),
					}
					saveAnnotationRecord(record)
					done(true, record, '')
				} else {
					done(false, null, data.getString('error') ?? '标注上传失败')
				}
			} catch (error) {
				console.log('uploadAnnotation parse failed', error)
				done(false, null, '响应解析失败')
			}
		},
		fail: (err) => {
			done(false, null, err.errMsg)
		},
	})
}
