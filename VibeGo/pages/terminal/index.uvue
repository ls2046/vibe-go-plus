	.app-page {
		height: 1000px;
		padding: 20px;
		background-color: #eef3ff;
		justify-content: center;
	}

	.card {
		padding: 18px;
		border-width: 1px;
		border-color: #dbe3f0;
		border-style: solid;
		border-radius: 18px;
		background-color: #ffffff;
	}

	.brand-row {
		flex-direction: row;
		align-items: center;
	}

	.brand-mark {
		width: 44px;
		height: 44px;
		border-radius: 13px;
		align-items: center;
		justify-content: center;
		background-color: #111827;
	}

	.brand-mark-text {
		font-size: 22px;
		font-weight: 700;
		color: #ffffff;
	}

	.brand-copy {
		flex: 1;
		margin-left: 12px;
	}

	.title {
		font-size: 18px;
		font-weight: 700;
		color: #111827;
	}

	.subtitle {
		margin-top: 5px;
		font-size: 12px;
		line-height: 18px;
		color: #64748b;
	}

	.prompt {
		margin-top: 16px;
		height: 120px;
		padding: 12px;
		border-radius: 14px;
		background-color: #f8fafc;
		font-size: 13px;
		color: #111827;
	}

	.primary-button {
		margin-top: 14px;
		height: 44px;
		border-radius: 14px;
		font-size: 14px;
		font-weight: 700;
		color: #ffffff;
		background-color: #111827;
	}

	.secondary-button {
		margin-top: 10px;
		height: 44px;
		border-radius: 14px;
		font-size: 14px;
		font-weight: 700;
		color: #111827;
		background-color: #f1f5f9;
	}
</style>
