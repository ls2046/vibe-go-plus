<template>
	<view :class="appPageClass()" :style="pageStyle()">
		<view class="window" :style="windowStyle()">
			<index-sidebar
				v-if="!isCompactChat"
				:activeRailMode="activeRailMode"
				:assistantText="assistantNavText()"
				:railCompact="railCompact()"
				:sidebarStyle="sidebarStyle()"
				:nightMode="isNightTheme()"
				@toggleSidebar="toggleSidebar"
				@openConversationList="openConversationList"
				@refreshCodexLists="refreshCodexListsFromMenu"
				@openAssistant="openAssistant"
				@goWeb="goWeb"
				@toggleSettings="toggleSettings"
			></index-sidebar>

			<view v-if="!isCompactChat && !railCompact() && showThreadListPane()" class="splitter" :style="splitterStyle()" @touchstart="startResize" @touchmove="moveResize" @touchend="endResize"></view>

			<view class="main">
				<view class="main-surface" :class="workspaceMotionActive ? 'main-surface-motion-active' : ''" :style="mainSurfaceStyle()">
					<view v-if="rightMode == 'chat'" class="chat-workspace" :style="tabCardStyle()">
							<thread-list-pane
								v-if="showThreadListPane()"
								:projectGroups="projectGroups"
								:activeThreadId="activeThreadId"
								:activeProjectId="selectedProjectId()"
								:cardStyle="threadListCardStyle()"
								:scrollTargetTop="threadListScrollTargetTop"
								:scrollRequestKey="threadListScrollRequestKey"
								:nightMode="isNightTheme()"
								@newThread="newThread"
							@selectThread="selectThreadById"
							@toggleProjectGroup="toggleProjectGroup"
							@startProjectThread="startProjectThread"
						></thread-list-pane>
						<view v-if="showThreadListPane()" class="pane-gap" :style="paneGapStyle()"></view>

						<chat-workspace
							:displayTitle="displayTitle"
							:threadLoading="threadLoading"
							:messageViews="messageViews"
							:processEvents="processEvents"
							:codexRunning="codexRunning"
							:liveStatusText="liveStatusText()"
							:hasEarlierMessages="hasEarlierMessages()"
							:chatScrollTop="chatScrollTop"
							:chatScrollIntoView="chatScrollIntoView"
							:prompt="prompt"
							:voiceTarget="voiceTarget"
							:voicePreviewText="voicePreviewText"
							:composerAttachments="composerAttachments"
							:hasComposerAttachment="hasComposerAttachment()"
							:composerMicActive="composerMicActive()"
							:canSendPrompt="canSendPrompt()"
							:sendIconSrc="sendIconSrc()"
							:uploadIconSrc="uploadIconSrc()"
							:nightMode="isNightTheme()"
							:chatShellStyle="chatShellStyle()"
							:titleBarStyle="titleBarStyle()"
							:chatBodyStyle="chatBodyStyle()"
							:chatScrollStyle="chatScrollStyle()"
							:chatScrollContentStyle="chatScrollContentStyle()"
							:messageImageStyle="messageImageStyle()"
							:composerStyle="composerStyle()"
							:composerContentStyle="composerContentStyle()"
							:composerInputStyle="composerInputStyle()"
							:userMessageStyle="userMessageStyle()"
							:showCompactMenuButton="isCompactChat"
							:voiceFirstComposer="isAssistantVoiceFirstComposer()"
							:perceptionEnabled="assistantPerceptionEnabled"
							:perceptionBusy="assistantPerceptionBusy"
							:recentMessageId="recentMessageId"
							:sendPulseActive="sendPulseActive"
							:threadSwitchMotionActive="threadSwitchMotionActive"
							@toggleSettings="toggleSettings"
							@openCompactDrawer="openCompactDrawer"
							@loadEarlierMessages="loadEarlierMessages"
							@copyText="copyText"
							@textSegmentClick="onTextSegmentClick"
							@copyMessage="copyMessage"
							@clearComposerAttachment="onClearComposerAttachment($event)"
							@promptInput="onPromptInput"
							@openUploadMenu="openUploadMenu"
							@toggleComposerVoiceRecord="toggleComposerVoiceRecord"
							@togglePerception="toggleAssistantPerception"
							@sendPrompt="triggerPrimarySend"
						></chat-workspace>
					</view>

					<web-annotator-pane
						v-else-if="rightMode == 'web'"
						:paneStyle="tabCardStyle()"
						:embeddedWebUrl="embeddedWebUrl"
						:webViewKey="webViewKey"
						:webContainerStyle="embeddedWebContainerStyle()"
						:isCapturingScreenshot="isCapturingScreenshot"
						:isAnnotating="isAnnotating"
						:showAnnotationPill="showAnnotationPill"
						:canUndoAnnotation="canUndoAnnotation()"
						:webCanGoBack="webNavCanGoBack"
						:webCanGoForward="webNavCanGoForward"
						:webNavBusy="webNavBusy"
						:annotationSendLoading="annotationSendStatus == 'sending' || annotationSendStatus == 'waiting'"
						:annotationPreviewSrc="annotationPreviewSrc"
						:annotationStageWidth="annotationStageWidth"
						:annotationStageHeight="annotationStageHeight"
						:annotationOverlayStyle="annotationOverlayStyle()"
						:annotationStageStyle="annotationStageStyle()"
						:annotationImageStyle="annotationImageStyle()"
						:showCompactMenuButton="isCompactChat"
						:compactMenuButtonStyle="compactWebMenuButtonStyle()"
						:annotationSegments="annotationSegments"
						:annotationDots="annotationDots"
						@openCompactDrawer="openCompactDrawer"
						@undoAnnotation="undoAnnotation"
						@toggleAnnotationPill="toggleAnnotationPill"
						@micClick="onMicClick"
						@webBack="controlEmbeddedWeb('back')"
						@webForward="controlEmbeddedWeb('forward')"
						@webReload="controlEmbeddedWeb('reload')"
						@annotationTouchStart="onAnnotationTouchStart"
						@annotationTouchMove="onAnnotationTouchMove"
						@annotationTouchEnd="onAnnotationTouchEnd"
					></web-annotator-pane>

					<file-workspace
						v-else
						:layoutStyle="filesLayoutStyle()"
						:nodes="nodes"
						:selectedPath="selectedPath"
						:fileText="fileText"
						:showCompactMenuButton="isCompactChat"
						@openCompactDrawer="openCompactDrawer"
						@reloadTree="reloadTree"
						@nodeTap="onNodeTap"
						@sendFileToCodex="sendFileToCodex"
						@saveFile="saveFile"
						@showChat="showChat"
						@fileTextInput="onFileTextInput"
					></file-workspace>

				</view>
			</view>
		</view>
		<compact-drawer
			v-if="isCompactChat && compactDrawerOpen"
			:motionActive="compactDrawerMotionActive"
			:activeRailMode="activeRailMode"
			:assistantText="assistantNavText()"
			:showThreadList="showCompactDrawerThreadList()"
			:nightMode="isNightTheme()"
			:panelStyle="compactDrawerPanelStyle()"
			:threadListCardStyle="compactDrawerThreadListStyle()"
			:projectGroups="projectGroups"
			:activeThreadId="activeThreadId"
			:activeProjectId="selectedProjectId()"
			:threadListScrollTargetTop="threadListScrollTargetTop"
			:threadListScrollRequestKey="threadListScrollRequestKey"
			@close="closeCompactDrawer"
			@noop="noopClick"
			@openConversationList="openConversationListFromCompactDrawer"
			@refreshCodexLists="refreshCodexListsFromMenu"
			@openAssistant="openAssistantFromCompactDrawer"
			@goWeb="goWebFromCompactDrawer"
			@toggleSettings="toggleSettingsFromCompactDrawer"
			@newThread="newThreadFromCompactDrawer"
			@selectThread="selectThreadByIdFromCompactDrawer"
			@toggleProjectGroup="toggleProjectGroup"
			@startProjectThread="startProjectThreadFromCompactDrawer"
		></compact-drawer>
		<view v-if="settingsOpen" class="settings-dialog-overlay" @touchstart="onSettingsOverlayTouchStart" @touchend="onSettingsOverlayTouchEnd" @click="onSettingsOverlayClick">
			<view class="settings-dialog-mask"></view>
			<view class="settings-dialog" :class="settingsMotionActive ? 'settings-dialog-motion-active' : ''" :style="settingsDialogStyle()" @click="noopClick" @touchend="noopClick">
			<view class="settings-dialog-head">
				<text class="settings-title">设置</text>
				<view class="settings-close-btn" @click.stop="closeSettings">
					<image class="settings-close-icon" :src="settingsCloseIconSrc()" mode="aspectFit"></image>
				</view>
			</view>
			<view class="settings-section">
				<text class="settings-section-title">服务器</text>
				<view class="settings-field-row">
					<view class="settings-field settings-field-host">
						<text class="settings-field-label">IP / 域名</text>
						<input class="settings-input" v-model="serverHost" placeholder="127.0.0.1:8790" />
					</view>
					<view class="settings-field settings-field-port">
						<text class="settings-field-label">端口</text>
						<input class="settings-input" v-model="serverPort" placeholder="8790" />
					</view>
				</view>
				<text v-if="settingsError.length > 0" class="settings-error">{{ settingsError }}</text>
			</view>
			<view class="settings-section settings-theme-section">
				<text class="settings-section-title">外观</text>
				<view class="settings-theme-switch">
					<view class="settings-theme-option" :class="themeOptionClass('light')" @click.stop="changeAppTheme('light')">
						<text class="settings-theme-option-text" :class="themeOptionTextClass('light')">浅色</text>
					</view>
					<view class="settings-theme-option" :class="themeOptionClass('night')" @click.stop="changeAppTheme('night')">
						<text class="settings-theme-option-text" :class="themeOptionTextClass('night')">黑夜</text>
					</view>
				</view>
			</view>
			<view class="settings-actions">
				<view class="settings-btn settings-btn-primary settings-btn-wide" @click.stop="saveServerFields">
					<text class="settings-btn-text settings-btn-primary-text">保存服务器</text>
				</view>
				<view class="settings-secondary-actions">
					<view class="settings-btn settings-btn-secondary" @click.stop="resetAssistant">
						<text class="settings-btn-text">重置助手</text>
					</view>
					<view class="settings-btn settings-btn-secondary" @click.stop="openKeyboardSettingsFromSettings">
						<text class="settings-btn-text">键盘设置</text>
					</view>
					<view class="settings-btn settings-btn-secondary" @click.stop="openAbilityCenterFromSettings">
						<text class="settings-btn-text">能力中心</text>
					</view>
				</view>
			</view>
		</view>
	</view>
	<drop-dialog
		v-if="dropDialogOpen"
		:hasCurrentThreadTarget="hasCurrentDropThreadTarget()"
		:previewIsImage="dropPreviewIsImage()"
		:previewIsClipboard="dropPreviewIsClipboard()"
		:clipboardPreviewText="dropPreviewClipboardText()"
		:previewUrl="dropPreviewUrl()"
		:dropInstruction="dropInstruction"
		:dropSendError="dropSendError"
		:dropMicActive="dropMicActive()"
		:dropMicButtonText="dropMicButtonText()"
		:canSendCurrent="dropCanSendToCurrentThread()"
		:canSendAssistant="dropCanSendToAssistant()"
		:currentButtonText="dropCurrentButtonText()"
		:assistantButtonText="dropAssistantButtonText()"
		:voiceTarget="voiceTarget"
		:voicePreviewText="voicePreviewText"
		:dialogStyle="dropDialogStyle()"
		:previewStyle="dropDialogPreviewStyle()"
		:compact="dropDialogCompact()"
		:dialogWidth="dropDialogWidth()"
		:dialogHeight="dropDialogHeight()"
		:windowWidth="windowWidth"
		:windowHeight="windowHeight"
		:nightMode="isNightTheme()"
		@cancel="cancelDropFile"
		@noop="noopClick"
		@toggleVoiceRecord="toggleVoiceRecord"
		@sendCurrent="sendDropToCurrentThread"
		@sendAssistant="sendDropToAssistant"
		@instructionInput="onDropInstructionInput"
	></drop-dialog>
	</view>
</template>

<script lang="uts">
import { DEFAULT_SERVER_URL, emptyAnnotationSourceContext, emptyAssistantRecord, getActiveProjectId, getActiveRailMode, getActiveThreadId, getAnnotationSourceContext, getAppTheme, getAsrMode, getAssistantRecord, getComposerDraft, getDevUrl, getPendingGlobalVoiceText, getRightMode, getServerUrl, getThreadListCollapsed, normalizeAppTheme, normalizeAsrMode, setActiveProjectId, setActiveRailMode, setActiveThreadId, setAnnotationSourceContext, setAppTheme, setAsrMode, setAssistantRecord, setComposerDraft, setDevUrl, setPendingGlobalVoiceText, setRightMode, setServerUrl, setThreadListCollapsed, type AnnotationSourceContext, type AssistantRecord } from '../../common/app-state.uts'
import { type DropUploadedInfo } from '../../common/android-drop.uts'
import { openExternalUri } from '../../common/android-open.uts'
import { installGlobalVoiceLongPress, isGlobalVoiceActive, toggleGlobalVoiceFromButton } from '../../common/android-global-voice.uts'
import { clearKeyboardPrimaryClearHandler, clearKeyboardPrimaryDeleteHandler, clearKeyboardPrimarySendHandler, registerKeyboardPrimaryClearHandler, registerKeyboardPrimaryDeleteHandler, registerKeyboardPrimarySendHandler } from '../../common/android-keyboard.uts'
import { cancelVoiceRecording, requestRecordAudioPermission, startVoiceRecording, stopVoiceRecording } from '../../common/android-voice-record.uts'
import { claimVoiceSession, releaseVoiceSession } from '../../common/voice-session-lock.uts'
import { captureCurrentWindowLayoutRegion, type ScreenshotResult } from '../../common/android-shot.uts'
import { controlEmbeddedWebView } from '../../common/android-webview-nav.uts'
import { captureOnce, getScreenCapability, requestCapturePermission, stopCaptureSession, type ScreenCapability, type ScreenCaptureFrameResult } from '../../common/android-screen.uts'
import { getPendingAnnotation, setPendingAnnotation } from '../../common/app-state.uts'
import { readSystemClipboardFirst, readSystemClipboardText, type ClipboardFirstInfo } from '../../common/system-clipboard.uts'
// #ifdef APP-ANDROID
import Context from 'android.content.Context'
import ClipboardManager from 'android.content.ClipboardManager'
import ClipData from 'android.content.ClipData'
// #endif
import {
	apiCodexSend,
	apiCodexCreateThread,
	apiCodexStatus,
	apiCodexThreadScope,
	apiCodexThreadSnapshotWithProcessLimit,
	apiCodexThreads,
	apiCodexThreadsWithSync,
	apiCodexThreadUpdates,
	apiListProject,
	apiProjects,
	apiProjectsWithSync,
	apiReadProject,
	apiWriteProject,
	checkServerHealth,
	transcribeMobileAudio,
	uploadAnnotation,
	uploadMobileFile,
	type ChatMessage,
	type CodexCursor,
	type CodexEvent,
	type CodexProcessEvent,
	type CodexCreateThreadResult,
	type CodexWatch,
	type CodexThread,
	type FsEntry,
	type ProjectInfo,
} from '../../common/mobile-api.uts'
import IndexSidebar from './parts/IndexSidebar.uvue'
import ThreadListPane from './parts/ThreadListPane.uvue'
import ChatWorkspace from './parts/ChatWorkspace.uvue'
import WebAnnotatorPane from './parts/WebAnnotatorPane.uvue'
import FileWorkspace from './parts/FileWorkspace.uvue'
import DropDialog from './parts/DropDialog.uvue'
import CompactDrawer from './parts/CompactDrawer.uvue'
import { type ChatMessageView, type ChatTextBlock, type ChatTextSegment, type ComposerAttachment, type DropSendTarget, type Point, type ProjectThreadGroup, type Segment, type TreeNode } from './modules/index-types.uts'
import { pxSizeStyle } from './modules/layout-metrics.uts'

const EXPANDED_CODEX_PROJECTS_KEY = 'vibego.expandedCodexProjects'
const CODEX_PROJECTS_CACHE_KEY = 'vibego.codexProjectsCache.v1'
const CODEX_THREADS_CACHE_KEY = 'vibego.codexThreadsCache.v1'
const CODEX_THREAD_SNAPSHOT_CACHE_KEY = 'vibego.codexThreadSnapshotCache.v2'
const CODEX_DIRECT_PROJECT_ID = 'codex-direct-conversations'
const PAGE_VOICE_OWNER = 'page'
const RECENT_NORMAL_THREAD_KEY = 'vibego.recentNormalThreadId'
const LIST_REFRESH_MIN_INTERVAL_MS = 30000
const DROP_FOREGROUND_MARK_KEY = 'vibego.dropForegroundAt'
const DROP_FOREGROUND_MARK_TTL_MS = 3500
const CLIPBOARD_DIALOG_FINGERPRINT_KEY = 'vibego.clipboardDialogFingerprint'

type CachedThreadSnapshot = {
	threadId: string
	summary: CodexThread
	messages: Array<ChatMessage>
	processEvents: Array<CodexProcessEvent>
	cursor: CodexCursor
	active: boolean
	cachedAt: number
}

export default {
	components: {
		IndexSidebar,
		ThreadListPane,
		ChatWorkspace,
		WebAnnotatorPane,
		FileWorkspace,
		DropDialog,
		CompactDrawer,
	},
	data() {
		return {
			serverUrl: '',
			serverHost: '',
			serverPort: '',
			appTheme: 'light',
			statusText: '',
			settingsOpen: false,
			settingsError: '',
			settingsLastTouchX: -1,
			settingsLastTouchY: -1,
			settingsLastTouchAt: 0,
			settingsLastHandledAt: 0,
			screenOverlayGranted: false,
			screenProjectionAuthorized: false,
			screenProjectionActive: false,
			screenCapabilityText: '识屏状态未检测',
			screenCapturePath: '',
			screenCaptureMetaText: '',
			screenCaptureUploadText: '',
			screenCaptureBusy: false,
			assistantPerceptionEnabled: false,
			assistantPerceptionBusy: false,
			assistantPerceptionSessionId: 0,
			assistantPerceptionText: '',
			assistantPerceptionUploadPath: '',
			assistantPerceptionCaptureDone: false,
			assistantPerceptionCaptureError: '',
			sidebarCollapsed: false,
			userSidebarCollapsed: false,
			isCompactChat: false,
			isIconSidebar: false,
			layoutInitialized: false,
			sidebarWidth: 230,
			expandedSidebarWidth: 230,
			minSidebarWidth: 210,
			maxSidebarWidth: 280,
			screenWidth: 1080,
			compactBreakpoint: 540,
			iconSidebarBreakpoint: 720,
			windowWidth: 1080,
			windowHeight: 900,
			safeTop: 0,
			safeBottom: 0,
			resizing: false,
			resizeStartX: 0,
			resizeStartWidth: 360,
				projects: new Array<ProjectInfo>(),
				projectGroups: new Array<ProjectThreadGroup>(),
				expandedProjectIds: new Array<string>(),
				threads: new Array<CodexThread>(),
				threadListScrollTargetTop: 0,
				threadListScrollRequestKey: 0,
				projectThreadRefreshAt: 0,
				projectListRequestSeq: 0,
				threadListRequestSeq: 0,
				startupBootAt: 0,
				activeThreadSnapshotStale: false,
				activeThreadSnapshotCachedAt: 0,
				snapshotLoadingThreadId: '',
				snapshotLoadingStartedAt: 0,
			messages: new Array<ChatMessage>(),
			messageViews: new Array<ChatMessageView>(),
			processEvents: new Array<CodexProcessEvent>(),
			nodes: new Array<TreeNode>(),
			activeProjectId: '',
				activeProjectPath: '',
				activeThreadId: '',
				activeRailMode: 'conversation',
				previousRailMode: 'conversation',
				conversationOpenPending: false,
				assistantThreadId: '',
			assistantProjectId: '',
			assistantTitle: '',
			assistantInitializedAt: '',
			assistantInitializing: false,
			assistantPendingProjectId: '',
			pendingAssistantPrompt: '',
			pendingAssistantPromptWaiting: false,
			mainTitle: '',
			rightMode: 'chat',
			compactDrawerOpen: false,
			embeddedWebUrl: '',
			webViewKey: '',
			isExternalUrl: false,
			webNavCanGoBack: false,
			webNavCanGoForward: false,
			webNavBusy: false,
			isAnnotating: false,
			annotationBusy: false,
			annotationSubmitting: false,
			showAnnotationPill: false,
			isCapturingScreenshot: false,
			annotationImagePath: '',
			annotationPreviewSrc: '',
			annotationDots: new Array<Point>(),
			annotationSegments: new Array<Segment>(),
			annotationStrokeGroups: new Array<number>(),
			annotationStrokeSegmentGroups: new Array<number>(),
			annotationStageWidth: 375,
			annotationStageHeight: 720,
			annotationStrokePointCount: 0,
			annotationStrokeSegmentCount: 0,
			annotationDrawing: false,
			annotationLastPoint: null as Point | null,
			pendingAnnotationVoiceText: '',
			annotationSourceProjectId: '',
			annotationSourceThreadId: '',
			annotationSourceTitle: '',
			annotationSourceIsAssistant: false,
			annotationSourceBoundAt: '',
			annotationSourceUrl: '',
			annotationSendStatus: '',
			prompt: '',
			assistantPromptDraft: '',
			conversationPromptDraft: '',
			selectedPath: '',
			fileText: '',
			originalText: '',
			dirty: false,
			codexRunning: false,
			threadLoading: false,
			pollTimer: 0,
			annotationPollTimer: 0,
			globalVoicePendingTimer: 0,
			webNavStatusTimer: 0,
			pollMode: '',
			annotationPollMode: '',
			pollMisses: 0,
			annotationPollMisses: 0,
			watchSendId: '',
			watchSince: '',
			watchThreadId: '',
			watchSessionFile: '',
			watchExpectNewThread: false,
			watchExcludeThreadId: '',
			watchCwd: '',
			annotationWatchSendId: '',
			annotationWatchSince: '',
			annotationWatchThreadId: '',
			annotationWatchSessionFile: '',
			annotationWatchExpectNewThread: false,
			annotationWatchExcludeThreadId: '',
			annotationWatchCwd: '',
			cursorThreadId: '',
			cursorSessionFile: '',
			cursorMessageCount: 0,
			cursorProcessCount: 0,
			cursorFileSize: 0,
			cursorByteOffset: 0,
			cursorOpenTurnStartedAt: '',
			cursorOpenTurnHasAssistantFinal: false,
			annotationCursorThreadId: '',
			annotationCursorSessionFile: '',
			annotationCursorMessageCount: 0,
			annotationCursorProcessCount: 0,
			annotationCursorFileSize: 0,
			annotationCursorByteOffset: 0,
			annotationCursorOpenTurnStartedAt: '',
			annotationCursorOpenTurnHasAssistantFinal: false,
			chatScrollTop: 0,
				chatScrollIntoView: '',
				chatScrollTimer: 0,
				chatScrollRequestId: 0,
				workspaceMotionActive: false,
				workspaceMotionTimer: 0,
				threadSwitchMotionActive: false,
				threadSwitchMotionTimer: 0,
				compactDrawerMotionActive: false,
				compactDrawerMotionTimer: 0,
				settingsMotionActive: false,
				settingsMotionTimer: 0,
				recentMessageId: '',
				recentMessageTimer: 0,
				sendPulseActive: false,
				sendPulseTimer: 0,
				activeThreadSnapshotCacheTimer: 0,
				visibleMessageCount: 40,
			messageViewStep: 40,
			messageViewCacheIds: new Array<string>(),
			messageViewCacheValues: new Array<ChatMessageView>(),
				dropDialogOpen: false,
				pendingDropFiles: new Array<DropUploadedInfo>(),
				activeDropFile: null as DropUploadedInfo | null,
				dropForegroundActive: false,
				dropForegroundUntil: 0,
				activeClipboardText: '',
				lastClipboardDialogText: '',
				lastClipboardDialogFingerprint: '',
				clipboardReadTimer: 0,
				clipboardAutoPrimed: false,
				composerAttachments: new Array<ComposerAttachment>(),
				dropInstruction: '',
				dropSendTarget: {
					kind: 'assistant_pending',
					title: 'AI 助手准备中',
					subtitle: '正在创建助手会话',
					threadId: '',
					projectId: '',
					scope: 'direct',
				} as DropSendTarget,
				dropSending: false,
				dropSendingKind: '',
				dropSendError: '',
				asrMode: 'cloud',
				voiceRecording: false,
				voiceTranscribing: false,
				voicePreviewText: '',
				voiceLastFinalText: '',
				voiceTarget: '',
				voiceSessionMode: '',
				voiceRecordPath: '',
				voiceSessionId: 0,
				globalVoiceActive: false,
		}
	},
	computed: {
		displayTitle(): string {
			if (this.isAssistantThread(this.activeThreadId)) return this.assistantThreadTitle()
			return this.mainTitle
		},
	},
		onLoad() {
			this.startupBootAt = Date.now()
			this.logStartupPerf('onLoad:start')
			const layoutStart = Date.now()
			this.initLayout()
			this.logStartupPerfEnd('onLoad:initLayout', layoutStart)
			this.hydrateDropForegroundProtection()
			const savedRailMode = getActiveRailMode()
			const savedRightMode = getRightMode()
			this.logStartupPerf('onLoad:stored-state', 'rail=' + savedRailMode + ' right=' + savedRightMode)
			this.serverUrl = getServerUrl()
			this.syncServerFieldsFromUrl()
			this.appTheme = getAppTheme()
			this.lastClipboardDialogFingerprint = this.loadClipboardDialogFingerprint()
			this.userSidebarCollapsed = getThreadListCollapsed()
			this.sidebarCollapsed = this.userSidebarCollapsed
			this.asrMode = getAsrMode()
			this.setEmbeddedWebUrl(getDevUrl())
			this.activeProjectId = getActiveProjectId()
			this.activeThreadId = getActiveThreadId()
			this.applyAssistantRecord(getAssistantRecord())
			this.hydrateAnnotationSourceContext()
			this.loadExpandedProjectIds()
			const cacheStart = Date.now()
			this.restoreProjectAndThreadCache()
			this.logStartupPerfEnd('onLoad:restoreProjectAndThreadCache', cacheStart, 'projects=' + this.projects.length.toString() + ' threads=' + this.threads.length.toString())
			const workspaceStart = Date.now()
			this.restoreInitialWorkspace(savedRailMode, savedRightMode)
			this.logStartupPerfEnd('onLoad:restoreInitialWorkspace', workspaceStart, 'activeThread=' + this.activeThreadId + ' messages=' + this.messages.length.toString() + ' views=' + this.messageViews.length.toString())
			this.applyComposerDraft()
			const capabilityStart = Date.now()
			this.refreshScreenCaptureStatus()
			this.logStartupPerfEnd('onLoad:refreshScreenCaptureStatus', capabilityStart)
				uni.$on('mobile-drop-uploaded', this.onDropUploaded)
				uni.$on('mobile-drop-event', this.onDropLifecycleEvent)
				uni.$on('mobile-share-text', this.onShareText)
			registerKeyboardPrimarySendHandler(() => {
				console.log('[vibego-keyboard]', 'primary-send-handler-callback', 'source=onLoad')
				this.triggerPrimarySend()
			})
			registerKeyboardPrimaryDeleteHandler(() => {
				console.log('[vibego-keyboard]', 'primary-delete-handler-callback', 'source=onLoad')
				this.triggerPrimaryDelete()
			})
			registerKeyboardPrimaryClearHandler(() => {
				console.log('[vibego-keyboard]', 'primary-clear-handler-callback', 'source=onLoad')
				this.triggerPrimaryClear()
			})
			uni.$on('mobile-clipboard-first', this.onClipboardFirst)
			uni.$on('vibego-app-show', this.onAppShow)
			uni.$on('mobile-global-voice-text', this.onGlobalVoiceText)
			uni.$on('mobile-global-voice-state', this.onGlobalVoiceState)
			uni.$on('vibego-keyboard-action', this.onKeyboardAction)
			this.globalVoiceActive = isGlobalVoiceActive()
			this.startGlobalVoicePendingPoll()
			this.startWebNavStatusPoll()
			this.logStartupPerf('onLoad:events-ready', 'globalVoice=' + (this.globalVoiceActive ? '1' : '0'))
			this.ensureStartupCacheLoaded()
			if (!this.shouldSuppressForegroundSideEffects()) this.handlePendingGlobalVoiceText()
			this.logStartupPerfEnd('onLoad:end', this.startupBootAt, 'rightMode=' + this.rightMode + ' rail=' + this.activeRailMode)
		},
		onShow() {
			const showStart = Date.now()
			this.logStartupPerf('onShow:start')
			registerKeyboardPrimarySendHandler(() => {
				console.log('[vibego-keyboard]', 'primary-send-handler-callback', 'source=onShow')
				this.triggerPrimarySend()
			})
			registerKeyboardPrimaryDeleteHandler(() => {
				console.log('[vibego-keyboard]', 'primary-delete-handler-callback', 'source=onShow')
				this.triggerPrimaryDelete()
			})
			registerKeyboardPrimaryClearHandler(() => {
				console.log('[vibego-keyboard]', 'primary-clear-handler-callback', 'source=onShow')
				this.triggerPrimaryClear()
			})
			installGlobalVoiceLongPress()
			setTimeout(() => {
				installGlobalVoiceLongPress()
			}, 120)
			this.refreshLayout()
			this.globalVoiceActive = isGlobalVoiceActive()
			const suppress = this.shouldSuppressForegroundSideEffects()
			this.logStartupPerf('onShow:foreground-state', 'suppress=' + (suppress ? '1' : '0'))
			this.refreshScreenCaptureStatus()
			if (!suppress) {
				this.applyComposerDraft()
				this.handlePendingAnnotation()
				this.handlePendingGlobalVoiceText()
			}
			this.logStartupPerfEnd('onShow:end', showStart)
	},
	onResize(options: OnResizeOptions) {
		const size = options.size
		this.applyResponsiveLayout(size.windowWidth, size.windowHeight, size.screenWidth)
	},
	onHide() {
		if (this.voiceRecording || this.voiceTranscribing) {
			this.cancelActiveVoiceSession()
		}
		this.dismissIdleClipboardDialogOnHide()
	},
	onUnload() {
		this.stopPolling()
		this.stopAnnotationMonitoring()
				if (this.chatScrollTimer != 0) clearTimeout(this.chatScrollTimer)
				if (this.workspaceMotionTimer != 0) clearTimeout(this.workspaceMotionTimer)
				if (this.threadSwitchMotionTimer != 0) clearTimeout(this.threadSwitchMotionTimer)
				if (this.compactDrawerMotionTimer != 0) clearTimeout(this.compactDrawerMotionTimer)
				if (this.settingsMotionTimer != 0) clearTimeout(this.settingsMotionTimer)
				if (this.recentMessageTimer != 0) clearTimeout(this.recentMessageTimer)
				if (this.sendPulseTimer != 0) clearTimeout(this.sendPulseTimer)
				if (this.activeThreadSnapshotCacheTimer != 0) clearTimeout(this.activeThreadSnapshotCacheTimer)
				if (this.clipboardReadTimer != 0) clearTimeout(this.clipboardReadTimer)
			if (this.globalVoicePendingTimer != 0) clearInterval(this.globalVoicePendingTimer)
			if (this.webNavStatusTimer != 0) clearInterval(this.webNavStatusTimer)
			uni.$off('mobile-drop-uploaded', this.onDropUploaded)
			uni.$off('mobile-drop-event', this.onDropLifecycleEvent)
			uni.$off('mobile-share-text', this.onShareText)
			clearKeyboardPrimarySendHandler()
			clearKeyboardPrimaryDeleteHandler()
			clearKeyboardPrimaryClearHandler()
			uni.$off('mobile-clipboard-first', this.onClipboardFirst)
			uni.$off('vibego-app-show', this.onAppShow)
			uni.$off('mobile-global-voice-text', this.onGlobalVoiceText)
			uni.$off('mobile-global-voice-state', this.onGlobalVoiceState)
			uni.$off('vibego-keyboard-action', this.onKeyboardAction)
			if (this.voiceRecording || this.voiceTranscribing) {
				this.cancelActiveVoiceSession()
			}
	},
		methods: {
		onPromptInput(value: string) {
			this.setPromptForActiveComposer(value)
		},
		isAssistantVoiceFirstComposer(): boolean {
			return this.activeRailMode == 'assistant' && this.rightMode == 'chat'
		},
		onFileTextInput(value: string) {
			this.fileText = value
			this.onEditorInput()
		},
		onDropInstructionInput(value: string) {
			this.dropInstruction = value
		},
		hydrateDropForegroundProtection() {
			const raw = uni.getStorageSync(DROP_FOREGROUND_MARK_KEY)
			let markAt = 0
			if (typeof raw == 'string' && raw.length > 0) {
				markAt = raw.toLong().toDouble()
			}
			if (markAt <= 0) return
			const now = Date.now()
			if (now - markAt > DROP_FOREGROUND_MARK_TTL_MS) return
			this.markDropForegroundActive(DROP_FOREGROUND_MARK_TTL_MS)
		},
		markDropForegroundActive(ttlMs: number = 2500) {
			const expiresAt = Date.now() + ttlMs
			this.dropForegroundActive = true
			if (expiresAt > this.dropForegroundUntil) this.dropForegroundUntil = expiresAt
			uni.setStorageSync(DROP_FOREGROUND_MARK_KEY, Date.now().toString())
		},
		clearDropForegroundProtectionIfExpired() {
			if (!this.dropForegroundActive) return
			if (Date.now() <= this.dropForegroundUntil) return
			this.dropForegroundActive = false
			this.dropForegroundUntil = 0
			uni.removeStorageSync(DROP_FOREGROUND_MARK_KEY)
		},
		shouldSuppressForegroundSideEffects(): boolean {
			if (this.dropDialogOpen || this.pendingDropFiles.length > 0 || this.activeDropFile != null) return true
			this.clearDropForegroundProtectionIfExpired()
			return this.dropForegroundActive
		},
		onDropLifecycleEvent(event: UTSJSONObject | null) {
			if (event == null) return
			const action = event.getString('action') ?? ''
			if (action == 'DRAG_STARTED' || action == 'DRAG_ENTERED' || action == 'DROP' || action == 'DRAG_ENDED') {
				this.markDropForegroundActive()
			}
		},
		startGlobalVoicePendingPoll() {
			if (this.globalVoicePendingTimer != 0) return
			this.globalVoicePendingTimer = setInterval(() => {
				this.consumePendingGlobalVoiceText()
			}, 800)
		},
		startWebNavStatusPoll() {
			if (this.webNavStatusTimer != 0) return
			this.webNavStatusTimer = setInterval(() => {
				this.refreshEmbeddedWebNavStatus()
			}, 1000)
		},
		refreshEmbeddedWebNavStatus() {
			if (this.rightMode != 'web' || this.embeddedWebUrl.length == 0 || this.isAnnotating || this.isCapturingScreenshot) return
			const result = controlEmbeddedWebView(
				'status',
				this.webCaptureLeft(),
				this.webCaptureTop(),
				this.embeddedWebWidth(),
				this.embeddedWebContentHeight(),
				this.windowWidth,
				this.windowHeight
			)
			if (!result.ok && result.error.length > 0) return
			this.webNavCanGoBack = result.canGoBack
			this.webNavCanGoForward = result.canGoForward
		},
		handlePendingGlobalVoiceText() {
			this.consumePendingGlobalVoiceText()
		},
		consumePendingGlobalVoiceText() {
			const text = getPendingGlobalVoiceText()
			if (text.length == 0) return
			this.logAssistantPerception('pending-text', 'length=' + text.length.toString())
			const consumed = this.applyGlobalVoiceTextForSession(text, 0)
			this.logAssistantPerception('pending-text-consumed', consumed.toString())
			if (consumed) setPendingGlobalVoiceText('')
		},
		onGlobalVoiceText(event: UTSJSONObject) {
			const eventText = event.getString('text') ?? ''
			const sessionId = event.getNumber('sessionId') ?? 0
			this.logAssistantPerception('voice-text-event', 'session=' + sessionId.toString() + ' length=' + eventText.length.toString())
			if (eventText.length > 0) {
				const consumed = this.applyGlobalVoiceTextForSession(eventText, sessionId)
				this.logAssistantPerception('voice-text-consumed', consumed.toString())
				if (consumed) setPendingGlobalVoiceText('')
				return
			}
			this.consumePendingGlobalVoiceText()
		},
		onGlobalVoiceState(event: UTSJSONObject) {
			this.globalVoiceActive = isGlobalVoiceActive()
			const phase = event.getString('phase') ?? ''
			const trigger = event.getString('trigger') ?? ''
			const sessionId = event.getNumber('sessionId') ?? 0
			this.logAssistantPerception('voice-state', 'phase=' + phase + ' trigger=' + trigger + ' session=' + sessionId.toString() + ' enabled=' + this.assistantPerceptionEnabled.toString() + ' context=' + this.isAssistantPerceptionContext().toString())
			if (phase == 'start' && trigger == 'long_press') {
				this.startAssistantPerceptionCapture(sessionId)
			}
		},
		applyGlobalVoiceTextForSession(text: string, sessionId: number): boolean {
			const clean = text.trim()
			if (this.handleAssistantPerceptionVoiceText(clean, sessionId)) return true
			return this.applyGlobalVoiceText(clean)
		},
		applyGlobalVoiceText(text: string): boolean {
			const clean = text.trim()
			if (clean.length == 0) return true
			if (this.dropDialogOpen) {
				this.appendDropInstruction(clean)
				console.log('[vibego-global-voice]', 'global-voice-consumed drop_dialog length=' + this.dropInstruction.length.toString())
				return true
			}
			if (this.rightMode == 'web' && this.isAnnotating) {
				this.appendPendingAnnotationVoiceText(clean)
				console.log('[vibego-global-voice]', 'global-voice-consumed annotation')
				this.sendCurrentAnnotationToSourceThread()
				return true
			}
			if (this.rightMode == 'chat' && this.activeRailMode == 'assistant') {
				this.appendComposerText(clean)
				this.showChat()
				this.scheduleChatBottom()
				console.log('[vibego-global-voice]', 'global-voice-consumed assistant')
				return true
			}
			if (this.rightMode == 'chat' && this.activeRailMode == 'conversation') {
				this.appendComposerText(clean)
				this.showChat()
				this.scheduleChatBottom()
				console.log('[vibego-global-voice]', 'global-voice-consumed project_chat')
				return true
			}
			console.log('[vibego-global-voice]', 'global-voice-deferred no_target')
			return false
		},
		openAssistantForGlobalVoice(text: string) {
			this.settingsOpen = false
			this.setWorkspaceState('assistant', 'chat')
			if (this.hasAssistantBinding()) {
				this.openAssistant()
			} else {
				this.mainTitle = this.assistantThreadTitle()
				this.createAssistant()
			}
			this.appendComposerText(text)
			this.showChat()
			this.scheduleChatBottom()
		},
		appendPendingAnnotationVoiceText(text: string) {
			const clean = text.trim()
			if (clean.length == 0) return
			if (this.pendingAnnotationVoiceText.trim().length == 0) {
				this.pendingAnnotationVoiceText = clean
			} else {
				this.pendingAnnotationVoiceText = this.pendingAnnotationVoiceText.trim() + '\n' + clean
			}
		},
		handlePendingAnnotation() {
			const pending = getPendingAnnotation()
			if (pending == null) return
			setPendingAnnotation(null)

			this.addComposerAttachment(pending.imagePath, pending.imagePath, 'image/png', '标注截图')

			this.setWorkspaceState('assistant', 'chat')
			this.setPromptForActiveComposer('这是 VibeGo APP 页面截图，图片中已有用户标注，请根据标注位置给出修改/排查建议。')
			this.showChat()
			this.scheduleChatBottom()

			this.sendPrompt()
		},
		logStartupPerf(step: string, detail: string = '') {
			// Startup profiling is intentionally silent in normal builds.
		},
		logStartupPerfEnd(step: string, startedAt: number, detail: string = '') {
			// Startup profiling is intentionally silent in normal builds.
		},
		triggerWorkspaceMotion() {
			if (this.workspaceMotionTimer != 0) clearTimeout(this.workspaceMotionTimer)
			this.workspaceMotionActive = true
			this.workspaceMotionTimer = setTimeout(() => {
				this.workspaceMotionActive = false
				this.workspaceMotionTimer = 0
			}, 180)
		},
		triggerThreadSwitchMotion() {
			if (this.threadSwitchMotionTimer != 0) clearTimeout(this.threadSwitchMotionTimer)
			this.threadSwitchMotionActive = true
			this.threadSwitchMotionTimer = setTimeout(() => {
				this.threadSwitchMotionActive = false
				this.threadSwitchMotionTimer = 0
			}, 220)
		},
		triggerCompactDrawerMotion() {
			if (this.compactDrawerMotionTimer != 0) clearTimeout(this.compactDrawerMotionTimer)
			this.compactDrawerMotionActive = true
			this.compactDrawerMotionTimer = setTimeout(() => {
				this.compactDrawerMotionActive = false
				this.compactDrawerMotionTimer = 0
			}, 180)
		},
		triggerSettingsMotion() {
			if (this.settingsMotionTimer != 0) clearTimeout(this.settingsMotionTimer)
			this.settingsMotionActive = true
			this.settingsMotionTimer = setTimeout(() => {
				this.settingsMotionActive = false
				this.settingsMotionTimer = 0
			}, 180)
		},
		markRecentMessage(messageId: string) {
			if (this.recentMessageTimer != 0) clearTimeout(this.recentMessageTimer)
			this.recentMessageId = messageId
			this.recentMessageTimer = setTimeout(() => {
				this.recentMessageId = ''
				this.recentMessageTimer = 0
			}, 340)
		},
		triggerSendPulse() {
			if (this.sendPulseTimer != 0) clearTimeout(this.sendPulseTimer)
			this.sendPulseActive = true
			this.sendPulseTimer = setTimeout(() => {
				this.sendPulseActive = false
				this.sendPulseTimer = 0
			}, 220)
		},
		initLayout() {
			try {
				const info = uni.getSystemInfoSync()
				const width = info.windowWidth
				const height = info.windowHeight
				const screenWidth = info.screenWidth
				const statusBarHeight = info.statusBarHeight
				this.applyResponsiveLayout(width, height, screenWidth)
				if (statusBarHeight > 0) this.safeTop = statusBarHeight
				this.safeBottom = this.bottomSafeInset(info.safeAreaInsets.bottom, info.windowBottom)
			} catch (_) {}
		},
		refreshLayout() {
			this.pollResponsiveLayout()
		},
		pollResponsiveLayout() {
			try {
				const info = uni.getSystemInfoSync()
				this.applyResponsiveLayout(info.windowWidth, info.windowHeight, info.screenWidth)
				const statusBarHeight = info.statusBarHeight
				if (statusBarHeight > 0) this.safeTop = statusBarHeight
				this.safeBottom = this.bottomSafeInset(info.safeAreaInsets.bottom, info.windowBottom)
			} catch (_) {}
		},
		bottomSafeInset(safeAreaBottom: number, windowBottom: number): number {
			const bottom = safeAreaBottom > windowBottom ? safeAreaBottom : windowBottom
			return bottom > 0 ? bottom : 0
		},
		applyResponsiveLayout(width: number, height: number, screenWidth: number) {
			if (screenWidth > 0) {
				this.screenWidth = screenWidth
				const halfWidth = Math.floor(screenWidth / 2)
				this.compactBreakpoint = halfWidth > 430 ? halfWidth : 430
				this.iconSidebarBreakpoint = Math.floor(screenWidth * 2 / 3)
			}
			if (width > 0) {
				this.windowWidth = width
				this.maxSidebarWidth = this.availableThreadListMaxWidth(width)
				if (!this.layoutInitialized) {
					this.sidebarWidth = this.clampWidth(this.desiredThreadListWidth(width))
					this.expandedSidebarWidth = this.sidebarWidth
					this.layoutInitialized = true
				} else if (this.sidebarWidth > this.maxSidebarWidth) {
					this.sidebarWidth = this.maxSidebarWidth
					this.expandedSidebarWidth = this.sidebarWidth
				} else if (this.sidebarWidth < this.minSidebarWidth) {
					this.sidebarWidth = this.minSidebarWidth
					this.expandedSidebarWidth = this.sidebarWidth
				}
				this.isCompactChat = width <= this.compactBreakpoint
				this.isIconSidebar = !this.isCompactChat && width < this.iconSidebarBreakpoint
				if (this.isCompactChat) this.resizing = false
				if (!this.isCompactChat) this.compactDrawerOpen = false
			}
			if (height > 0) this.windowHeight = height
		},
		pageStyle(): string {
			return 'height:' + this.pageContentHeight().toString() + 'px;padding-bottom:' + this.safeBottom.toString() + 'px;'
		},
		appPageClass(): string {
			return this.isNightTheme() ? 'app-page theme-night' : 'app-page'
		},
		isNightTheme(): boolean {
			return this.appTheme == 'night'
		},
		changeAppTheme(theme: string) {
			const next = normalizeAppTheme(theme)
			if (this.appTheme == next) return
			this.appTheme = next
			setAppTheme(next)
			this.rebuildMessageViews()
		},
		themeOptionClass(theme: string): string {
			return this.appTheme == theme ? 'settings-theme-option-active' : ''
		},
		themeOptionTextClass(theme: string): string {
			return this.appTheme == theme ? 'settings-theme-option-text-active' : ''
		},
		pageContentHeight(): number {
			const height = this.windowHeight - this.safeBottom
			return height > 320 ? height : 320
		},
		contentHeight(): number {
			return this.pageContentHeight()
		},
		surfaceHeight(): number {
			return this.pageContentHeight()
		},
		surfaceBottomInset(): number {
			return 0
		},
			settingsDialogCompact(): boolean {
				return this.windowWidth <= 430
			},
			settingsDialogWidth(): number {
				const viewport = this.windowWidth > 0 ? this.windowWidth : 350
				const maxWidth = this.settingsDialogCompact() ? viewport - 24 : viewport - 48
				let width = maxWidth
				if (width > 450) width = 450
				if (width < 300 && maxWidth >= 300) width = 300
				return width
			},
			settingsDialogPadding(): number {
				return this.settingsDialogCompact() ? 18 : 22
			},
			settingsDialogHeight(): number {
				return this.settingsDialogCompact() ? 492 : 506
			},
			settingsDialogStyle(): string {
				return 'width:' + this.settingsDialogWidth().toString() + 'px;height:' + this.settingsDialogHeight().toString() + 'px;padding:' + this.settingsDialogPadding().toString() + 'px;'
			},
			settingsDialogLeft(): number {
				const width = this.settingsDialogWidth()
				const viewport = this.windowWidth > 0 ? this.windowWidth : width
				const left = (viewport - width) / 2
				return left > 0 ? left : 0
			},
			settingsDialogTop(): number {
				const height = this.settingsDialogHeight()
				const viewport = this.windowHeight > 0 ? this.windowHeight : height
				const top = (viewport - height) / 2
				return top > 0 ? top : 0
			},
			isInsideSettingsDialog(x: number, y: number): boolean {
				const left = this.settingsDialogLeft()
				const top = this.settingsDialogTop()
				const width = this.settingsDialogWidth()
				const height = this.settingsDialogHeight()
				return x >= left && x <= left + width && y >= top && y <= top + height
			},
			dropDialogCompact(): boolean {
				return this.windowWidth <= 430
			},
			dropDialogWidth(): number {
				const viewport = this.windowWidth > 0 ? this.windowWidth : 350
				const maxWidth = this.dropDialogCompact() ? viewport - 24 : viewport - 48
				let width = maxWidth
				if (width > 500) width = 500
				if (width < 280 && maxWidth >= 280) width = 280
				return width
			},
			dropDialogPadding(): number {
				return this.dropDialogCompact() ? 18 : 24
			},
			dropDialogPreviewHeight(): number {
				if (!this.dropDialogCompact()) return 320
				const height = Math.floor(this.dropDialogWidth() * 0.82)
				if (height < 220) return 220
				if (height > 292) return 292
				return height
			},
			dropDialogHeight(): number {
				const padding = this.dropDialogPadding()
				const preview = this.dropDialogPreviewHeight()
				const input = 16 + 56
				const error = this.dropSendError.length > 0 ? 30 : 0
				const actions = this.dropDialogCompact() ? 16 + 64 : 20 + 64
				return padding * 2 + preview + input + error + actions
			},
		dropDialogStyle(): string {
			const padding = this.dropDialogPadding()
			return 'width:' + this.dropDialogWidth().toString() + 'px;height:' + this.dropDialogHeight().toString() + 'px;padding:' + padding.toString() + 'px;'
		},
		dropDialogPreviewStyle(): string {
			return 'height:' + this.dropDialogPreviewHeight().toString() + 'px;'
		},
		windowStyle(): string {
			return 'height:' + this.pageContentHeight().toString() + 'px;'
		},
		mainSurfaceStyle(): string {
			if (this.isCompactChat) return 'top:0px;bottom:' + this.cardBottomInset().toString() + 'px;'
			return 'top:' + this.cardTopInset().toString() + 'px;bottom:' + this.cardBottomInset().toString() + 'px;left:' + this.interPaneGap().toString() + 'px;right:' + this.contentGutter().toString() + 'px;'
		},
		sidebarStyle(): string {
			const width = this.railCompact() ? this.collapsedRailWidth() : this.railWidth()
			return 'width:' + width.toString() + 'px;height:' + this.contentHeight().toString() + 'px;padding-top:' + this.cardTopInset().toString() + 'px;padding-bottom:' + this.cardBottomInset().toString() + 'px;'
		},
		splitterStyle(): string {
			return 'height:' + this.surfaceHeight().toString() + 'px;width:0px;margin-top:0px;'
		},
		chatShellStyle(): string {
			const width = this.chatAreaWidth()
			return 'height:' + this.chatCardHeight().toString() + 'px;width:' + (width > 240 ? width : 240).toString() + 'px;'
		},
		tabCardStyle(): string {
			return 'height:' + this.chatCardHeight().toString() + 'px;width:100%;'
		},
		threadListCardStyle(): string {
			const width = this.threadListPaneWidth()
			return 'width:' + (width > 180 ? width : 180).toString() + 'px;'
		},
		paneGapStyle(): string {
			return 'width:' + this.interPaneGap().toString() + 'px;'
		},
		embeddedWebContainerStyle(): string {
			const height = this.embeddedWebContentHeight()
			return 'width:100%;height:' + (height > 120 ? height : 120).toString() + 'px;'
		},
		compactWebMenuButtonStyle(): string {
			return 'top:' + (this.safeTop + 14).toString() + 'px;'
		},
		showCompactDrawerThreadList(): boolean {
			return this.activeRailMode == 'conversation'
		},
		compactDrawerThreadListWidth(): number {
			const viewport = this.windowWidth > 0 ? this.windowWidth : 360
			const available = viewport - 24 - this.railWidth() - 12
			if (available > 228) return 228
			if (available > 180) return available
			return 180
		},
		compactDrawerPanelStyle(): string {
			const innerWidth = this.showCompactDrawerThreadList() ? this.railWidth() + 12 + this.compactDrawerThreadListWidth() : this.railWidth()
			return 'width:' + innerWidth.toString() + 'px;top:' + (this.safeTop + 10).toString() + 'px;bottom:' + (this.safeBottom + 10).toString() + 'px;'
		},
		compactDrawerThreadListStyle(): string {
			return 'width:' + this.compactDrawerThreadListWidth().toString() + 'px;height:100%;'
		},
		annotationOverlayStyle(): string {
			return 'width:' + this.embeddedWebWidth().toString() + 'px;height:' + this.embeddedWebContentHeight().toString() + 'px;'
		},
		annotationStageStyle(): string {
			return pxSizeStyle(this.annotationStageWidth, this.annotationStageHeight)
		},
		annotationImageStyle(): string {
			return pxSizeStyle(this.annotationStageWidth, this.annotationStageHeight)
		},
		titleBarStyle(): string {
			const height = this.titleBarOffset() - 1
			return 'top:1px;height:' + (height > 40 ? height : 40).toString() + 'px;padding-top:' + this.titlePaddingTop().toString() + 'px;'
		},
		chatBodyStyle(): string {
			const height = this.chatCardHeight() - this.titleBarOffset()
			const safeHeight = height > 180 ? height - 1 : this.chatCardHeight() - 1
			return 'margin-top:' + this.titleBarOffset().toString() + 'px;height:' + safeHeight.toString() + 'px;'
		},
		chatContentHeight(): number {
			const height = this.chatCardHeight() - this.titleBarOffset() - this.composerHeight() - this.composerBottomGap() - 12
			return height > 120 ? height : 120
		},
		chatScrollStyle(): string {
			return 'height:' + this.chatContentHeight().toString() + 'px;'
		},
		chatScrollContentStyle(): string {
			const horizontal = this.chatHorizontalPadding() + 14
			const top = this.chatScrollTopPadding() + 10
			const bottom = this.chatScrollBottomPadding() + 18
			return 'padding-left:' + horizontal.toString() + 'px;padding-right:' + horizontal.toString() + 'px;padding-bottom:' + bottom.toString() + 'px;padding-top:' + top.toString() + 'px;'
		},
			messageImageStyle(): string {
				const available = this.chatContentHeight() - 24
				if (available <= 120) return 'height:120px;'
				let height = Math.floor(available * 0.72)
				if (height > 480) height = 480
				if (height < 180) height = 180
				if (height > available) height = available
				return 'height:' + height.toString() + 'px;'
			},
			composerStyle(): string {
				const padding = this.chatHorizontalPadding()
				return 'left:' + padding.toString() + 'px;right:' + padding.toString() + 'px;bottom:' + this.composerBottomGap().toString() + 'px;height:' + this.composerHeight().toString() + 'px;'
			},
			composerContentStyle(): string {
				return 'height:' + this.composerContentHeight().toString() + 'px;'
			},
			composerInputStyle(): string {
				return 'height:' + this.composerInputHeight().toString() + 'px;'
			},
		sidebarTopPadding(): number {
			return this.safeTop > 0 ? this.safeTop + 8 : 10
		},
		cardTopInset(): number {
			return this.sidebarTopPadding()
		},
		cardBottomInset(): number {
			return 18
		},
		chatCardHeight(): number {
			if (this.isCompactChat) {
				const compactHeight = this.surfaceHeight() - this.cardBottomInset()
				return compactHeight > 320 ? compactHeight : 320
			}
			const height = this.surfaceHeight() - this.cardTopInset() - this.cardBottomInset()
			return height > 320 ? height : 320
		},
		titlePaddingTop(): number {
			return this.isCompactChat ? this.safeTop : 0
		},
		titleBarOffset(): number {
			return this.isCompactChat ? 54 + this.safeTop : 58
		},
		chatScrollTopPadding(): number {
			return 8
		},
		chatScrollBottomPadding(): number {
			return this.composerHeight() + 34
		},
			composerEstimatedLineCount(): number {
				const text = this.prompt.length > 0 ? this.prompt : ' '
				const width = this.chatAreaWidth() - (this.chatHorizontalPadding() * 2) - 34
				const safeWidth = width > 180 ? width : 180
				const charsPerLine = Math.floor(safeWidth / 9)
				const safeChars = charsPerLine > 18 ? charsPerLine : 18
				const lines = text.split('\n')
				let count = 0
				for (let index: Int = 0; index < lines.length; index++) {
					const line = lines[index]
					const wrapped = Math.floor(line.length / safeChars) + 1
					count = count + (wrapped > 1 ? wrapped : 1)
				}
				if (count < 1) return 1
				if (count > 8) return 8
				return count
			},
			composerInputHeight(): number {
				if (this.isAssistantVoiceFirstComposer()) return 40
				const height = this.composerEstimatedLineCount() * 26 + 12
				if (height < 44) return 44
				if (height > 222) return 222
				return height
			},
			composerAttachmentRows(): number {
				const count = this.composerAttachments.length
				if (count <= 0) return 0
				const width = this.chatAreaWidth() - (this.chatHorizontalPadding() * 2) - 8
				const safeWidth = width > 160 ? width : 160
				const itemWidth = 94
				let perRow = Math.floor(safeWidth / itemWidth)
				if (perRow < 1) perRow = 1
				let rows = Math.floor((count + perRow - 1) / perRow)
				if (rows < 1) rows = 1
				return rows
			},
			composerAttachmentHeight(): number {
				const rows = this.composerAttachmentRows()
				if (rows <= 0) return 0
				return rows * 94 + 8
			},
			composerContentHeight(): number {
				if (this.isAssistantVoiceFirstComposer()) return 52
				const inputHeight = this.composerInputHeight()
				return inputHeight + this.composerAttachmentHeight()
			},
			composerHeight(): number {
				if (this.isAssistantVoiceFirstComposer()) return 72
				const height = this.composerContentHeight() + 82
				if (height < 124) return 124
				if (height > 420) return 420
				return height
			},
		composerBottomGap(): number {
			return 16
		},
		chatHorizontalPadding(): number {
			const width = this.chatAreaWidth()
			if (width < 560) return 14
			if (width < 760) return 20
			return 28
		},
		chatAreaWidth(): number {
			if (this.isCompactChat) return this.windowWidth
			if (!this.showThreadListPane()) return this.mainContentWidth()
			const width = this.chatPaneWidth()
			return width > 240 ? width : 240
		},
		mainContentWidth(): number {
			const rail = this.railCompact() ? this.collapsedRailWidth() : this.railWidth()
			const width = this.windowWidth - rail - this.interPaneGap() - this.contentGutter()
			return width > 240 ? width : 240
		},
		chatWorkspaceWidth(): number {
			return this.mainContentWidth()
		},
		threadListPaneWidth(): number {
			if (!this.showThreadListPane()) return 0
			const width = this.chatWorkspaceWidth() - this.chatPaneWidth() - this.interPaneGap()
			return width > 180 ? width : 180
		},
		chatPaneWidth(): number {
			if (!this.showThreadListPane()) return this.chatWorkspaceWidth()
			let width = Math.floor(this.windowWidth / 2)
			const maxWidth = this.chatWorkspaceWidth() - this.interPaneGap() - 180
			if (width > maxWidth) width = maxWidth
			return width > 240 ? width : 240
		},
		showThreadListPane(): boolean {
			return !this.isCompactChat && !this.railCompact() && !this.userSidebarCollapsed && this.activeRailMode == 'conversation'
		},
		embeddedWebWidth(): number {
			return this.mainContentWidth()
		},
		embeddedWebContentHeight(): number {
			const height = this.chatCardHeight()
			return height > 120 ? height : 120
		},
		contentGutter(): number {
			return 12
		},
		interPaneGap(): number {
			return 12
		},
		actualSidebarWidth(): number {
			if (this.railCompact()) return this.collapsedRailWidth()
			return this.balancedPaneWidth(this.windowWidth)
		},
		balancedPaneWidth(totalWidth: number): number {
			const available = totalWidth - (this.contentGutter() * 2)
			const width = Math.floor(available / 2)
			return width > this.collapsedRailWidth() ? width : this.collapsedRailWidth()
		},
		railWidth(): number {
			return 78
		},
		collapsedRailWidth(): number {
			return 48
		},
		sidebarGap(): number {
			return this.contentGutter()
		},
		sidebarChromeWidth(): number {
			return this.railWidth() + this.sidebarGap()
		},
		minChatWidthFor(totalWidth: number): number {
			return Math.floor(totalWidth / 2)
		},
		minReadableChatWidthFor(totalWidth: number): number {
			return this.minChatWidthFor(totalWidth)
		},
		desiredThreadListWidth(totalWidth: number): number {
			if (totalWidth >= 1320) return 270
			if (totalWidth >= 1100) return 250
			return 230
		},
		availableThreadListMaxWidth(totalWidth: number): number {
			let maxWidth = this.balancedPaneWidth(totalWidth) - this.sidebarChromeWidth()
			if (maxWidth < this.minSidebarWidth) maxWidth = this.minSidebarWidth
			return maxWidth
		},
		effectiveSidebarCollapsed(): boolean {
			return this.railCompact()
		},
		railCompact(): boolean {
			return this.isIconSidebar
		},
		threadTimeText(thread: CodexThread): string {
			if (thread.runtimeActive) return '现在'
			const value = thread.lastMessageAt.length > 0 ? thread.lastMessageAt : thread.updatedAt
			return this.relativeTime(value)
		},
			processEventLabel(event: CodexProcessEvent): string {
				if (event.kind == 'tool_call') return event.name.length > 0 ? '工具 ' + event.name : '工具调用'
				if (event.kind == 'tool_result') return '工具结果'
				if (event.kind == 'task_started') return '开始处理'
				if (event.kind == 'task_complete') return '处理完成'
				if (event.kind == 'task_error') return '错误'
				return '过程'
			},
			liveStatusText(): string {
				if (this.codexRunning) {
					if (this.watchSendId.length > 0) return '正在等待 Codex 输出...'
					return '正在读取 Codex 会话更新...'
				}
				if (this.processEvents.length > 0) {
					const last = this.processEvents[(this.processEvents.length - 1).toInt()]
					if (last.kind == 'task_error') return last.text
				}
				return ''
			},
		markdownTextColor(): string {
			return this.isNightTheme() ? '#e8edf7' : '#242424'
		},
		markdownHeadingColor(): string {
			return this.isNightTheme() ? '#f4efe7' : '#1f1f1f'
		},
		markdownWeakColor(): string {
			return this.isNightTheme() ? '#8f98aa' : '#777777'
		},
		markdownLinkColor(): string {
			return this.isNightTheme() ? '#b88cff' : '#1663c7'
		},
		markdownCodeBgColor(): string {
			return this.isNightTheme() ? '#151a24' : '#f4f4f4'
		},
		markdownCodeTextColor(): string {
			return this.isNightTheme() ? '#f2e9dc' : '#202020'
		},
		markdownInlineCodeBgColor(): string {
			return this.isNightTheme() ? '#252b39' : '#eeeeee'
		},
		markdownRuleColor(): string {
			return this.isNightTheme() ? 'rgba(255,255,255,0.12)' : '#e6e6e6'
		},
		markdownQuoteBgColor(): string {
			return this.isNightTheme() ? '#1d2432' : '#f7f5f2'
		},
		markdownQuoteBorderColor(): string {
			return this.isNightTheme() ? '#d6a64e' : '#d0d0d0'
		},
		markdownQuoteTextColor(): string {
			return this.isNightTheme() ? '#d7deeb' : '#444444'
		},
		markdownTableBorderColor(): string {
			return this.isNightTheme() ? 'rgba(255,255,255,0.13)' : '#dddddd'
		},
		markdownTableHeadBgColor(): string {
			return this.isNightTheme() ? '#242b3a' : '#f5f5f5'
		},
		renderMarkdownHtml(text: string): string {
			const lines = text.replace('\r\n', '\n').split('\n')
			let html = ''
			let index: Int = 0
			while (index < lines.length) {
				const line = lines[index]
				const trimmed = line.trim()
				if (trimmed.length == 0) {
					index = index + 1
					continue
				}
				if (trimmed.startsWith('```') || trimmed.startsWith('~~~')) {
					const fence = trimmed.substring(0, 3)
					let code = ''
					index = index + 1
					while (index < lines.length && !lines[index].trim().startsWith(fence)) {
						code = code.length == 0 ? lines[index] : code + '\n' + lines[index]
						index = index + 1
					}
					if (index < lines.length) index = index + 1
					html = html + '<pre style="margin:10px 0;padding:12px;border-radius:10px;background:' + this.markdownCodeBgColor() + ';white-space:pre-wrap;word-break:break-all;"><code style="font-family:monospace;font-size:13px;line-height:21px;color:' + this.markdownCodeTextColor() + ';">' + this.escapeHtml(code) + '</code></pre>'
					continue
				}
				if (this.isMarkdownHr(trimmed)) {
					html = html + '<hr style="height:1px;border:0;background:' + this.markdownRuleColor() + ';margin:14px 0;" />'
					index = index + 1
					continue
				}
				if (this.headingLevel(trimmed) > 0) {
					const level = this.headingLevel(trimmed)
					const body = trimmed.substring(level).trim()
					const size = level == 1 ? 22 : (level == 2 ? 19 : 16)
					html = html + '<h' + level.toString() + ' style="margin:14px 0 8px;font-size:' + size.toString() + 'px;line-height:' + (size + 8).toString() + 'px;font-weight:700;color:' + this.markdownHeadingColor() + ';">' + this.parseInlineMarkdown(body) + '</h' + level.toString() + '>'
					index = index + 1
					continue
				}
				if (this.isTableStart(lines, index)) {
					html = html + this.renderMarkdownTable(lines, index)
					index = index + 2
					while (index < lines.length && this.isTableLine(lines[index])) index = index + 1
					continue
				}
				if (trimmed.startsWith('>')) {
					let quote = ''
					while (index < lines.length && lines[index].trim().startsWith('>')) {
						let value = lines[index].trim()
						value = value.substring(1).trim()
						quote = quote.length == 0 ? value : quote + '\n' + value
						index = index + 1
					}
					html = html + '<blockquote style="margin:10px 0;padding:8px 12px;border-left:3px solid ' + this.markdownQuoteBorderColor() + ';background:' + this.markdownQuoteBgColor() + ';color:' + this.markdownQuoteTextColor() + ';font-size:15px;line-height:25px;">' + this.parseInlineMarkdown(quote).replace('\n', '<br/>') + '</blockquote>'
					continue
				}
				const listKind = this.markdownListKind(trimmed)
				if (listKind.length > 0) {
					const tag = listKind == 'ordered' ? 'ol' : 'ul'
					html = html + '<' + tag + ' style="margin:8px 0 10px;padding-left:22px;font-size:15px;line-height:25px;color:' + this.markdownTextColor() + ';">'
					while (index < lines.length && this.markdownListKind(lines[index].trim()) == listKind) {
						html = html + '<li style="margin:3px 0;">' + this.parseInlineMarkdown(this.markdownListText(lines[index].trim())) + '</li>'
						index = index + 1
					}
					html = html + '</' + tag + '>'
					continue
				}
				let paragraph = trimmed
				index = index + 1
				while (index < lines.length && !this.isMarkdownBlockStart(lines, index)) {
					const next = lines[index].trim()
					if (next.length == 0) break
					paragraph = paragraph + '\n' + next
					index = index + 1
				}
				html = html + '<p style="margin:0 0 12px;font-size:15px;line-height:25px;color:' + this.markdownTextColor() + ';word-break:break-all;">' + this.parseInlineMarkdown(paragraph).replace('\n', '<br/>') + '</p>'
			}
			return html
		},
		escapeHtml(text: string): string {
			return text.split('&').join('&amp;').split('<').join('&lt;').split('>').join('&gt;').split('"').join('&quot;').split("'").join('&#39;')
		},
		escapeHtmlChar(ch: string): string {
			if (ch == '&') return '&amp;'
			if (ch == '<') return '&lt;'
			if (ch == '>') return '&gt;'
			if (ch == '"') return '&quot;'
			if (ch == "'") return '&#39;'
			if (ch == '\n') return '<br/>'
			const canBreak = ch == '/' || ch == '\\' || ch == '_' || ch == '-' || ch == '.' || ch == ':' || ch == '?' || ch == '&' || ch == '=' || ch == '#'
			return canBreak ? ch + '&#8203;' : ch
		},
		parseInlineMarkdown(text: string): string {
			let html = ''
			let index: Int = 0
			while (index < text.length) {
				const rest = text.substring(index)
				if (rest.startsWith('`')) {
					const end = text.indexOf('`', index + 1)
					if (end > index) {
						html = html + '<code style="padding:1px 5px;border-radius:5px;background:' + this.markdownInlineCodeBgColor() + ';font-family:monospace;font-size:13px;color:' + this.markdownCodeTextColor() + ';">' + this.escapeHtml(text.substring(index + 1, end)) + '</code>'
						index = (end + 1).toInt()
						continue
					}
				}
				if (rest.startsWith('![')) {
					const close = text.indexOf('](', index + 2)
					const end = close >= 0 ? text.indexOf(')', close + 2) : -1
					if (close > index && end > close) {
						const alt = text.substring(index + 2, close)
						const url = text.substring(close + 2, end)
						html = html + '<a href="' + this.escapeHtml(url) + '" style="color:' + this.markdownLinkColor() + ';text-decoration:none;">图片：' + this.escapeHtml(alt.length > 0 ? alt : url) + '</a>'
						index = (end + 1).toInt()
						continue
					}
				}
				if (rest.startsWith('[')) {
					const close = text.indexOf('](', index + 1)
					const end = close >= 0 ? text.indexOf(')', close + 2) : -1
					if (close > index && end > close) {
						const label = text.substring(index + 1, close)
						const url = text.substring(close + 2, end)
						html = html + '<a href="' + this.escapeHtml(url) + '" style="color:' + this.markdownLinkColor() + ';text-decoration:none;">' + this.parseInlineMarkdown(label) + '</a>'
						index = (end + 1).toInt()
						continue
					}
				}
				if (rest.startsWith('**') || rest.startsWith('__')) {
					const marker = rest.startsWith('**') ? '**' : '__'
					const end = text.indexOf(marker, index + 2)
					if (end > index) {
						html = html + '<strong style="font-weight:700;">' + this.parseInlineMarkdown(text.substring(index + 2, end)) + '</strong>'
						index = (end + 2).toInt()
						continue
					}
				}
				if (rest.startsWith('~~')) {
					const end = text.indexOf('~~', index + 2)
					if (end > index) {
						html = html + '<del style="color:' + this.markdownWeakColor() + ';">' + this.parseInlineMarkdown(text.substring(index + 2, end)) + '</del>'
						index = (end + 2).toInt()
						continue
					}
				}
				if (rest.startsWith('*')) {
					const end = text.indexOf('*', index + 1)
					if (end > index) {
						html = html + '<em style="font-style:italic;">' + this.parseInlineMarkdown(text.substring(index + 1, end)) + '</em>'
						index = (end + 1).toInt()
						continue
					}
				}
				html = html + this.escapeHtmlChar(text.substring(index, index + 1))
				index = index + 1
			}
			return html
		},
		headingLevel(line: string): number {
			let level = 0
			while (level < line.length && level < 6 && line.substring(level, level + 1) == '#') level = level + 1
			if (level == 0 || level >= line.length) return 0
			return line.substring(level, level + 1) == ' ' ? level : 0
		},
		isMarkdownHr(line: string): boolean {
			if (line.length < 3) return false
			let ch = line.substring(0, 1)
			if (ch != '-' && ch != '*' && ch != '_') return false
			for (let index: Int = 0; index < line.length; index++) {
				const value = line.substring(index, index + 1)
				if (value != ch && value != ' ') return false
			}
			return true
		},
		markdownListKind(line: string): string {
			if (line.startsWith('- ') || line.startsWith('* ') || line.startsWith('+ ') || line.startsWith('- [ ] ') || line.startsWith('- [x] ') || line.startsWith('- [X] ')) return 'unordered'
			const dot = line.indexOf('. ')
			if (dot > 0 && dot <= 3 && this.isDigits(line.substring(0, dot))) return 'ordered'
			return ''
		},
		markdownListText(line: string): string {
			if (line.startsWith('- [ ] ')) return '☐ ' + line.substring(6)
			if (line.startsWith('- [x] ') || line.startsWith('- [X] ')) return '☑ ' + line.substring(6)
			if (line.startsWith('- ') || line.startsWith('* ') || line.startsWith('+ ')) return line.substring(2)
			const dot = line.indexOf('. ')
			if (dot > 0 && dot <= 3 && this.isDigits(line.substring(0, dot))) return line.substring(dot + 2)
			return line
		},
		isTableLine(line: string): boolean {
			return line.indexOf('|') >= 0
		},
		isTableStart(lines: Array<string>, index: Int): boolean {
			if (index + 1 >= lines.length) return false
			return this.isTableLine(lines[index]) && this.isTableSeparator(lines[index + 1])
		},
		isTableSeparator(line: string): boolean {
			if (!this.isTableLine(line)) return false
			const cells = this.splitTableRow(line)
			if (cells.length == 0) return false
			for (let index: Int = 0; index < cells.length; index++) {
				const cell = cells[index].trim()
				if (cell.length < 3) return false
				for (let charIndex: Int = 0; charIndex < cell.length; charIndex++) {
					const ch = cell.substring(charIndex, charIndex + 1)
					if (ch != '-' && ch != ':' && ch != ' ') return false
				}
			}
			return true
		},
		splitTableRow(line: string): Array<string> {
			let value = line.trim()
			if (value.startsWith('|')) value = value.substring(1)
			if (value.endsWith('|')) value = value.substring(0, value.length - 1)
			return value.split('|')
		},
		renderMarkdownTable(lines: Array<string>, start: Int): string {
			const headers = this.splitTableRow(lines[start])
			let html = '<table style="width:100%;margin:10px 0;border-collapse:collapse;font-size:14px;line-height:22px;color:' + this.markdownTextColor() + ';">'
			html = html + '<thead><tr>'
			for (let index: Int = 0; index < headers.length; index++) html = html + '<th style="padding:6px;border:1px solid ' + this.markdownTableBorderColor() + ';background:' + this.markdownTableHeadBgColor() + ';font-weight:700;">' + this.parseInlineMarkdown(headers[index].trim()) + '</th>'
			html = html + '</tr></thead><tbody>'
			let rowIndex: Int = start + 2
			while (rowIndex < lines.length && this.isTableLine(lines[rowIndex])) {
				const cells = this.splitTableRow(lines[rowIndex])
				html = html + '<tr>'
				for (let cellIndex: Int = 0; cellIndex < headers.length; cellIndex++) {
					const cell = cellIndex < cells.length ? cells[cellIndex].trim() : ''
					html = html + '<td style="padding:6px;border:1px solid ' + this.markdownTableBorderColor() + ';">' + this.parseInlineMarkdown(cell) + '</td>'
				}
				html = html + '</tr>'
				rowIndex = rowIndex + 1
			}
			return html + '</tbody></table>'
		},
		isMarkdownBlockStart(lines: Array<string>, index: Int): boolean {
			if (index >= lines.length) return true
			const line = lines[index].trim()
			if (line.length == 0) return true
			if (line.startsWith('```') || line.startsWith('~~~') || line.startsWith('>')) return true
			if (this.headingLevel(line) > 0 || this.isMarkdownHr(line) || this.markdownListKind(line).length > 0) return true
			return this.isTableStart(lines, index)
		},
			copyMessage(message: ChatMessageView) {
				this.copyText(message.text)
			},
		copyText(text: string) {
			if (text.length == 0) {
				uni.showToast({ title: '没有可复制内容', icon: 'none' })
				return
			}
			// #ifdef APP-ANDROID
			try {
				const activity = UTSAndroid.getUniActivity()
				if (activity != null) {
					const manager = activity.getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
					const clip = ClipData.newPlainText("vibego", text)
					manager.setPrimaryClip(clip)
					uni.showToast({ title: '复制成功', icon: 'success' })
					return
				}
			} catch (e) {
				console.log('[vibego]', 'clipboard-write-failed', e)
			}
			// #endif
			uni.setClipboardData({
				data: text,
				success: () => {
					uni.showToast({ title: '复制成功', icon: 'success' })
				},
				fail: () => {
					uni.showToast({ title: '复制失败', icon: 'none' })
				}
			})
		},
			buildMessageView(message: ChatMessage): ChatMessageView {
				for (let index: Int = 0; index < this.messageViewCacheIds.length; index++) {
					if (this.messageViewCacheIds[index] == message.id) return this.messageViewCacheValues[index]
				}
			const view: ChatMessageView = {
				id: message.id,
				role: message.role,
				label: message.label,
				text: message.text,
				timestamp: message.timestamp,
				blocks: message.role == 'assistant' ? this.renderMessageBlocks(message.text) : new Array<ChatTextBlock>(),
			}
			this.messageViewCacheIds.push(message.id)
			this.messageViewCacheValues.push(view)
			return view
		},
		clearMessageViewCache() {
			this.messageViewCacheIds = new Array<string>()
			this.messageViewCacheValues = new Array<ChatMessageView>()
		},
		removeMessageViewCache(messageId: string) {
			const nextIds = new Array<string>()
			const nextValues = new Array<ChatMessageView>()
			for (let index: Int = 0; index < this.messageViewCacheIds.length; index++) {
				if (this.messageViewCacheIds[index] != messageId) {
					nextIds.push(this.messageViewCacheIds[index])
					nextValues.push(this.messageViewCacheValues[index])
				}
			}
			this.messageViewCacheIds = nextIds
			this.messageViewCacheValues = nextValues
		},
		resetMessageViews() {
			this.messageViews = new Array<ChatMessageView>()
			this.clearMessageViewCache()
		},
		rebuildMessageViews() {
			const views = new Array<ChatMessageView>()
			let count: Int = this.visibleMessageCount.toInt()
			if (count <= 0) count = this.messageViewStep.toInt()
			if (count > this.messages.length) count = this.messages.length.toInt()
			let start: Int = 0
			if (this.messages.length > count) start = (this.messages.length - count).toInt()
			for (let index: Int = start; index < this.messages.length; index++) {
				views.push(this.buildMessageView(this.messages[index]))
			}
			this.messageViews = views
		},
		appendMessageView(message: ChatMessage) {
			this.messageViews.push(this.buildMessageView(message))
			if (this.visibleMessageCount < this.messageViews.length) this.visibleMessageCount = this.messageViews.length.toInt()
			this.markRecentMessage(message.id)
		},
		replaceMessageView(messageId: string, message: ChatMessage): boolean {
			for (let index: Int = 0; index < this.messageViews.length; index++) {
				if (this.messageViews[index].id == messageId) {
					this.messageViews[index] = this.buildMessageView(message)
					return true
				}
			}
			return false
		},
		hasEarlierMessages(): boolean {
			return this.messages.length > this.messageViews.length
		},
		loadEarlierMessages() {
			const previousLength: Int = this.messageViews.length.toInt()
			this.visibleMessageCount = (this.visibleMessageCount + this.messageViewStep).toInt()
			this.rebuildMessageViews()
			if (this.messageViews.length > previousLength) {
				this.chatScrollTop = 1
				this.chatScrollIntoView = ''
			}
		},
		userMessageStyle(): string {
			const width = Math.floor(this.chatAreaWidth() * 0.76)
			return 'max-width:' + (width > 220 ? width : 220).toString() + 'px;'
		},
		wrapDisplayText(text: string, maxRun: number): string {
			if (text.length == 0 || maxRun <= 0) return text
			let wrapped = ''
			let runLength = 0
			for (let index: Int = 0; index < text.length; index++) {
				const ch = text.substring(index, index + 1)
				if (ch == '\n' || ch == '\r') {
					wrapped = wrapped + ch
					runLength = 0
					continue
				}
				const isBreakChar = ch == ' ' || ch == '\t' || ch == '/' || ch == '\\' || ch == '_' || ch == '-' || ch == '.' || ch == ':' || ch == '?' || ch == '&' || ch == '=' || ch == '#' || ch == '(' || ch == ')' || ch == '[' || ch == ']' || ch == '{' || ch == '}'
				if (runLength >= maxRun) {
					wrapped = wrapped + '\n'
					runLength = 0
				}
				wrapped = wrapped + ch
				runLength = isBreakChar ? 0 : runLength + 1
			}
			return wrapped
		},
		plainMarkdownText(text: string): string {
			let value = text
			while (true) {
				const open = value.indexOf('](')
				if (open < 0) break
				const start = value.lastIndexOf('[', open)
				const end = value.indexOf(')', open + 2)
				if (start < 0 || end < 0) break
				const label = value.substring(start + 1, open)
				value = value.substring(0, start) + label + value.substring(end + 1)
			}
			value = value.split('**').join('')
			value = value.split('__').join('')
			value = value.split('~~').join('')
			value = value.split('`').join('')
			return value
		},
		appendPlainTextSegments(segments: Array<ChatTextSegment>, text: string, linkify: boolean) {
			const value = this.plainMarkdownText(text)
			if (value.length == 0) return
			if (!linkify) {
				segments.push({ kind: 'text', text: value, url: '' })
				return
			}
			const urlRegex = /https?:\/\/[^\s]+/g
			let lastIndex = 0
			let match: RegExpExecArray | null
			while (true) {
				match = urlRegex.exec(value)
				if (match == null) break
				const start = match.index
				const url = match[0]!!
				if (start > lastIndex) {
					segments.push({ kind: 'text', text: value.substring(lastIndex, start), url: '' })
				}
				segments.push({ kind: 'url', text: url, url: url })
				lastIndex = start + url.length
			}
			if (lastIndex < value.length) {
				segments.push({ kind: 'text', text: value.substring(lastIndex), url: '' })
			}
		},
		textSegments(text: string, linkify: boolean): Array<ChatTextSegment> {
			const segments = new Array<ChatTextSegment>()
			if (!linkify || text.length == 0) {
				segments.push({ kind: 'text', text: this.plainMarkdownText(text), url: '' })
				return segments
			}
			let lastIndex = 0
			while (true) {
				const open = text.indexOf('](', lastIndex)
				if (open < 0) break
				const start = text.lastIndexOf('[', open)
				const end = text.indexOf(')', open + 2)
				if (start < lastIndex || end < 0) break
				if (start > lastIndex) {
					this.appendPlainTextSegments(segments, text.substring(lastIndex, start), true)
				}
				const label = this.plainMarkdownText(text.substring(start + 1, open)).trim()
				const url = text.substring(open + 2, end).trim()
				if (label.length > 0 && url.length > 0) {
					segments.push({ kind: 'url', text: label, url: url })
				}
				lastIndex = end + 1
			}
			if (lastIndex < text.length) {
				this.appendPlainTextSegments(segments, text.substring(lastIndex), true)
			}
			if (segments.length == 0) {
				segments.push({ kind: 'text', text: this.plainMarkdownText(text), url: '' })
			}
			return segments
		},
		onTextSegmentClick(seg: ChatTextSegment) {
			if (seg.kind != 'url') return
			this.openUrl(seg.url.length > 0 ? seg.url : seg.text)
		},
		normalizeWebUrl(url: string): string {
			let value = url.trim()
			while (value.endsWith('。') || value.endsWith('，') || value.endsWith('、') || value.endsWith('；') || value.endsWith('：') || value.endsWith('.') || value.endsWith(',') || value.endsWith(';') || value.endsWith(')') || value.endsWith(']')) {
				value = value.substring(0, value.length - 1).trim()
			}
			if (value.startsWith('//')) return 'https:' + value
			if (value.startsWith('http://') || value.startsWith('https://') || value.startsWith('file://') || value.startsWith('data:') || value.startsWith('about:')) return value
			if (value.startsWith('localhost') || value.startsWith('127.') || value.startsWith('192.168.') || value.startsWith('10.') || value.startsWith('172.')) return 'http://' + value
			if (value.indexOf('.') > 0) return 'https://' + value
			return value
		},
		setEmbeddedWebUrl(url: string) {
			const nextUrl = this.normalizeWebUrl(url)
			this.embeddedWebUrl = nextUrl
			this.webViewKey = nextUrl + '#' + Date.now().toString()
			this.checkExternalUrl(nextUrl)
			this.webNavCanGoBack = false
			this.webNavCanGoForward = false
			if (nextUrl.length > 0) setDevUrl(nextUrl)
			console.log('[vibego-webview]', 'load-url', nextUrl.length > 0 ? nextUrl : '<empty>')
		},
		openUrl(url: string) {
			if (url.length == 0) return
			uni.showActionSheet({
				itemList: ['跳转阅注页面', '在系统浏览器打开'],
				success: (res) => {
					if (res.tapIndex == 0) {
						this.openUrlInAnnotator(url)
						return
					}
					this.openUrlInSystemBrowser(url)
				},
			})
		},
		openUrlInAnnotator(url: string) {
			if (url.length == 0) return
			this.bindAnnotationSourceFromCurrentThread(url)
			this.setEmbeddedWebUrl(url)
			this.goWeb()
		},
		annotationSourceFallbackTitle(threadId: string, fallbackTitle: string, isAssistant: boolean): string {
			const thread = this.findThreadById(threadId)
			if (thread != null) return this.displayThreadTitle(thread)
			if (fallbackTitle.length > 0) return fallbackTitle
			if (isAssistant) return this.assistantThreadTitle()
			return this.mainTitle.length > 0 ? this.mainTitle : '当前会话'
		},
		currentAnnotationSourceContext(): AnnotationSourceContext {
			return {
				projectId: this.annotationSourceProjectId,
				threadId: this.annotationSourceThreadId,
				title: this.annotationSourceTitle,
				isAssistant: this.annotationSourceIsAssistant,
				boundAt: this.annotationSourceBoundAt,
				sourceUrl: this.annotationSourceUrl,
			}
		},
		applyAnnotationSourceContext(context: AnnotationSourceContext, persist: boolean = false) {
			if (context.threadId.length == 0) return
			const sourceUrl = context.sourceUrl.length > 0 ? this.normalizeWebUrl(context.sourceUrl) : ''
			const nextContext: AnnotationSourceContext = {
				projectId: context.isAssistant ? '' : context.projectId,
				threadId: context.threadId,
				title: this.annotationSourceFallbackTitle(context.threadId, context.title, context.isAssistant),
				isAssistant: context.isAssistant,
				boundAt: context.boundAt.length > 0 ? context.boundAt : new Date().toISOString(),
				sourceUrl,
			}
			this.annotationSourceProjectId = nextContext.projectId
			this.annotationSourceThreadId = nextContext.threadId
			this.annotationSourceTitle = nextContext.title
			this.annotationSourceIsAssistant = nextContext.isAssistant
			this.annotationSourceBoundAt = nextContext.boundAt
			this.annotationSourceUrl = nextContext.sourceUrl
			const current = getAnnotationSourceContext()
			if (persist || current.threadId != nextContext.threadId || current.projectId != nextContext.projectId || current.title != nextContext.title || current.isAssistant != nextContext.isAssistant || current.sourceUrl != nextContext.sourceUrl || current.boundAt != nextContext.boundAt) {
				setAnnotationSourceContext(nextContext)
			}
		},
		hydrateAnnotationSourceContext() {
			const stored = getAnnotationSourceContext()
			if (stored.threadId.length == 0) return
			this.applyAnnotationSourceContext(stored, false)
		},
		resolveCurrentThreadAnnotationSourceContext(sourceUrl: string = ''): AnnotationSourceContext | null {
			let threadId = this.activeThreadId
			let projectId = ''
			let isAssistant = false
			let fallbackTitle = ''
			if (threadId.length == 0 && this.activeRailMode == 'assistant' && this.hasAssistantBinding()) {
				threadId = this.assistantThreadId
				projectId = ''
				isAssistant = true
				fallbackTitle = this.assistantThreadTitle()
			} else if (threadId.length > 0) {
				isAssistant = this.isAssistantThread(threadId)
				projectId = isAssistant ? '' : (this.selectedProjectId().length > 0 ? this.selectedProjectId() : this.activeProjectId)
				fallbackTitle = isAssistant ? this.assistantThreadTitle() : this.mainTitle
			}
			if (threadId.length == 0) return null
			return {
				projectId,
				threadId,
				title: this.annotationSourceFallbackTitle(threadId, fallbackTitle, isAssistant),
				isAssistant,
				boundAt: new Date().toISOString(),
				sourceUrl: sourceUrl.length > 0 ? sourceUrl : this.embeddedWebUrl,
			}
		},
		bindAnnotationSourceFromCurrentThread(sourceUrl: string = ''): boolean {
			const context = this.resolveCurrentThreadAnnotationSourceContext(sourceUrl)
			if (context == null) {
				if (this.annotationSourceThreadId.length > 0) {
					console.log('[vibego-annotation]', 'keep-existing-source', this.annotationSourceThreadId)
					return true
				}
				return false
			}
			this.applyAnnotationSourceContext(context, true)
			return true
		},
		resolveAnnotationSourceFallback(): boolean {
			const current = this.currentAnnotationSourceContext()
			if (current.threadId.length > 0) {
				this.applyAnnotationSourceContext(current, false)
				return true
			}
			const stored = getAnnotationSourceContext()
			if (stored.threadId.length > 0) {
				this.applyAnnotationSourceContext(stored, false)
				return true
			}
			const live = this.resolveCurrentThreadAnnotationSourceContext(this.embeddedWebUrl)
			if (live == null) {
				const empty = emptyAnnotationSourceContext()
				this.annotationSourceProjectId = empty.projectId
				this.annotationSourceThreadId = empty.threadId
				this.annotationSourceTitle = empty.title
				this.annotationSourceIsAssistant = empty.isAssistant
				this.annotationSourceBoundAt = empty.boundAt
				this.annotationSourceUrl = empty.sourceUrl
				return false
			}
			this.applyAnnotationSourceContext(live, true)
			return true
		},
		rememberAnnotationSourceContext() {
			this.bindAnnotationSourceFromCurrentThread(this.embeddedWebUrl)
		},
		openUrlInSystemBrowser(url: string) {
			const normalized = this.normalizeWebUrl(url)
			if (normalized.length == 0) return
			if (!openExternalUri(normalized)) {
				uni.showToast({ title: '打开系统浏览器失败', icon: 'none' })
			}
		},
		cleanImageReference(value: string): string {
			let text = value.trim()
			while (text.endsWith('。') || text.endsWith('，') || text.endsWith('、') || text.endsWith('；') || text.endsWith('：') || text.endsWith(',') || text.endsWith(';')) {
				text = text.substring(0, text.length - 1).trim()
			}
			return text
		},
		isImageReference(value: string): boolean {
			let text = this.cleanImageReference(value)
			if (text.startsWith('file://')) text = text.substring(7)
			const hash = text.indexOf('#')
			if (hash >= 0) text = text.substring(0, hash)
			const query = text.indexOf('?')
			if (query >= 0) text = text.substring(0, query)
			const lower = text.toLowerCase()
			return lower.endsWith('.png') || lower.endsWith('.jpg') || lower.endsWith('.jpeg') || lower.endsWith('.gif') || lower.endsWith('.webp')
		},
		serverBaseUrl(): string {
			let value = this.normalizeWebUrl(this.serverUrl).trim()
			while (value.endsWith('/')) value = value.substring(0, value.length - 1)
			return value
		},
		encodeUrlPath(pathname: string): string {
			const parts = pathname.split('/')
			let result = ''
			for (let index: Int = 0; index < parts.length; index++) {
				const part = parts[index]
				if (index == 0 && part.length == 0) {
					result = '/'
					continue
				}
				if (index > 0 && !result.endsWith('/')) result = result + '/'
				result = result + encodeURIComponent(part)
			}
			return result
		},
		isLocalImagePath(value: string): boolean {
			const text = value.trim()
			return text.startsWith('/') || text.startsWith('~/')
		},
		resolveMessageImageSrc(value: string): string {
			let source = this.cleanImageReference(value)
			if (source.startsWith('file://')) {
				source = decodeURIComponent(source.substring(7)) ?? source.substring(7)
			}
			if (source.startsWith('http://') || source.startsWith('https://') || source.startsWith('data:image/')) return source
			const base = this.serverBaseUrl()
			if (base.length == 0) return source
			if (source.startsWith('/uploads/')) return base + this.encodeUrlPath(source)
			const uploadsIndex = source.indexOf('/uploads/')
			const serverUploadsIndex = source.indexOf('/server/uploads/')
			if (uploadsIndex >= 0 && serverUploadsIndex >= 0) return base + this.encodeUrlPath(source.substring(uploadsIndex))
			if (this.isLocalImagePath(source)) return base + '/api/local-image?path=' + encodeURIComponent(source)
			return source
		},
		messageImageAltFromPath(value: string): string {
			let text = this.cleanImageReference(value)
			if (text.startsWith('file://')) text = text.substring(7)
			const slash = text.lastIndexOf('/')
			if (slash >= 0 && slash + 1 < text.length) return text.substring(slash + 1)
			return '图片'
		},
		markdownImageParts(line: string): Array<string> {
			const value = line.trim()
			const result = new Array<string>()
			if (!value.startsWith('![')) return result
			const open = value.indexOf('](')
			const end = value.lastIndexOf(')')
			if (open < 2 || end <= open + 2) return result
			if (value.substring(end + 1).trim().length > 0) return result
			const alt = value.substring(2, open).trim()
			const source = value.substring(open + 2, end).trim()
			if (!this.isImageReference(source)) return result
			result.push(alt.length > 0 ? alt : this.messageImageAltFromPath(source))
			result.push(this.resolveMessageImageSrc(source))
			return result
		},
		renderMessageBlocks(text: string): Array<ChatTextBlock> {
			const blocks = new Array<ChatTextBlock>()
			const lines = text.split('\n')
			let paragraph = ''
			let code = ''
			let inCode = false
				for (let index: Int = 0; index < lines.length; index++) {
					const rawLine = lines[index]
					const line = rawLine.trim()
					if (line.startsWith('```')) {
						if (inCode) {
							if (code.trim().length > 0) blocks.push({ kind: 'code', text: this.wrapDisplayText(code, 42), rawText: code, segments: this.textSegments(code, false) })
							code = ''
							inCode = false
						} else {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							if (plainParagraph.length > 0) blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
							paragraph = ''
							inCode = true
						}
						continue
					}
				if (inCode) {
					code = code.length == 0 ? rawLine : code + '\n' + rawLine
					continue
					}
					if (line.length == 0) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						continue
					}
					const imageParts = this.markdownImageParts(line)
					if (imageParts.length >= 2 || this.isImageReference(line)) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						if (imageParts.length >= 2) {
							blocks.push({ kind: 'image', text: imageParts[0], rawText: imageParts[1], segments: this.textSegments('', false) })
						} else {
							blocks.push({ kind: 'image', text: this.messageImageAltFromPath(line), rawText: this.resolveMessageImageSrc(line), segments: this.textSegments('', false) })
						}
						continue
					}
					if (this.isTableStart(lines, index)) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						let tableRaw = ''
						let rowIndex: Int = index
						while (rowIndex < lines.length && this.isTableLine(lines[rowIndex])) {
							tableRaw = tableRaw.length == 0 ? lines[rowIndex] : tableRaw + '\n' + lines[rowIndex]
							rowIndex = rowIndex + 1
						}
						blocks.push({ kind: 'table', text: '', rawText: tableRaw, segments: this.textSegments('', false) })
						index = (rowIndex - 1).toInt()
						continue
					}
					if (this.headingLevel(line) > 0) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						const level = this.headingLevel(line)
						const rawHeading = line.substring(level).trim()
						const plainHeading = this.plainMarkdownText(rawHeading)
						blocks.push({ kind: 'heading', text: plainHeading, rawText: line, segments: this.textSegments(rawHeading, true) })
						continue
					}
					if (this.isMarkdownHr(line)) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						blocks.push({ kind: 'hr', text: '', rawText: line, segments: this.textSegments('', false) })
						continue
					}
					if (line.startsWith('>')) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						const rawQuote = line.substring(1).trim()
						const plainQuote = this.plainMarkdownText(rawQuote)
						blocks.push({ kind: 'quote', text: this.wrapDisplayText(plainQuote, 28), rawText: line, segments: this.textSegments(rawQuote, true) })
						continue
					}
					if (this.isListLine(line)) {
						if (paragraph.trim().length > 0) {
							const plainParagraph = this.plainMarkdownText(paragraph.trim())
							blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainParagraph, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
						}
						paragraph = ''
						const rawList = this.cleanListLine(line)
						const plainList = this.plainMarkdownText(rawList)
						blocks.push({ kind: 'list', text: this.wrapDisplayText(plainList, 28), rawText: line, segments: this.textSegments(rawList, true) })
						continue
					}
					paragraph = paragraph.length == 0 ? rawLine : paragraph + '\n' + rawLine
				}
				if (inCode && code.trim().length > 0) blocks.push({ kind: 'code', text: this.wrapDisplayText(code, 42), rawText: code, segments: this.textSegments(code, false) })
				if (paragraph.trim().length > 0) {
					const plainRest = this.plainMarkdownText(paragraph.trim())
					blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainRest, 28), rawText: paragraph.trim(), segments: this.textSegments(paragraph.trim(), true) })
				}
				if (blocks.length == 0 && text.length > 0) {
					const plainAll = this.plainMarkdownText(text)
					blocks.push({ kind: 'paragraph', text: this.wrapDisplayText(plainAll, 28), rawText: text, segments: this.textSegments(text, true) })
				}
				return blocks
			},
		isListLine(line: string): boolean {
			if (line.startsWith('- ') || line.startsWith('• ')) return true
			const dot = line.indexOf('. ')
			if (dot <= 0 || dot > 3) return false
			const prefix = line.substring(0, dot)
			return this.isDigits(prefix)
		},
		isDigits(value: string): boolean {
			if (value.length == 0) return false
			for (let index: Int = 0; index < value.length; index++) {
				const ch = value.substring(index, index + 1)
				if ('0123456789'.indexOf(ch) < 0) return false
			}
			return true
		},
		cleanListLine(line: string): string {
			if (line.startsWith('- ') || line.startsWith('• ')) return line.substring(2)
			const dot = line.indexOf('. ')
			if (dot > 0 && dot <= 3 && this.isDigits(line.substring(0, dot))) return line.substring(dot + 2)
			return line
		},
		filesLayoutStyle(): string {
			return 'height:' + this.surfaceHeight().toString() + 'px;padding-top:' + this.titleBarOffset().toString() + 'px;padding-bottom:' + this.composerBottomGap().toString() + 'px;'
		},
		clampWidth(value: number): number {
			if (value < this.minSidebarWidth) return this.minSidebarWidth
			if (value > this.maxSidebarWidth) return this.maxSidebarWidth
			return value
		},
		touchX(event: UniTouchEvent): number {
			const touch: UniTouch = event.touches[0]
			return touch.clientX
		},
		startResize(event: UniTouchEvent) {
			if (this.isCompactChat || this.railCompact() || !this.showThreadListPane()) return
			this.resizing = true
			this.resizeStartX = this.touchX(event)
			this.resizeStartWidth = this.sidebarWidth
		},
		moveResize(event: UniTouchEvent) {
			if (!this.resizing || this.isCompactChat || this.railCompact() || !this.showThreadListPane()) return
			const delta = this.touchX(event) - this.resizeStartX
			const nextWidth = this.clampWidth(this.resizeStartWidth + delta)
			this.sidebarWidth = nextWidth
			this.expandedSidebarWidth = nextWidth
		},
		endResize(_: UniTouchEvent) {
			this.resizing = false
		},
		openCompactDrawer() {
			if (!this.isCompactChat) return
			this.compactDrawerOpen = true
			this.triggerCompactDrawerMotion()
		},
		closeCompactDrawer() {
			this.compactDrawerOpen = false
		},
		toggleSidebar() {
			if (this.isCompactChat || this.isIconSidebar) return
			if (this.userSidebarCollapsed) {
				this.userSidebarCollapsed = false
				this.sidebarCollapsed = false
			} else {
				this.userSidebarCollapsed = true
				this.sidebarCollapsed = true
			}
			setThreadListCollapsed(this.userSidebarCollapsed)
			},
		toggleSettings() {
			if (this.settingsOpen) {
				this.closeSettings()
				return
			}
			this.syncServerFieldsFromUrl()
			this.settingsError = ''
			this.settingsOpen = true
			this.triggerSettingsMotion()
		},
		closeSettings() {
			this.settingsOpen = false
			this.settingsError = ''
		},
		syncServerFieldsFromUrl() {
			let value = this.serverUrl.length > 0 ? this.serverUrl : getServerUrl()
			value = value.trim()
			if (value.startsWith('http://')) value = value.substring(7)
			if (value.startsWith('https://')) value = value.substring(8)
			const slash = value.indexOf('/')
			if (slash >= 0) value = value.substring(0, slash)
			const colon = value.lastIndexOf(':')
			if (colon > 0) {
				this.serverHost = value.substring(0, colon)
				this.serverPort = value.substring(colon + 1)
			} else {
				this.serverHost = value
				this.serverPort = '8790'
			}
		},
		serverUrlFromFields(): string {
			let host = this.serverHost.trim()
			if (host.startsWith('http://')) host = host.substring(7)
			if (host.startsWith('https://')) host = host.substring(8)
			const slash = host.indexOf('/')
			if (slash >= 0) host = host.substring(0, slash)
			const port = this.serverPort.trim()
			if (host.length == 0 || port.length == 0) return ''
			return 'http://' + host + ':' + port
		},
		saveServerFields() {
			const nextUrl = this.serverUrlFromFields()
			if (nextUrl.length == 0) {
				this.settingsError = '请填写服务器 IP 和端口'
				return
			}
			const previousUrl = getServerUrl()
			const serverChanged = previousUrl != nextUrl
			this.serverUrl = nextUrl
			setServerUrl(this.serverUrl)
			this.settingsError = '正在连接服务器...'
			checkServerHealth((result) => {
				if (result.ok) {
					if (serverChanged) this.clearCodexDataForServerSwitch()
					this.settingsError = ''
					uni.showToast({ title: '服务器已保存', icon: 'success' })
					this.refreshProjectAndThreadLists(true)
				} else {
					setServerUrl(previousUrl)
					this.settingsError = result.error
				}
			})
		},
		clearCodexDataForServerSwitch() {
			this.stopPolling()
			this.clearWatch()
			this.clearCursor()
			this.projects = new Array<ProjectInfo>()
			this.threads = new Array<CodexThread>()
			this.projectGroups = new Array<ProjectThreadGroup>()
			this.activeProjectId = ''
			this.activeProjectPath = ''
			this.activeThreadId = ''
			this.mainTitle = ''
			this.messages = new Array<ChatMessage>()
			this.resetMessageViews()
			this.processEvents = new Array<CodexProcessEvent>()
			this.codexRunning = false
			this.threadLoading = false
			this.snapshotLoadingThreadId = ''
			this.snapshotLoadingStartedAt = 0
			this.activeThreadSnapshotStale = false
			this.activeThreadSnapshotCachedAt = 0
			setActiveProjectId('')
			setActiveThreadId('')
			uni.removeStorageSync(CODEX_PROJECTS_CACHE_KEY)
			uni.removeStorageSync(CODEX_THREADS_CACHE_KEY)
			uni.removeStorageSync(CODEX_THREAD_SNAPSHOT_CACHE_KEY)
			uni.removeStorageSync(RECENT_NORMAL_THREAD_KEY)
			this.logStartupPerf('serverSwitch:cache-cleared', 'url=' + this.serverUrl)
		},
		handleSettingsOverlayPoint(source: string, x: number, y: number) {
			const now = Date.now()
			if (now - this.settingsLastHandledAt < 80) return
			this.settingsLastHandledAt = now
			if (this.isInsideSettingsDialog(x, y)) {
				this.noopClick()
			} else {
				this.closeSettings()
			}
		},
		onSettingsOverlayTouchStart(event: UniTouchEvent) {
			if (event.touches.length <= 0) return
			const touch: UniTouch = event.touches[0]
			this.settingsLastTouchX = touch.clientX
			this.settingsLastTouchY = touch.clientY
			this.settingsLastTouchAt = Date.now()
		},
		onSettingsOverlayTouchEnd(_: UniTouchEvent) {
			if (this.settingsLastTouchX < 0 || this.settingsLastTouchY < 0) return
			this.handleSettingsOverlayPoint('touchend', this.settingsLastTouchX, this.settingsLastTouchY)
		},
		onSettingsOverlayClick(_: any) {
			if (this.settingsLastTouchX < 0 || this.settingsLastTouchY < 0) return
			if (Date.now() - this.settingsLastTouchAt > 1200) return
			this.handleSettingsOverlayPoint('click', this.settingsLastTouchX, this.settingsLastTouchY)
		},
		openAbilityCenterFromSettings() {
			this.closeSettings()
			this.goBackgroundTest()
		},
		openKeyboardSettingsFromSettings() {
			this.closeSettings()
			uni.navigateTo({ url: '/pages/keyboard/index' })
		},
		onKeyboardAction(event: UTSJSONObject | null) {
			if (event == null) return
			const action = event.getString('action') ?? ''
			const phase = event.getString('phase') ?? ''
			console.log('[vibego-keyboard]', 'page-action', 'action=' + action + ' phase=' + phase)
			if (action == 'send') {
				this.triggerPrimarySend()
				return
			}
			if (action == 'delete') {
				this.triggerPrimaryDelete()
				return
			}
			if (action == 'noop') {
				this.triggerPrimaryClear()
				return
			}
			if (action == 'cancel') {
				if (this.settingsOpen) {
					this.closeSettings()
					return
				}
				if (this.dropDialogOpen) {
					this.cancelDropFile()
					return
				}
				if (this.compactDrawerOpen) {
					this.closeCompactDrawer()
					return
				}
				uni.navigateBack()
			}
		},
		applyScreenCapability(result: ScreenCapability) {
			this.screenOverlayGranted = result.overlayGranted
			this.screenProjectionAuthorized = result.projectionAuthorized
			this.screenProjectionActive = result.projectionActive
			let status = result.message
			if (this.screenOverlayGranted) {
				status = status + ' · overlay=granted'
			} else {
				status = status + ' · overlay=missing'
			}
			this.screenCapabilityText = status
			if (result.lastError.length > 0) {
				this.screenCaptureUploadText = result.lastError
			}
		},
		refreshScreenCaptureStatus() {
			getScreenCapability((result) => {
				this.applyScreenCapability(result)
			})
		},
		requestScreenCaptureFromMain() {
			requestCapturePermission((result) => {
				this.applyScreenCapability(result)
				if (result.projectionAuthorized) {
					uni.showToast({ title: '识屏授权成功', icon: 'success' })
				} else if (result.lastError.length > 0) {
					uni.showToast({ title: result.lastError, icon: 'none' })
				}
			})
		},
		isAssistantPerceptionContext(): boolean {
			return this.rightMode == 'chat' && this.activeRailMode == 'assistant'
		},
		logAssistantPerception(stage: string, message: string) {
			console.log('[vibego-assistant-perception]', stage, message)
		},
		isScreenCapturePermissionError(message: string): boolean {
			if (message.length == 0) return false
			if (message.indexOf('请先完成屏幕采集') >= 0) return true
			if (message.indexOf('屏幕采集权限') >= 0) return true
			if (message.indexOf('屏幕采集授权') >= 0) return true
			return false
		},
		requestScreenCapturePermissionAfterError(message: string, source: string) {
			this.logAssistantPerception('auto-permission-request', 'source=' + source + ' error=' + message)
			this.screenCaptureUploadText = '需要重新授权识屏…'
			requestCapturePermission((result) => {
				this.applyScreenCapability(result)
				this.logAssistantPerception('auto-permission-result', 'source=' + source + ' authorized=' + result.projectionAuthorized.toString() + ' active=' + result.projectionActive.toString() + ' error=' + result.lastError)
				if (result.projectionAuthorized) {
					this.screenCaptureUploadText = '识屏授权已恢复'
					uni.showToast({ title: '识屏授权已恢复', icon: 'success' })
					return
				}
				const error = result.lastError.length > 0 ? result.lastError : '需要授权后才能识屏'
				this.screenCaptureUploadText = error
				uni.showToast({ title: error, icon: 'none' })
			})
		},
		resetAssistantPerceptionPending() {
			this.logAssistantPerception('reset-pending', 'session=' + this.assistantPerceptionSessionId.toString())
			this.assistantPerceptionBusy = false
			this.assistantPerceptionSessionId = 0
			this.assistantPerceptionText = ''
			this.assistantPerceptionUploadPath = ''
			this.assistantPerceptionCaptureDone = false
			this.assistantPerceptionCaptureError = ''
		},
		toggleAssistantPerception() {
			this.logAssistantPerception('toggle', 'enabled=' + this.assistantPerceptionEnabled.toString() + ' busy=' + this.assistantPerceptionBusy.toString())
			if (this.assistantPerceptionBusy) {
				uni.showToast({ title: '感知处理中', icon: 'none' })
				return
			}
			if (this.assistantPerceptionEnabled) {
				this.assistantPerceptionEnabled = false
				this.resetAssistantPerceptionPending()
				uni.showToast({ title: '感知已关闭', icon: 'none' })
				return
			}
			this.assistantPerceptionBusy = true
			this.logAssistantPerception('permission-request', 'start')
			requestCapturePermission((result) => {
				this.applyScreenCapability(result)
				this.assistantPerceptionBusy = false
				this.logAssistantPerception('permission-result', 'authorized=' + result.projectionAuthorized.toString() + ' active=' + result.projectionActive.toString() + ' error=' + result.lastError)
				if (result.projectionAuthorized) {
					this.assistantPerceptionEnabled = true
					uni.showToast({ title: '感知已开启', icon: 'success' })
					return
				}
				this.assistantPerceptionEnabled = false
				const message = result.lastError.length > 0 ? result.lastError : '需要授权后才能开启感知'
				uni.showToast({ title: message, icon: 'none' })
			})
		},
		failAssistantPerceptionCapture(sessionId: number, error: string) {
			this.logAssistantPerception('capture-fail', 'session=' + sessionId.toString() + ' current=' + this.assistantPerceptionSessionId.toString() + ' error=' + error)
			if (this.assistantPerceptionSessionId != sessionId) return
			const message = error.length > 0 ? error : '感知识屏失败'
			this.assistantPerceptionCaptureDone = true
			this.assistantPerceptionCaptureError = message
			this.assistantPerceptionBusy = false
			this.screenCaptureBusy = false
			this.screenCaptureUploadText = message
			uni.showToast({ title: message, icon: 'none' })
			this.trySendAssistantPerceptionVoice()
		},
		startAssistantPerceptionCapture(sessionId: number) {
			this.logAssistantPerception('capture-start-request', 'session=' + sessionId.toString() + ' enabled=' + this.assistantPerceptionEnabled.toString() + ' context=' + this.isAssistantPerceptionContext().toString() + ' screenBusy=' + this.screenCaptureBusy.toString())
			if (!this.assistantPerceptionEnabled || !this.isAssistantPerceptionContext()) {
				this.logAssistantPerception('capture-start-skip', 'disabled-or-wrong-context')
				return
			}
			if (sessionId <= 0) {
				this.logAssistantPerception('capture-start-skip', 'invalid-session')
				return
			}
			this.resetAssistantPerceptionPending()
			this.assistantPerceptionBusy = true
			this.assistantPerceptionSessionId = sessionId
			if (this.screenCaptureBusy) {
				this.failAssistantPerceptionCapture(sessionId, '正在识屏，请稍后再试')
				return
			}
			this.screenCaptureBusy = true
			this.screenCaptureUploadText = '正在感知识屏…'
			this.logAssistantPerception('capture-once-call', 'session=' + sessionId.toString())
			captureOnce((result: ScreenCaptureFrameResult) => {
				this.applyScreenCapability(result.capability)
				this.logAssistantPerception('capture-once-result', 'session=' + sessionId.toString() + ' ok=' + result.ok.toString() + ' path=' + result.path + ' error=' + result.error)
				if (this.assistantPerceptionSessionId != sessionId) {
					this.logAssistantPerception('capture-result-stale', 'session=' + sessionId.toString() + ' current=' + this.assistantPerceptionSessionId.toString())
					this.screenCaptureBusy = false
					return
				}
				if (!result.ok) {
					const error = result.error.length > 0 ? result.error : result.capability.lastError
					if (this.isScreenCapturePermissionError(error)) {
						this.requestScreenCapturePermissionAfterError(error, 'assistant-perception')
					}
					this.failAssistantPerceptionCapture(sessionId, result.error)
					return
				}
				this.screenCapturePath = result.path
				this.screenCaptureMetaText = result.path + ' · ' + result.width.toString() + ' x ' + result.height.toString() + ' · ' + result.timestamp
				this.screenCaptureUploadText = '正在登记感知截图…'
				this.logAssistantPerception('upload-call', 'session=' + sessionId.toString() + ' path=' + result.path)
				uploadMobileFile(result.path, result.path, 'image/png', (ok, record, error) => {
					this.logAssistantPerception('upload-result', 'session=' + sessionId.toString() + ' ok=' + ok.toString() + ' error=' + error)
					if (this.assistantPerceptionSessionId != sessionId) {
						this.logAssistantPerception('upload-result-stale', 'session=' + sessionId.toString() + ' current=' + this.assistantPerceptionSessionId.toString())
						this.screenCaptureBusy = false
						return
					}
					this.screenCaptureBusy = false
					if (ok && record != null) {
						this.assistantPerceptionUploadPath = record.path.length > 0 ? record.path : record.url
						this.logAssistantPerception('upload-path', this.assistantPerceptionUploadPath)
						this.assistantPerceptionCaptureDone = true
						this.assistantPerceptionCaptureError = ''
						this.assistantPerceptionBusy = false
						this.screenCaptureUploadText = '感知截图已登记：' + this.assistantPerceptionUploadPath
						this.trySendAssistantPerceptionVoice()
						return
					}
					this.failAssistantPerceptionCapture(sessionId, error)
				})
			})
		},
		trySendAssistantPerceptionVoice() {
			this.logAssistantPerception('try-send', 'session=' + this.assistantPerceptionSessionId.toString() + ' textLength=' + this.assistantPerceptionText.length.toString() + ' captureDone=' + this.assistantPerceptionCaptureDone.toString() + ' uploadPath=' + this.assistantPerceptionUploadPath + ' error=' + this.assistantPerceptionCaptureError)
			if (this.assistantPerceptionSessionId <= 0) return
			if (this.assistantPerceptionText.length == 0) return
			if (!this.assistantPerceptionCaptureDone) return
			const text = this.assistantPerceptionText
			const uploadPath = this.assistantPerceptionUploadPath
			const error = this.assistantPerceptionCaptureError
			this.resetAssistantPerceptionPending()
			if (error.length > 0 || uploadPath.length == 0) {
				this.logAssistantPerception('send-cancel', 'error=' + error + ' uploadPath=' + uploadPath)
				return
			}
			const sendText = text + '\n\n' + this.attachmentPathInstruction(uploadPath)
			if (this.shouldQueueAssistantPrompt()) {
				this.logAssistantPerception('send-queue', 'length=' + sendText.length.toString())
				this.queueAssistantPrompt(sendText)
				return
			}
			this.logAssistantPerception('send-now', 'length=' + sendText.length.toString())
			this.sendPromptText(sendText)
		},
		handleAssistantPerceptionVoiceText(text: string, sessionId: number): boolean {
			this.logAssistantPerception('handle-voice-text', 'incomingSession=' + sessionId.toString() + ' current=' + this.assistantPerceptionSessionId.toString() + ' enabled=' + this.assistantPerceptionEnabled.toString() + ' context=' + this.isAssistantPerceptionContext().toString() + ' length=' + text.length.toString())
			if (!this.assistantPerceptionEnabled || !this.isAssistantPerceptionContext()) return false
			const voiceSessionId = sessionId > 0 ? sessionId : Date.now()
			if (this.assistantPerceptionSessionId <= 0 || voiceSessionId != this.assistantPerceptionSessionId) {
				this.startAssistantPerceptionCapture(voiceSessionId)
			}
			if (voiceSessionId != this.assistantPerceptionSessionId) {
				this.logAssistantPerception('handle-voice-cancel', 'capture-not-started session=' + voiceSessionId.toString() + ' current=' + this.assistantPerceptionSessionId.toString())
				uni.showToast({ title: '感知识屏未启动，本次语音已取消', icon: 'none' })
				return true
			}
			const clean = text.trim()
			if (clean.length == 0) return true
			this.assistantPerceptionText = clean
			this.trySendAssistantPerceptionVoice()
			return true
		},
		captureScreenFromMain() {
			if (this.screenCaptureBusy) {
				uni.showToast({ title: '正在识屏…', icon: 'none' })
				return
			}
			this.runScreenCaptureOnce()
		},
		runScreenCaptureOnce() {
			this.screenCaptureBusy = true
			captureOnce((result: ScreenCaptureFrameResult) => {
				this.applyScreenCapability(result.capability)
				if (!result.ok) {
					this.screenCaptureBusy = false
					const error = result.error.length > 0 ? result.error : result.capability.lastError
					this.screenCaptureUploadText = error
					if (this.isScreenCapturePermissionError(error)) {
						this.requestScreenCapturePermissionAfterError(error, 'manual-capture')
						return
					}
					uni.showToast({ title: error, icon: 'none' })
					return
				}
				this.screenCapturePath = result.path
				this.screenCaptureMetaText = result.path + ' · ' + result.width.toString() + ' x ' + result.height.toString() + ' · ' + result.timestamp
				this.screenCaptureUploadText = '正在登记到文件链路…'
				uploadMobileFile(result.path, result.path, 'image/png', (ok, record, error) => {
					if (ok && record != null) {
						this.screenCaptureUploadText = '识屏图片已登记：' + record.path
						uni.showToast({ title: '识屏图片已保存', icon: 'success' })
					} else {
						this.screenCaptureUploadText = error
						uni.showToast({ title: error, icon: 'none' })
					}
					this.screenCaptureBusy = false
				})
			})
		},
		triggerScreenCaptureFromMenu() {
			if (this.screenCaptureBusy) {
				uni.showToast({ title: '正在识屏…', icon: 'none' })
				return
			}
			this.screenCaptureBusy = true
			this.screenCaptureUploadText = '正在准备识屏…'
			getScreenCapability((capability) => {
				this.applyScreenCapability(capability)
				if (!capability.captureSupported) {
					this.screenCaptureBusy = false
					const message = capability.lastError.length > 0 ? capability.lastError : '当前基座不支持识屏'
					this.screenCaptureUploadText = message
					uni.showToast({ title: message, icon: 'none' })
					return
				}
				if (capability.projectionAuthorized) {
					this.runScreenCaptureOnce()
					return
				}
				requestCapturePermission((result) => {
					this.applyScreenCapability(result)
					if (result.projectionAuthorized) {
						this.runScreenCaptureOnce()
						return
					}
					this.screenCaptureBusy = false
					const message = result.lastError.length > 0 ? result.lastError : '需要授权后才能识屏'
					this.screenCaptureUploadText = message
					uni.showToast({ title: message, icon: 'none' })
				})
			})
		},
		stopScreenCaptureFromMain() {
			stopCaptureSession((result) => {
				this.applyScreenCapability(result)
				uni.showToast({ title: result.message, icon: 'success' })
			})
		},
		fillLocal() {
			this.serverUrl = DEFAULT_SERVER_URL
			this.saveAndCheck()
		},
			saveAndCheck() {
				setServerUrl(this.serverUrl)
				const healthStart = Date.now()
				this.logStartupPerf('serverHealth:start', 'url=' + this.serverUrl)
				checkServerHealth((result) => {
					this.logStartupPerfEnd('serverHealth:end', healthStart, 'ok=' + (result.ok ? '1' : '0') + ' error=' + result.error)
					if (result.ok) this.statusText = '服务可用'
					else this.statusText = result.error
				})
			},
			ensureStartupCacheLoaded() {
				if (this.projects.length > 0 || this.threads.length > 0) {
					this.logStartupPerf('startupCache:lists-hit', 'projects=' + this.projects.length.toString() + ' threads=' + this.threads.length.toString())
				} else {
					this.logStartupPerf('startupCache:missing-lists', 'projects=' + this.projects.length.toString() + ' threads=' + this.threads.length.toString() + ' request=1')
					this.refreshProjectAndThreadLists(true)
				}
				if (this.activeThreadId.length == 0) {
					this.logStartupPerf('startupCache:snapshot-skip-empty')
					return
				}
				if (this.messages.length > 0 || this.processEvents.length > 0) {
					this.logStartupPerf('startupCache:snapshot-visible', 'thread=' + this.activeThreadId + ' messages=' + this.messages.length.toString() + ' processes=' + this.processEvents.length.toString())
					return
				}
				this.logStartupPerf('startupCache:missing-snapshot', 'thread=' + this.activeThreadId + ' request=1')
				this.loadThreadSnapshot(this.activeThreadId, this.codexRunning)
			},
		refreshCodexListsFromMenu() {
			const refreshStart = Date.now()
			this.logStartupPerf('manualRefresh:start')
			uni.showToast({ title: '正在刷新 Codex 列表', icon: 'none' })
			const healthStart = Date.now()
			this.logStartupPerf('manualRefresh:serverHealth:start', 'url=' + this.serverUrl)
			checkServerHealth((result) => {
				this.logStartupPerfEnd('manualRefresh:serverHealth:end', healthStart, 'ok=' + (result.ok ? '1' : '0') + ' error=' + result.error)
				if (!result.ok) {
					this.statusText = result.error
					uni.showToast({ title: result.error, icon: 'none' })
					this.logStartupPerfEnd('manualRefresh:end', refreshStart, 'ok=0')
					return
				}
				this.refreshScreenCaptureStatus()
				this.refreshProjectAndThreadLists(true)
				if (this.activeThreadId.length > 0) this.loadThreadSnapshot(this.activeThreadId, this.codexRunning)
				this.ensureAssistantReady()
				this.logStartupPerfEnd('manualRefresh:scheduled', refreshStart, 'activeThread=' + this.activeThreadId)
			})
		},
		applyAssistantRecord(record: AssistantRecord) {
			this.assistantThreadId = record.threadId ?? ''
			this.assistantProjectId = ''
			this.assistantTitle = record.title ?? ''
			this.assistantInitializedAt = record.initializedAt ?? ''
			if ((record.projectId ?? '').length > 0 && this.assistantThreadId.length > 0) {
				this.persistAssistantRecord()
			}
		},
		persistAssistantRecord() {
			setAssistantRecord({
				threadId: this.assistantThreadId,
				projectId: this.assistantProjectId,
				title: this.assistantTitle,
				initializedAt: this.assistantInitializedAt,
			})
		},
		clearAssistantBinding() {
			this.assistantThreadId = ''
			this.assistantProjectId = ''
			this.assistantTitle = ''
			this.assistantInitializedAt = ''
			this.assistantPendingProjectId = ''
			this.assistantInitializing = false
			setAssistantRecord(emptyAssistantRecord())
		},
		hasAssistantBinding(): boolean {
			return this.assistantThreadId.length > 0
		},
		assistantNavText(): string {
			return this.assistantInitializing && !this.hasAssistantBinding() ? '助手准备中' : '助手'
		},
			assistantThreadTitle(): string {
				if (this.assistantTitle.length > 0) return this.assistantTitle
				return 'AI 助手'
			},
			normalizedRailMode(mode: string): string {
				if (mode == 'assistant' || mode == 'annotate' || mode == 'search') return mode
				return 'conversation'
			},
			restorableRailMode(mode: string): string {
				if (mode == 'assistant' || mode == 'annotate') return mode
				return 'conversation'
			},
			normalizedRightMode(mode: string): string {
				if (mode == 'web' || mode == 'files') return mode
				return 'chat'
			},
			activeComposerKind(): string {
				return this.activeRailMode == 'assistant' ? 'assistant' : 'conversation'
			},
			rememberPromptDraft() {
				if (this.activeComposerKind() == 'assistant') {
					this.assistantPromptDraft = this.prompt
				} else {
					this.conversationPromptDraft = this.prompt
				}
			},
			restorePromptDraft() {
				this.prompt = this.activeComposerKind() == 'assistant' ? this.assistantPromptDraft : this.conversationPromptDraft
			},
			setPromptForActiveComposer(value: string) {
				this.prompt = value
				this.rememberPromptDraft()
			},
			setRightModePersisted(mode: string, persist: boolean = true) {
				const next = this.normalizedRightMode(mode)
				if (this.rightMode == 'chat' && next != 'chat') this.rememberPromptDraft()
				this.rightMode = next
				if (next == 'chat') this.restorePromptDraft()
				if (persist) setRightMode(next)
			},
			setContentRailMode(mode: string, persist: boolean = true) {
				const next = this.normalizedRailMode(mode)
				if (this.rightMode == 'chat' && next != this.activeRailMode) this.rememberPromptDraft()
				if (this.settingsOpen) {
					this.previousRailMode = next
				} else {
					this.activeRailMode = next
					this.previousRailMode = next
				}
				if (this.rightMode == 'chat') this.restorePromptDraft()
				if (persist) setActiveRailMode(next)
			},
			setWorkspaceState(railMode: string, rightMode: string, persist: boolean = true) {
				this.setContentRailMode(railMode, persist)
				this.setRightModePersisted(rightMode, persist)
			},
			restoreRailModeFromContext() {
				if (this.isAssistantThread(this.activeThreadId)) {
					this.setContentRailMode('assistant')
				} else {
					this.setContentRailMode('conversation')
				}
			},
			restoreInitialWorkspace(savedRailValue: string, savedRightValue: string) {
				this.settingsOpen = false
				const savedRailMode = this.restorableRailMode(savedRailValue)
				const savedRightMode = this.normalizedRightMode(savedRightValue)
				if (savedRightMode == 'web') {
					this.setWorkspaceState('annotate', 'web', false)
					if (this.embeddedWebUrl.length == 0) this.setEmbeddedWebUrl(getDevUrl())
					this.checkExternalUrl(this.embeddedWebUrl)
					return
				}
				if (savedRightMode == 'files') {
					const rail = savedRailMode == 'assistant' ? 'conversation' : savedRailMode
					this.setWorkspaceState(rail, 'files', false)
					return
				}
				if (savedRailMode == 'assistant' && this.hasAssistantBinding()) {
					this.setWorkspaceState('assistant', 'chat', false)
					this.mainTitle = this.assistantThreadTitle()
					this.activeThreadId = this.assistantThreadId
					setActiveThreadId(this.assistantThreadId)
					this.activeProjectId = ''
					this.activeProjectPath = ''
					setActiveProjectId('')
					if (this.messages.length == 0 && this.processEvents.length == 0) {
						if (!this.restoreCachedThreadSnapshot(this.assistantThreadId)) this.loadThreadSnapshot(this.assistantThreadId, false)
					}
					return
				}
				this.setWorkspaceState('conversation', 'chat', false)
				if (this.activeThreadId.length > 0 && !this.isAssistantThread(this.activeThreadId)) {
					const activeThread = this.findThreadById(this.activeThreadId)
					if (activeThread != null) {
						this.applyThreadSummary(activeThread)
						if (this.messages.length == 0 && this.processEvents.length == 0) {
							if (!this.restoreCachedThreadSnapshot(activeThread.id)) this.loadThreadSnapshot(activeThread.id, false)
						}
						return
					}
					if (this.restoreCachedThreadSnapshot(this.activeThreadId)) return
				}
				if (this.selectRecentNormalThread()) return
				if (this.ensureDefaultChatThread('restore_initial')) return
				this.clearActiveThread()
			},
			isAssistantViewActive(): boolean {
				return this.activeRailMode == 'assistant'
			},
			isConversationViewActive(): boolean {
				return this.activeRailMode == 'conversation'
			},
		isAssistantThread(threadId: string): boolean {
			return threadId.length > 0 && threadId == this.assistantThreadId
		},
		displayThreadTitle(thread: CodexThread): string {
			if (this.isAssistantThread(thread.id)) return this.assistantThreadTitle()
			return thread.title
		},
		normalizeAssistantThreadSummary(summary: CodexThread): CodexThread {
			if (!this.isAssistantThread(summary.id)) return summary
			summary.projectId = CODEX_DIRECT_PROJECT_ID
			summary.projectName = '对话'
			summary.cwd = ''
			return summary
		},
		repairAssistantThreadScope(threadId: string) {
			if (!this.isAssistantThread(threadId)) return
			apiCodexThreadScope(threadId, 'direct', '', (ok, summary, error) => {
				if (!ok) {
					console.log('[vibego-app-debug] repairAssistantThreadScope failed', threadId, error)
					return
				}
				if (summary.id.length == 0) return
				const normalized = this.normalizeAssistantThreadSummary(summary)
				this.upsertThreadSummary(normalized)
				if (this.activeThreadId == normalized.id) this.applyThreadSummary(normalized)
			})
		},
			openAssistant() {
				this.triggerWorkspaceMotion()
				this.settingsOpen = false
				this.setContentRailMode('assistant')
				if (!this.hasAssistantBinding()) {
					this.createAssistant()
					return
				}
			this.repairAssistantThreadScope(this.assistantThreadId)
			if (this.activeThreadId == this.assistantThreadId && (this.messages.length > 0 || this.processEvents.length > 0)) {
				this.showChat()
				return
			}
			const thread = this.findThreadById(this.assistantThreadId)
			if (thread != null) {
				this.selectThreadById(thread.id)
				return
			}
			this.stopPolling()
			this.clearWatch()
			this.clearCursor()
			this.threadLoading = true
			this.messages = new Array<ChatMessage>()
			this.resetMessageViews()
			this.processEvents = new Array<CodexProcessEvent>()
			this.codexRunning = false
			this.activeThreadId = this.assistantThreadId
			setActiveThreadId(this.assistantThreadId)
			if (this.assistantProjectId.length > 0) {
				this.activeProjectId = this.assistantProjectId
				setActiveProjectId(this.assistantProjectId)
				this.syncActiveProjectPath()
			} else {
				this.activeProjectId = ''
				this.activeProjectPath = ''
				setActiveProjectId('')
			}
			this.mainTitle = this.assistantThreadTitle()
			this.showChat()
			if (!this.restoreCachedThreadSnapshot(this.assistantThreadId)) this.loadThreadSnapshot(this.assistantThreadId, false)
		},
		openAssistantFromCompactDrawer() {
			this.closeCompactDrawer()
			this.openAssistant()
		},
		openAssistantOnLaunch() {
			this.settingsOpen = false
			this.setWorkspaceState('assistant', 'chat')
			if (!this.hasAssistantBinding()) {
				this.mainTitle = this.assistantThreadTitle()
				return
			}
			this.repairAssistantThreadScope(this.assistantThreadId)
			if (this.activeThreadId != this.assistantThreadId) {
				this.activeThreadId = this.assistantThreadId
				setActiveThreadId(this.assistantThreadId)
			}
			this.activeProjectId = ''
			this.activeProjectPath = ''
			setActiveProjectId('')
			this.mainTitle = this.assistantThreadTitle()
			const thread = this.findThreadById(this.assistantThreadId)
			if (thread != null) this.applyThreadSummary(thread)
			if (this.messages.length == 0 && this.processEvents.length == 0) {
				if (!this.restoreCachedThreadSnapshot(this.assistantThreadId)) this.loadThreadSnapshot(this.assistantThreadId, false)
			}
		},
		resetAssistant() {
			this.settingsOpen = false
			this.clearAssistantBinding()
			this.createAssistant()
		},
		ensureAssistantReady() {
			if (this.hasAssistantBinding()) {
				this.repairAssistantThreadScope(this.assistantThreadId)
				return
			}
			this.createAssistantInMode(false)
		},
		createAssistant() {
			this.createAssistantInMode(true)
		},
		createAssistantInMode(foreground: boolean) {
			if (this.assistantInitializing) return
			this.assistantInitializing = true
			const projectId = ''
			this.assistantPendingProjectId = ''
				if (foreground) {
					this.stopPolling()
					this.clearWatch()
					this.clearCursor()
					this.setWorkspaceState('assistant', 'chat')
					this.activeProjectId = ''
					this.activeProjectPath = ''
					setActiveProjectId('')
				this.activeThreadId = ''
				setActiveThreadId('')
				this.messages = new Array<ChatMessage>()
				this.resetMessageViews()
				this.processEvents = new Array<CodexProcessEvent>()
				this.codexRunning = false
				this.threadLoading = false
				this.mainTitle = this.assistantThreadTitle()
			}
			const text = this.buildAssistantInitPrompt()
			if (foreground) this.pushLocalProcessEvent('send_step', '正在初始化助手并自动发送提示词…', 'assistant_init')
			const clientRequestId = Date.now().toString() + '-assistant-' + Math.floor(Math.random() * 100000).toString()
			apiCodexSend(projectId, '', text, clientRequestId, 'direct', (ok, result, error) => {
				if (ok) {
					if (foreground) {
						this.applyWatch(result.watch)
						this.applyStatusEvents(result.events)
					}
					if (result.accepted && result.threadId.length > 0) {
						this.bindAssistantThread(result.threadId, projectId)
						if (foreground) {
							this.activeThreadId = result.threadId
							setActiveThreadId(result.threadId)
							this.clearWatch()
							this.loadThreadSnapshot(result.threadId, true)
							uni.showToast({ title: '助手已创建', icon: 'success' })
						} else {
							this.loadThreads()
						}
					} else {
						if (foreground) {
							this.startStatusPolling()
						} else {
							this.assistantInitializing = false
							this.assistantPendingProjectId = ''
						}
					}
					return
				}
					this.assistantInitializing = false
					this.assistantPendingProjectId = ''
					this.pendingAssistantPromptWaiting = false
					if (this.pendingAssistantPrompt.length > 0 && this.prompt.trim().length == 0) {
						this.setPromptForActiveComposer(this.pendingAssistantPrompt)
					}
					this.statusText = error
					if (foreground) {
						this.applyStatusEvents(result.events)
						this.pushLocalProcessEvent('task_error', '助手初始化失败：' + error, 'assistant_failed')
					}
				})
		},
		bindAssistantThread(threadId: string, projectId: string) {
			if (threadId.length == 0) return
			this.assistantThreadId = threadId
			this.assistantProjectId = ''
			this.assistantTitle = 'AI 助手'
			if (this.assistantInitializedAt.length == 0) this.assistantInitializedAt = new Date().toISOString()
			this.assistantInitializing = false
			this.assistantPendingProjectId = ''
			this.persistAssistantRecord()
			if (this.dropDialogOpen && this.dropSendTarget.kind == 'assistant_pending') {
				this.dropSendTarget = this.defaultDropSendTarget()
			}
			if (this.pendingAssistantPrompt.length > 0) {
				this.pendingAssistantPromptWaiting = true
			}
		},
		buildAssistantInitPrompt(): string {
			let text = '你现在是我的长期 AI 助手。后续我发给你的任何内容，你都要结合这个会话的上下文持续为我提供帮助、建议，并尽量直接推进执行。'
			text = text + '\n\n你的工作方式：'
			text = text + '\n1. 优先理解我的真实目标，不要只做表面回复。'
			text = text + '\n2. 如果信息足够，直接给出可执行建议、修改方案、排查步骤或结果。'
			text = text + '\n3. 如果信息不足，只提出最少但关键的澄清。'
			text = text + '\n4. 当我发截图、文件、录音、代码片段时，默认你要结合它们继续处理当前任务。'
			text = text + '\n5. 回复保持直接、简洁、面向执行。'
			text = text + '\n\n如果你理解了，就用一句话确认你会作为我的长期助手持续协助这个会话。'
			return text
		},
		applyComposerDraft() {
			const draft = getComposerDraft()
			if (draft.length > 0) {
				this.setPromptForActiveComposer(draft)
				setComposerDraft('')
			}
		},
			onDropUploaded(info: DropUploadedInfo) {
				console.log('[vibego-file-drop]', this.dropDialogOpen ? 'replace-active' : 'queued', 'path=' + info.path)
				this.markDropForegroundActive()
				if (this.dropDialogOpen) {
					this.activeDropFile = info
					this.activeClipboardText = ''
					this.dropSendTarget = this.defaultDropSendTarget()
					this.dropSending = false
					this.dropSendingKind = ''
					this.dropSendError = ''
					return
				}
				this.pendingDropFiles.push(info)
				this.openNextDropDialog()
			},
			onClipboardFirst(info: ClipboardFirstInfo) {
				this.openClipboardDialog(info.text, false)
			},
			onAppShow() {},
			openConversationList() {
				this.triggerWorkspaceMotion()
				this.settingsOpen = false
				this.setWorkspaceState('conversation', 'chat')
				this.conversationOpenPending = true
				if (this.selectRecentNormalThread()) {
					this.conversationOpenPending = false
					return
				}
				if (this.isAssistantThread(this.activeThreadId)) {
					this.clearActiveThread()
				}
				if (this.threads.length == 0) {
					this.loadThreads()
					return
				}
				this.conversationOpenPending = false
			},
			openConversationListFromCompactDrawer() {
				this.openConversationList()
				this.compactDrawerOpen = true
			},
			scheduleClipboardRead() {
				const shouldPrime = !this.clipboardAutoPrimed
				const first = readSystemClipboardText('pages/index/index')
				this.handleAutoClipboardText(first, false)
				if (this.clipboardReadTimer != 0) clearTimeout(this.clipboardReadTimer)
				this.clipboardReadTimer = setTimeout(() => {
					this.clipboardReadTimer = 0
					const text = readSystemClipboardText('pages/index/index')
					this.handleAutoClipboardText(text, false)
					if (shouldPrime) this.clipboardAutoPrimed = true
				}, 360)
			},
			handleAutoClipboardText(text: string, shouldPrime: boolean) {
				const value = text.trim()
				console.log('[vibego-clipboard]', 'auto-read', 'length=' + value.length.toString() + ' shouldPrime=' + shouldPrime.toString() + ' dialogOpen=' + this.dropDialogOpen.toString())
				if (value.length == 0) {
					if (shouldPrime) this.lastClipboardDialogText = ''
					return
				}
				if (shouldPrime) {
					this.lastClipboardDialogText = value
					this.lastClipboardDialogFingerprint = this.clipboardDialogFingerprint(value)
					return
				}
				this.openClipboardDialog(value, false)
			},
			loadClipboardDialogFingerprint(): string {
				const value = uni.getStorageSync(CLIPBOARD_DIALOG_FINGERPRINT_KEY)
				return typeof value == 'string' ? value : ''
			},
			clipboardDialogFingerprint(text: string): string {
				const value = text.trim()
				let hash = 7
				for (let index: Int = 0; index < value.length; index++) {
					const code = value.charCodeAt(index) ?? 0
					hash = (hash * 131 + code) % 2147483647
				}
				return value.length.toString() + ':' + hash.toString()
			},
			rememberClipboardDialogText(text: string) {
				const value = text.trim()
				this.lastClipboardDialogText = value
				this.lastClipboardDialogFingerprint = this.clipboardDialogFingerprint(value)
				uni.setStorageSync(CLIPBOARD_DIALOG_FINGERPRINT_KEY, this.lastClipboardDialogFingerprint)
			},
			dismissIdleClipboardDialogOnHide() {
				if (!this.dropDialogOpen) return
				if (this.dropSending) return
				if (this.activeDropFile != null) return
				if (this.activeClipboardText.length == 0) return
				if (this.dropInstruction.trim().length > 0) return
				this.rememberClipboardDialogText(this.activeClipboardText)
				console.log('[vibego-clipboard]', 'dialog-auto-dismiss-on-hide', 'length=' + this.activeClipboardText.length.toString())
				this.closeDropDialog()
			},
			onShareText(text: string) {
				if (text.length == 0) return
				this.appendComposerText(text)
			this.showChat()
			uni.showToast({ title: '已加入对话', icon: 'success' })
			},
			openUploadMenu() {
				uni.showActionSheet({
					itemList: ['剪切板', '拍照', '相册', '任意文件'],
					success: (res) => {
						if (res.tapIndex == 0) {
							this.readClipboardIntoDialog()
							return
						}
						if (res.tapIndex == 1) {
							this.choosePhotoUpload(['camera'])
							return
						}
						if (res.tapIndex == 2) {
							this.choosePhotoUpload(['album'])
							return
						}
						this.chooseAnyFileUpload()
					},
				})
			},
			readClipboardIntoDialog() {
				const text = readSystemClipboardFirst('pages/index/index')
				if (text.trim().length == 0) {
					uni.showToast({ title: '剪切板没有文字', icon: 'none' })
					return
				}
				this.openClipboardDialog(text, true)
			},
			openClipboardDialog(text: string, force: boolean) {
				const value = text.trim()
				if (value.length == 0) return
				if (this.dropDialogOpen) {
					console.log('[vibego-clipboard]', 'dialog-skip', 'reason=dialog-open length=' + value.length.toString())
					return
				}
				const fingerprint = this.clipboardDialogFingerprint(value)
				if (!force && (value == this.lastClipboardDialogText || fingerprint == this.lastClipboardDialogFingerprint || fingerprint == this.loadClipboardDialogFingerprint())) {
					console.log('[vibego-clipboard]', 'dialog-skip', 'reason=same-content length=' + value.length.toString())
					return
				}
				this.activeDropFile = null
				this.activeClipboardText = value
				this.rememberClipboardDialogText(value)
				this.dropInstruction = ''
				this.dropSendTarget = this.defaultDropSendTarget()
				this.dropSending = false
				this.dropSendingKind = ''
				this.dropSendError = ''
				this.dropDialogOpen = true
				console.log('[vibego-clipboard]', 'dialog-open', 'length=' + value.length.toString() + ' force=' + force.toString())
			},
		choosePhotoUpload(sourceTypes: Array<string>) {
			console.log('[vibego-file-drop]', 'choose-image-start')
			try {
				uni.chooseImage({
					count: 9,
					sizeType: ['original'],
					sourceType: sourceTypes,
					success: (res) => {
						const paths = res.tempFilePaths
						console.log('[vibego-file-drop]', 'choose-image-success', 'count=' + paths.length.toString())
						if (paths.length == 0) return
						this.uploadChosenLocalFiles(paths, 'image/*', '正在上传照片...', '照片已加入对话')
					},
					fail: (err) => {
						console.log('[vibego-file-drop]', 'choose-image-failed', err)
						if (err.errMsg.indexOf('cancel') >= 0) return
						uni.showToast({ title: err.errMsg, icon: 'none' })
					},
				})
			} catch (error) {
				console.log('[vibego-file-drop]', 'choose-image-exception', error)
				uni.showToast({ title: '当前基座缺少相册模块', icon: 'none' })
			}
		},
		chooseAnyFileUpload() {
			try {
				uni.chooseFile({
					count: 9,
					type: 'all',
					success: (res) => {
						const paths = new Array<string>()
						for (let pathIndex: Int = 0; pathIndex < res.tempFilePaths.length; pathIndex++) {
							this.pushUniqueFilePath(paths, res.tempFilePaths[pathIndex])
						}
						const files = res.tempFiles
						for (let index: Int = 0; index < files.length; index++) {
							const path = files[index].path
							this.pushUniqueFilePath(paths, path)
						}
						console.log('[vibego-file-drop]', 'choose-file-success', 'tempFilePaths=' + res.tempFilePaths.length.toString() + ' tempFiles=' + files.length.toString() + ' paths=' + paths.length.toString())
						if (paths.length == 0) return
						this.uploadChosenLocalFiles(paths, '*/*', '正在上传文件...', '文件已加入对话')
					},
					fail: (err) => {
						console.log('[vibego-file-drop]', 'choose-file-failed', err)
						if (err.errMsg.indexOf('cancel') >= 0) return
						uni.showToast({ title: err.errMsg, icon: 'none' })
					},
				})
			} catch (error) {
				console.log('[vibego-file-drop]', 'choose-file-exception', error)
				uni.showToast({ title: '当前基座缺少文件选择模块', icon: 'none' })
			}
		},
			pushUniqueFilePath(paths: Array<string>, path: string) {
				if (path.length == 0) return
				for (let index: Int = 0; index < paths.length; index++) {
					if (paths[index] == path) return
				}
				paths.push(path)
			},
			uploadChosenLocalFiles(filePaths: Array<string>, mimeType: string, loadingTitle: string, successTitle: string) {
				if (filePaths.length == 0) return
				let uploaded = 0
				let failed = 0
				uni.showToast({ title: filePaths.length > 1 ? ('正在上传' + filePaths.length.toString() + '个文件...') : loadingTitle, icon: 'none' })
				for (let index: Int = 0; index < filePaths.length; index++) {
					const filePath = filePaths[index]
					if (filePath.length == 0) {
						failed = failed + 1
						continue
					}
					uploadMobileFile(filePath, filePath, mimeType, (ok, record, error) => {
						if (ok && record != null) {
							this.addComposerAttachment(record.url.length > 0 ? record.url : record.path, record.path, record.mimeType, record.name)
							uploaded = uploaded + 1
							this.showChat()
						} else {
							failed = failed + 1
							console.log('[vibego-file-drop]', 'multi-upload-failed', error)
						}
						if (uploaded + failed >= filePaths.length) {
							if (uploaded > 0) {
								uni.showToast({ title: uploaded > 1 ? ('已加入' + uploaded.toString() + '个文件') : successTitle, icon: 'success' })
							} else {
								uni.showToast({ title: error.length > 0 ? error : '上传失败', icon: 'none' })
							}
						}
					})
				}
			},
			uploadChosenLocalFile(filePath: string, mimeType: string, loadingTitle: string, successTitle: string) {
				if (filePath.length == 0) return
				const paths = new Array<string>()
				paths.push(filePath)
				this.uploadChosenLocalFiles(paths, mimeType, loadingTitle, successTitle)
		},
		openNextDropDialog() {
			if (this.dropDialogOpen) return
			if (this.pendingDropFiles.length == 0) return
			const file = this.pendingDropFiles[0]
			const next = new Array<DropUploadedInfo>()
			for (let i: Int = 1; i < this.pendingDropFiles.length; i++) {
				next.push(this.pendingDropFiles[i])
			}
			this.pendingDropFiles = next
			this.activeDropFile = file
			this.dropInstruction = ''
			this.dropSendTarget = this.defaultDropSendTarget()
			this.dropSending = false
			this.dropSendingKind = ''
			this.dropSendError = ''
			this.dropDialogOpen = true
		},
		defaultDropSendTarget(): DropSendTarget {
			const current = this.currentThreadDropSendTarget()
			if (current != null) return current
			return this.assistantDropSendTarget()
		},
		assistantDropSendTarget(): DropSendTarget {
			if (this.hasAssistantBinding()) {
				return {
					kind: 'assistant',
					title: 'AI 助手',
					subtitle: '长期助手会话',
					threadId: this.assistantThreadId,
					projectId: '',
					scope: '',
				}
			}
			return {
				kind: 'assistant_pending',
				title: 'AI 助手准备中',
				subtitle: '正在自动创建助手会话',
				threadId: '',
				projectId: '',
				scope: 'direct',
			}
		},
		currentThreadDropSendTarget(): DropSendTarget | null {
			const thread = this.currentDropThreadTarget()
			if (thread != null) {
				const projectName = thread.projectName.length > 0 ? thread.projectName : '对话'
				return {
					kind: 'current_thread',
					title: '当前会话',
					subtitle: projectName,
					threadId: thread.id,
					projectId: thread.projectId,
					scope: '',
				}
			}
			const activeThreadId = this.activeThreadId
			if (activeThreadId.length > 0 && !this.isAssistantThread(activeThreadId) && this.activeRailMode == 'conversation') {
				let subtitle = this.mainTitle.length > 0 ? this.mainTitle : '对话'
				if (this.activeProjectId.length > 0) {
					for (let index: Int = 0; index < this.projects.length; index++) {
						if (this.projects[index].id == this.activeProjectId && this.projects[index].name.length > 0) {
							subtitle = this.projects[index].name
							break
						}
					}
				}
				return {
					kind: 'current_thread',
					title: this.mainTitle.length > 0 ? this.mainTitle : '当前会话',
					subtitle,
					threadId: activeThreadId,
					projectId: this.activeProjectId,
					scope: '',
				}
			}
			const recent = this.findRecentNormalThread()
			if (recent == null) return null
			const recentProjectName = recent.projectName.length > 0 ? recent.projectName : '对话'
				return {
					kind: 'current_thread',
					title: '当前会话',
					subtitle: recentProjectName,
					threadId: recent.id,
					projectId: recent.projectId,
					scope: '',
				}
			},
			dropCurrentButtonText(): string {
				if (this.dropSending && this.dropSendingKind == 'current_thread') return '发送中...'
				return '当前会话'
			},
			dropAssistantButtonText(): string {
				if (this.dropSending && (this.dropSendingKind == 'assistant' || this.dropSendingKind == 'assistant_pending')) return '发送中...'
				if (!this.hasAssistantBinding()) return 'AI助手'
				return 'AI助手'
			},
		recentDropThreadId(): string {
			const value = uni.getStorageSync(RECENT_NORMAL_THREAD_KEY)
			return typeof value == 'string' ? value : ''
		},
		rememberRecentNormalThread(threadId: string) {
			if (threadId.length == 0) return
			if (this.isAssistantThread(threadId)) return
			uni.setStorageSync(RECENT_NORMAL_THREAD_KEY, threadId)
		},
		currentDropThreadTarget(): CodexThread | null {
			const id = this.activeThreadId
			if (id.length == 0) return null
			if (this.isAssistantThread(id)) return null
			return this.findThreadById(id)
		},
		hasCurrentDropThreadTarget(): boolean {
			return this.currentDropThreadTarget() != null
		},
		currentDropThreadTitle(): string {
			const thread = this.currentDropThreadTarget()
			if (thread == null) return ''
			return this.displayThreadTitle(thread)
		},
		dropPreviewUrl(): string {
			const file = this.activeDropFile
			if (file == null) return ''
			return file.url
		},
			dropPreviewIsImage(): boolean {
				const file = this.activeDropFile
				if (file == null) return false
				return file.url.length > 0 && file.mimeType.startsWith('image/')
			},
			dropPreviewIsClipboard(): boolean {
				return this.activeClipboardText.length > 0
			},
			dropPreviewClipboardText(): string {
				const text = this.activeClipboardText.replace(/\s+/g, ' ').trim()
				if (text.length <= 128) return text
				return text.substring(0, 128) + '...'
			},
			currentAsrMode(): string {
				return 'cloud'
			},
			activeVoiceMode(): string {
				return 'cloud'
			},
			asrModeLabel(mode: string): string {
				return '火山'
			},
			asrModeButtonClass(mode: string): string {
				const classes = new Array<string>()
				if (this.currentAsrMode() == mode) classes.push('voice-mode-option-active')
				if (this.voiceRecording || this.voiceTranscribing || this.globalVoiceActive) classes.push('voice-mode-option-disabled')
				return classes.join(' ')
			},
			asrModeTextClass(mode: string): string {
				if (this.currentAsrMode() == mode) return 'voice-mode-option-text-active'
				return ''
			},
			changeAsrMode(mode: string) {
				if (this.voiceRecording || this.voiceTranscribing || this.globalVoiceActive) {
					uni.showToast({ title: '录音进行中，先结束再切换方案', icon: 'none' })
					return
				}
				this.asrMode = 'cloud'
				setAsrMode('cloud')
			},
			composerMicActive(): boolean {
				return this.globalVoiceActive
			},
			dropMicActive(): boolean {
				return this.globalVoiceActive
			},
			dropMicButtonText(): string {
				return this.asrModeLabel(this.currentAsrMode()) + '录音'
			},
			resetVoiceUi() {
				this.voiceRecording = false
				this.voiceTranscribing = false
				this.voicePreviewText = ''
				this.voiceLastFinalText = ''
				this.voiceTarget = ''
				this.voiceSessionMode = ''
				this.voiceRecordPath = ''
				this.voiceSessionId = 0
				releaseVoiceSession(PAGE_VOICE_OWNER)
			},
			cancelActiveVoiceSession() {
				this.resetVoiceUi()
				cancelVoiceRecording()
			},
			resetDropDialogState() {
				if (this.voiceTarget == 'drop' && (this.voiceRecording || this.voiceTranscribing)) {
					this.cancelActiveVoiceSession()
				}
				this.dropDialogOpen = false
				this.pendingDropFiles = new Array<DropUploadedInfo>()
				this.activeDropFile = null
				this.activeClipboardText = ''
				this.dropInstruction = ''
				this.dropSendTarget = this.defaultDropSendTarget()
				this.dropSending = false
				this.dropSendingKind = ''
				this.dropSendError = ''
				this.resetVoiceUi()
			},
			closeDropDialog() {
				if (this.voiceTarget == 'drop' && (this.voiceRecording || this.voiceTranscribing)) {
					this.cancelActiveVoiceSession()
				}
				this.dropDialogOpen = false
				this.activeDropFile = null
				this.activeClipboardText = ''
				this.dropInstruction = ''
				this.dropSendTarget = this.defaultDropSendTarget()
				this.dropSending = false
				this.dropSendingKind = ''
				this.dropSendError = ''
				this.resetVoiceUi()
				this.openNextDropDialog()
			},
			dropPayloadText(): string {
				const instruction = this.dropInstruction.trim()
				if (this.activeClipboardText.length > 0) {
					let text = instruction.length > 0 ? ('请按以下要求处理这段剪切板文字：\n' + instruction) : '请处理这段剪切板文字。'
					text = text + '\n\n剪切板内容：\n' + this.activeClipboardText
					return text
				}
				const file = this.activeDropFile
				if (file == null) return ''
				let text = instruction.length > 0 ? ('请按以下要求处理这个文件：\n' + instruction) : '请处理这个文件。'
				const fileRef = file.path.length > 0 ? file.path : file.url
				text = text + '\n\n' + this.attachmentPathInstruction(fileRef)
				return text
			},
			dropCanSend(): boolean {
				return this.dropCanSendToTarget(this.defaultDropSendTarget())
			},
			dropCanSendToTarget(target: DropSendTarget): boolean {
				if (this.dropSending || this.voiceRecording || this.voiceTranscribing) return false
				if (target.kind == 'assistant_pending') return false
				return this.dropPayloadText().length > 0
			},
			dropCanSendToCurrentThread(): boolean {
				const target = this.currentThreadDropSendTarget()
				if (target == null) return false
				return this.dropCanSendToTarget(target)
			},
			dropCanSendToAssistant(): boolean {
				return this.dropCanSendToTarget(this.assistantDropSendTarget())
			},
			sendDropToTarget(target: DropSendTarget) {
				if (!this.dropCanSendToTarget(target)) {
					console.log('[vibego-drop-dialog]', 'send-blocked', 'dropSending=' + this.dropSending.toString(), 'voiceRecording=' + this.voiceRecording.toString(), 'voiceTranscribing=' + this.voiceTranscribing.toString(), 'globalVoiceActive=' + this.globalVoiceActive.toString(), 'target=' + target.kind, 'payloadLength=' + this.dropPayloadText().length.toString())
					return
				}
				const text = this.dropPayloadText()
				if (text.length == 0) return
				this.dropSending = true
				this.dropSendingKind = target.kind
				this.dropSendError = ''
				this.sendDropPayloadToTarget(target, text)
			},
			sendDropToCurrentThread() {
				const target = this.currentThreadDropSendTarget()
				if (target == null) return
				this.sendDropToTarget(target)
			},
			sendDropToAssistant() {
				this.sendDropToTarget(this.assistantDropSendTarget())
			},
			triggerPrimarySend() {
				console.log('[vibego-keyboard]', 'trigger-primary-send', 'dropDialogOpen=' + this.dropDialogOpen.toString() + ' promptLength=' + this.prompt.length.toString())
				if (this.dropDialogOpen) {
					console.log('[vibego-keyboard]', 'trigger-primary-send-drop', 'target=' + this.defaultDropSendTarget().kind)
					this.sendDropToTarget(this.defaultDropSendTarget())
					return
				}
				console.log('[vibego-keyboard]', 'trigger-primary-send-prompt', 'length=' + this.prompt.length.toString())
				this.sendPrompt()
			},
			triggerPrimaryDelete() {
				console.log('[vibego-keyboard]', 'trigger-primary-delete', 'dropDialogOpen=' + this.dropDialogOpen.toString() + ' promptLength=' + this.prompt.length.toString() + ' dropInstructionLength=' + this.dropInstruction.length.toString())
				if (this.dropDialogOpen) {
					if (this.dropInstruction.length > 0) {
						this.dropInstruction = this.dropInstruction.substring(0, this.dropInstruction.length - 1)
						console.log('[vibego-keyboard]', 'trigger-primary-delete-drop', 'dropInstructionLength=' + this.dropInstruction.length.toString())
					}
					return
				}
				if (this.prompt.length > 0) {
					this.setPromptForActiveComposer(this.prompt.substring(0, this.prompt.length - 1))
					console.log('[vibego-keyboard]', 'trigger-primary-delete-prompt', 'promptLength=' + this.prompt.length.toString())
					return
				}
				console.log('[vibego-keyboard]', 'trigger-primary-delete-empty', 'noop=1')
			},
			triggerPrimaryClear() {
				console.log('[vibego-keyboard]', 'trigger-primary-clear', 'dropDialogOpen=' + this.dropDialogOpen.toString() + ' promptLength=' + this.prompt.length.toString() + ' dropInstructionLength=' + this.dropInstruction.length.toString())
				if (this.dropDialogOpen) {
					if (this.dropInstruction.length > 0) {
						this.dropInstruction = ''
						console.log('[vibego-keyboard]', 'trigger-primary-clear-drop', 'dropInstructionLength=0')
					}
					return
				}
				if (this.prompt.length > 0) {
					this.setPromptForActiveComposer('')
					console.log('[vibego-keyboard]', 'trigger-primary-clear-prompt', 'promptLength=0')
					return
				}
				console.log('[vibego-keyboard]', 'trigger-primary-clear-empty', 'noop=1')
			},
			applyDropTargetBeforeSend(target: DropSendTarget, text: string) {
				const previousThreadId = this.activeThreadId
				this.stopPolling()
				this.clearWatch()
				this.clearCursor()
				let targetThreadId = target.threadId
				if (target.kind == 'assistant') targetThreadId = this.assistantThreadId
				const sameThread = targetThreadId.length > 0 && previousThreadId == targetThreadId
				if (!sameThread) {
					this.messages = new Array<ChatMessage>()
					this.resetMessageViews()
					this.processEvents = new Array<CodexProcessEvent>()
				}
				if (targetThreadId.length > 0) {
					this.activeThreadId = targetThreadId
					setActiveThreadId(targetThreadId)
					const thread = this.findThreadById(targetThreadId)
					if (thread != null) {
						this.applyThreadSummary(thread)
					} else if (target.kind == 'assistant') {
						this.activeProjectId = ''
						this.activeProjectPath = ''
						setActiveProjectId('')
						this.mainTitle = this.assistantThreadTitle()
					} else {
						this.mainTitle = target.title
					}
				} else {
					this.activeThreadId = ''
					setActiveThreadId('')
					this.activeProjectId = target.projectId
					setActiveProjectId(target.projectId)
					this.syncActiveProjectPath()
					this.mainTitle = ''
					}
					const sentAt = new Date().toISOString()
					const localMessage: ChatMessage = { id: 'local-user-' + sentAt, role: 'user', label: 'You', text, timestamp: sentAt }
					this.processEvents = new Array<CodexProcessEvent>()
					this.messages.push(localMessage)
					this.appendMessageView(localMessage)
					this.pushLocalProcessEvent('send_step', '正在发送到 ' + target.title + '…', 'prepare')
				this.codexRunning = true
				this.showChat()
				this.scheduleChatBottom()
			},
			sendDropPayloadToTarget(target: DropSendTarget, text: string) {
				let projectId = target.projectId
				let threadId = target.threadId
				let scope = target.scope
				if (target.kind == 'assistant') {
					threadId = this.assistantThreadId
					projectId = ''
					scope = ''
				}
				if (threadId.length == 0 && scope.length == 0) scope = projectId.length > 0 ? 'project' : 'direct'
				if (target.kind == 'assistant' && threadId.length == 0) {
					this.dropSending = false
					this.dropSendingKind = ''
					this.dropSendError = 'AI 助手还在准备中'
					return
				}
				this.applyDropTargetBeforeSend(target, text)
				this.closeDropDialog()
				const clientRequestId = Date.now().toString() + '-drop-' + Math.floor(Math.random() * 100000).toString()
				apiCodexSend(projectId, threadId, text, clientRequestId, scope, (ok, result, error) => {
					if (ok) {
						this.dropSending = false
						this.dropSendingKind = ''
						this.applyWatch(result.watch)
						this.applyStatusEvents(result.events)
						if (result.threadId.length > 0) {
							this.activeThreadId = result.threadId
							setActiveThreadId(result.threadId)
							if (target.kind != 'assistant') this.rememberRecentNormalThread(result.threadId)
						}
						if (result.accepted && result.threadId.length > 0) {
							this.clearWatch()
							this.loadThreadSnapshot(result.threadId, true)
						} else {
							this.startStatusPolling()
						}
						return
					}
					this.dropSending = false
					this.dropSendingKind = ''
					this.dropSendError = error
					this.statusText = error
					this.applyStatusEvents(result.events)
					this.pushLocalProcessEvent('task_error', '发送失败：' + error, 'send_failed')
				})
			},
		cancelDropFile() {
			console.log('[vibego-drop-dialog]', 'parent-cancelDropFile', 'dropSending=' + this.dropSending.toString(), 'dropDialogOpen=' + this.dropDialogOpen.toString(), 'activeDropFile=' + (this.activeDropFile != null ? 'yes' : 'no'), 'pendingCount=' + this.pendingDropFiles.length.toString())
			if (isGlobalVoiceActive()) {
				console.log('[vibego-drop-dialog]', 'parent-cancelDropFile-blocked-global-voice')
				this.globalVoiceActive = true
				return
			}
			if (this.dropSending) {
				console.log('[vibego-drop-dialog]', 'parent-cancelDropFile-blocked-sending')
				return
			}
			this.closeDropDialog()
		},
		noopClick() {
			console.log('[vibego-drop-dialog]', 'parent-noopClick')
			// 拦截弹窗内部点击，阻止冒泡到遮罩层
			},
			appendComposerFilePath(path: string) {
				if (path.length == 0) return
				const line = this.attachmentPathInstruction(path)
				this.appendComposerText(line)
			},
			appendComposerText(text: string) {
				if (text.length == 0) return
				if (this.prompt.trim().length == 0) {
					this.setPromptForActiveComposer(text)
					return
				}
				if (this.prompt.endsWith('\n')) {
					this.setPromptForActiveComposer(this.prompt + text)
				} else {
					this.setPromptForActiveComposer(this.prompt + '\n' + text)
				}
			},
			addComposerAttachment(url: string, path: string, mimeType: string, name: string = '') {
				const attachment: ComposerAttachment = {
					url,
					path,
					mimeType,
					name: name.length > 0 ? name : this.attachmentNameFromPath(path.length > 0 ? path : url),
				}
				const next = new Array<ComposerAttachment>()
				for (let index: Int = 0; index < this.composerAttachments.length; index++) {
					next.push(this.composerAttachments[index])
				}
				next.push(attachment)
				this.composerAttachments = next
				console.log('[vibego-file-drop]', 'composer-attachment-added', 'count=' + this.composerAttachments.length.toString() + ' name=' + attachment.name + ' mime=' + attachment.mimeType)
			},
			clearComposerAttachment(index: number = -1) {
				if (index < 0) {
					this.composerAttachments = new Array<ComposerAttachment>()
					return
				}
				const next = new Array<ComposerAttachment>()
				for (let itemIndex: Int = 0; itemIndex < this.composerAttachments.length; itemIndex++) {
					if (itemIndex != index) next.push(this.composerAttachments[itemIndex])
				}
				this.composerAttachments = next
			},
			onClearComposerAttachment(value: any) {
				if (value instanceof UTSJSONObject) {
					this.clearComposerAttachment(value.getNumber('index') ?? -1)
					return
				}
				this.clearComposerAttachment(value as number)
			},
			hasComposerAttachment(): boolean {
				return this.composerAttachments.length > 0
			},
			attachmentNameFromPath(path: string): string {
				const slash = path.lastIndexOf('/')
				if (slash >= 0 && slash + 1 < path.length) return path.substring(slash + 1)
				return path.length > 0 ? path : '文件'
			},
			composerAttachmentRef(attachment: ComposerAttachment): string {
				if (attachment.path.length > 0) return attachment.path
				return attachment.url
			},
			composerSendText(): string {
				let text = this.prompt.trim()
				const lines = new Array<string>()
				for (let index: Int = 0; index < this.composerAttachments.length; index++) {
					const fileRef = this.composerAttachmentRef(this.composerAttachments[index])
					const line = this.attachmentPathInstruction(fileRef)
					if (line.length > 0) lines.push(line)
				}
				if (lines.length == 0) return text
				const attachmentText = lines.join('\n\n')
				if (text.length == 0) return attachmentText
				return text + '\n\n' + attachmentText
			},
			toggleComposerVoiceRecord() {
				toggleGlobalVoiceFromButton()
				this.globalVoiceActive = isGlobalVoiceActive()
			},
			toggleVoiceRecord() {
				toggleGlobalVoiceFromButton()
				this.globalVoiceActive = isGlobalVoiceActive()
			},
			appendVoiceFinal(text: string) {
				const clean = text.trim()
				if (clean.length == 0) return
				if (clean == this.voiceLastFinalText) return
				this.voiceLastFinalText = clean
				if (this.voiceTarget == 'drop') {
					this.appendDropInstruction(clean)
					return
				}
				this.appendComposerText(clean)
			},
			startVoiceRecord(target: string) {
				if (this.voiceRecording || this.voiceTranscribing) return
				if (!claimVoiceSession(PAGE_VOICE_OWNER)) {
					uni.showToast({ title: '已有录音正在进行', icon: 'none' })
					return
				}
				this.startCloudVoiceRecord(target)
			},
			startCloudVoiceRecord(target: string) {
				requestRecordAudioPermission((granted) => {
					if (!granted) {
						this.resetVoiceUi()
						uni.showToast({ title: '需要麦克风权限才能录音', icon: 'none' })
						return
					}
					const sessionId = Date.now()
					this.voiceTarget = target
					this.voiceSessionMode = 'cloud'
					this.voiceRecording = false
					this.voiceTranscribing = true
					this.voicePreviewText = ''
					this.voiceLastFinalText = ''
					this.voiceRecordPath = ''
					this.voiceSessionId = sessionId
					startVoiceRecording((result) => {
						if (this.voiceSessionId != sessionId) return
						if (!result.ok) {
							this.resetVoiceUi()
							uni.showToast({ title: result.error.length > 0 ? result.error : '启动录音失败', icon: 'none' })
							return
						}
						this.voiceRecordPath = result.path
						this.voiceRecording = true
						this.voiceTranscribing = false
					})
				})
			},
			stopVoiceRecord() {
				if (!this.voiceRecording && !this.voiceTranscribing) return
				this.stopCloudVoiceRecord()
			},
			stopCloudVoiceRecord() {
				const sessionId = this.voiceSessionId
				this.voiceRecording = false
				this.voiceTranscribing = true
				stopVoiceRecording((result) => {
					if (this.voiceSessionId != sessionId) return
					if (!result.ok || result.path.length == 0) {
						const error = result.error.length > 0 ? result.error : '结束录音失败'
						this.resetVoiceUi()
						uni.showToast({ title: error, icon: 'none' })
						return
					}
					this.voiceRecordPath = result.path
					transcribeMobileAudio(result.path, (ok, text, error) => {
						if (this.voiceSessionId != sessionId) return
						if (ok) {
							this.appendVoiceFinal(text)
							this.resetVoiceUi()
							if (text.trim().length == 0) {
								uni.showToast({ title: '未识别到有效语音', icon: 'none' })
							}
							return
						}
						this.resetVoiceUi()
						uni.showToast({ title: error.length > 0 ? error : '语音转写失败', icon: 'none' })
					})
				})
			},
			appendDropInstruction(text: string) {
				if (text.length == 0) return
				const trimmed = this.dropInstruction.trim()
				if (trimmed.length == 0) {
					this.dropInstruction = text
				} else {
					this.dropInstruction = trimmed + '\n' + text
				}
				console.log('[vibego-drop-dialog]', 'instruction-updated length=' + this.dropInstruction.length.toString())
			},
			loadExpandedProjectIds() {
				const raw = uni.getStorageSync(EXPANDED_CODEX_PROJECTS_KEY)
				const ids = new Array<string>()
				if (typeof raw == 'string' && raw.length > 0) {
					try {
						const parsed = JSON.parse(raw) as Array<any>
						for (let index: Int = 0; index < parsed.length; index++) {
							const value = parsed[index]
							if (typeof value == 'string') {
								const id = value as string
								if (id.length > 0) ids.push(id)
							}
						}
					} catch (_) {}
				}
				this.expandedProjectIds = ids
			},
			saveExpandedProjectIds() {
				uni.setStorageSync(EXPANDED_CODEX_PROJECTS_KEY, JSON.stringify(this.expandedProjectIds))
			},
			cachedProject(item: UTSJSONObject): ProjectInfo {
				return {
					id: item.getString('id') ?? '',
					name: item.getString('name') ?? '',
					path: item.getString('path') ?? '',
				}
			},
			readCachedProjects(): Array<ProjectInfo> {
				const readStart = Date.now()
				const raw = uni.getStorageSync(CODEX_PROJECTS_CACHE_KEY)
				const cached = new Array<ProjectInfo>()
				let rawLength = 0
				if (typeof raw == 'string' && raw.length > 0) {
					rawLength = raw.length
					try {
						const parsed = JSON.parse(raw) as Array<any>
						for (let index: Int = 0; index < parsed.length; index++) {
							const project = this.cachedProject(parsed[index] as UTSJSONObject)
							if (project.id.length > 0 && project.name.length > 0) cached.push(project)
						}
					} catch (error) {
						console.log('[vibego-startup-perf]', 'cache:readProjects:parse-failed', 'rawLength=' + rawLength.toString(), error)
					}
				}
				this.logStartupPerfEnd('cache:readProjects', readStart, 'rawLength=' + rawLength.toString() + ' count=' + cached.length.toString())
				return cached
			},
			readCachedThreads(): Array<CodexThread> {
				const readStart = Date.now()
				const raw = uni.getStorageSync(CODEX_THREADS_CACHE_KEY)
				const cached = new Array<CodexThread>()
				let rawLength = 0
				if (typeof raw == 'string' && raw.length > 0) {
					rawLength = raw.length
					try {
						const parsed = JSON.parse(raw) as Array<any>
						for (let index: Int = 0; index < parsed.length; index++) {
							const thread = this.cachedCodexThread(parsed[index] as UTSJSONObject)
							if (thread.id.length > 0) cached.push(thread)
						}
					} catch (error) {
						console.log('[vibego-startup-perf]', 'cache:readThreads:parse-failed', 'rawLength=' + rawLength.toString(), error)
					}
				}
				this.logStartupPerfEnd('cache:readThreads', readStart, 'rawLength=' + rawLength.toString() + ' count=' + cached.length.toString())
				return cached
			},
			saveProjectsCache(projects: Array<ProjectInfo>) {
				const saveStart = Date.now()
				const encoded = JSON.stringify(projects)
				uni.setStorageSync(CODEX_PROJECTS_CACHE_KEY, encoded)
				const saved = this.readCachedProjects()
				this.logStartupPerfEnd('cache:saveProjectsCache', saveStart, 'source=' + projects.length.toString() + ' saved=' + saved.length.toString() + ' encodedLength=' + encoded.length.toString())
			},
			saveThreadsCache() {
				const saveStart = Date.now()
				const encoded = JSON.stringify(this.threads)
				uni.setStorageSync(CODEX_THREADS_CACHE_KEY, encoded)
				const saved = this.readCachedThreads()
				this.logStartupPerfEnd('cache:saveThreadsCache', saveStart, 'source=' + this.threads.length.toString() + ' saved=' + saved.length.toString() + ' encodedLength=' + encoded.length.toString())
			},
			cachedCodexThread(item: UTSJSONObject | null): CodexThread {
				if (item == null) {
					return {
						id: '',
						title: '',
						name: '',
						cwd: '',
						projectId: '',
						projectName: '',
						updatedAt: '',
						lastMessageAt: '',
						preview: '',
						previewRole: '',
						messageCount: 0,
						sessionFile: '',
						runtimeStatus: '',
						runtimeActive: false,
					}
				}
				return {
					id: item.getString('id') ?? '',
					title: item.getString('title') ?? (item.getString('name') ?? ''),
					name: item.getString('name') ?? (item.getString('title') ?? ''),
					cwd: item.getString('cwd') ?? '',
					projectId: item.getString('projectId') ?? '',
					projectName: item.getString('projectName') ?? '',
					updatedAt: item.getString('updatedAt') ?? '',
					lastMessageAt: item.getString('lastMessageAt') ?? '',
					preview: item.getString('preview') ?? '',
					previewRole: item.getString('previewRole') ?? '',
					messageCount: item.getNumber('messageCount') ?? 0,
					sessionFile: item.getString('sessionFile') ?? '',
					runtimeStatus: item.getString('runtimeStatus') ?? '',
					runtimeActive: item.getBoolean('runtimeActive') == true,
				}
			},
			cachedChatMessage(item: UTSJSONObject): ChatMessage {
				return {
					id: item.getString('id') ?? '',
					role: item.getString('role') ?? '',
					label: item.getString('label') ?? '',
					text: item.getString('text') ?? '',
					timestamp: item.getString('timestamp') ?? '',
				}
			},
			cachedProcessEvent(item: UTSJSONObject): CodexProcessEvent {
				return {
					id: item.getString('id') ?? '',
					kind: item.getString('kind') ?? '',
					type: item.getString('type') ?? '',
					text: item.getString('text') ?? '',
					time: item.getString('time') ?? '',
					step: item.getString('step') ?? '',
					callId: item.getString('callId') ?? '',
					name: item.getString('name') ?? '',
					status: item.getString('status') ?? '',
				}
			},
			cachedCursor(item: UTSJSONObject | null): CodexCursor {
				if (item == null) {
					return {
						threadId: '',
						sessionFile: '',
						messageCount: 0,
						processCount: 0,
						fileSize: 0,
						byteOffset: 0,
						updatedAt: '',
						openTurnStartedAt: '',
						openTurnHasAssistantFinal: false,
					}
				}
				return {
					threadId: item.getString('threadId') ?? '',
					sessionFile: item.getString('sessionFile') ?? '',
					messageCount: item.getNumber('messageCount') ?? 0,
					processCount: item.getNumber('processCount') ?? 0,
					fileSize: item.getNumber('fileSize') ?? 0,
					byteOffset: item.getNumber('byteOffset') ?? 0,
					updatedAt: item.getString('updatedAt') ?? '',
					openTurnStartedAt: item.getString('openTurnStartedAt') ?? '',
					openTurnHasAssistantFinal: item.getBoolean('openTurnHasAssistantFinal') == true,
				}
			},
			cachedMessages(item: UTSJSONObject): Array<ChatMessage> {
				const messages = new Array<ChatMessage>()
				const rawMessages = item.getArray('messages') ?? new Array<any>()
				for (let index: Int = 0; index < rawMessages.length; index++) {
					messages.push(this.cachedChatMessage(rawMessages[index] as UTSJSONObject))
				}
				return messages
			},
			cachedProcessEvents(item: UTSJSONObject): Array<CodexProcessEvent> {
				const events = new Array<CodexProcessEvent>()
				const rawEvents = item.getArray('processEvents') ?? new Array<any>()
				for (let index: Int = 0; index < rawEvents.length; index++) {
					events.push(this.cachedProcessEvent(rawEvents[index] as UTSJSONObject))
				}
				return events
			},
			cachedThreadSnapshot(item: UTSJSONObject): CachedThreadSnapshot {
				return {
					threadId: item.getString('threadId') ?? '',
					summary: this.cachedCodexThread(item.getJSON('summary') as UTSJSONObject | null),
					messages: this.cachedMessages(item),
					processEvents: this.cachedProcessEvents(item),
					cursor: this.cachedCursor(item.getJSON('cursor') as UTSJSONObject | null),
					active: item.getBoolean('active') == true,
					cachedAt: item.getNumber('cachedAt') ?? 0,
				}
			},
			readCachedThreadSnapshots(): Array<CachedThreadSnapshot> {
				const cacheStart = Date.now()
				const raw = uni.getStorageSync(CODEX_THREAD_SNAPSHOT_CACHE_KEY)
				const cached = new Array<CachedThreadSnapshot>()
				let rawLength = 0
				if (typeof raw == 'string' && raw.length > 0) {
					rawLength = raw.length
					try {
						const parsed = JSON.parse(raw) as Array<any>
						for (let index: Int = 0; index < parsed.length; index++) {
							const snapshot = this.cachedThreadSnapshot(parsed[index] as UTSJSONObject)
							if (snapshot.threadId.length > 0) cached.push(snapshot)
						}
					} catch (error) {
						console.log('[vibego-startup-perf]', 'cache:readThreadSnapshots:parse-failed', 'rawLength=' + rawLength.toString(), error)
					}
				}
				this.logStartupPerfEnd('cache:readThreadSnapshots', cacheStart, 'rawLength=' + rawLength.toString() + ' count=' + cached.length.toString())
				return cached
			},
			writeCachedThreadSnapshots(snapshots: Array<CachedThreadSnapshot>) {
				const writeStart = Date.now()
				try {
					const encoded = JSON.stringify(snapshots)
					uni.setStorageSync(CODEX_THREAD_SNAPSHOT_CACHE_KEY, encoded)
					const saved = uni.getStorageSync(CODEX_THREAD_SNAPSHOT_CACHE_KEY)
					let savedLength = 0
					if (typeof saved == 'string') savedLength = saved.length
					this.logStartupPerfEnd('cache:writeThreadSnapshots', writeStart, 'count=' + snapshots.length.toString() + ' encodedLength=' + encoded.length.toString() + ' savedLength=' + savedLength.toString())
				} catch (error) {
					this.logStartupPerfEnd('cache:writeThreadSnapshots:failed', writeStart, 'count=' + snapshots.length.toString())
					console.log('[vibego-startup-perf]', 'cache:writeThreadSnapshots:error', error)
				}
			},
			saveActiveThreadSnapshotCache() {
				const cacheStart = Date.now()
				if (this.activeThreadId.length == 0) return
				const summary = this.findThreadById(this.activeThreadId)
				if (summary == null) return
				const snapshot: CachedThreadSnapshot = {
					threadId: this.activeThreadId,
					summary,
					messages: this.messages,
					processEvents: this.processEvents,
					cursor: this.currentCursor(),
					active: this.codexRunning,
					cachedAt: Date.now(),
				}
				const existing = this.readCachedThreadSnapshots()
				const next = new Array<CachedThreadSnapshot>()
				next.push(snapshot)
				for (let index: Int = 0; index < existing.length; index++) {
					if (existing[index].threadId != snapshot.threadId) next.push(existing[index])
				}
				this.writeCachedThreadSnapshots(next)
				this.activeThreadSnapshotCachedAt = snapshot.cachedAt
				this.activeThreadSnapshotStale = false
				this.logStartupPerfEnd('cache:saveActiveSnapshot', cacheStart, 'thread=' + this.activeThreadId + ' messages=' + snapshot.messages.length.toString() + ' processes=' + snapshot.processEvents.length.toString())
			},
			scheduleActiveThreadSnapshotCache(delayMs: number = 600) {
				if (this.activeThreadSnapshotCacheTimer != 0) clearTimeout(this.activeThreadSnapshotCacheTimer)
				this.activeThreadSnapshotCacheTimer = setTimeout(() => {
					this.activeThreadSnapshotCacheTimer = 0
					this.saveActiveThreadSnapshotCache()
				}, delayMs)
			},
			restoreCachedThreadSnapshot(threadId: string): boolean {
				const restoreStart = Date.now()
				if (threadId.length == 0) return false
				const cached = this.readCachedThreadSnapshots()
				for (let index: Int = 0; index < cached.length; index++) {
					const snapshot = cached[index]
					if (snapshot.threadId != threadId) continue
					const summary = this.normalizeAssistantThreadSummary(snapshot.summary)
					this.applyThreadSummary(summary)
					this.upsertThreadSummary(summary, false)
					this.messages = snapshot.messages
					this.visibleMessageCount = this.messageViewStep.toInt()
					this.clearMessageViewCache()
					this.rebuildMessageViews()
					this.processEvents = snapshot.processEvents
					this.applyCursor(snapshot.cursor)
					this.codexRunning = snapshot.active
					this.threadLoading = false
					this.activeThreadSnapshotStale = false
					this.activeThreadSnapshotCachedAt = snapshot.cachedAt
					this.scheduleChatBottom()
					if (snapshot.active) this.startUpdatesPolling(snapshot.threadId)
					this.logStartupPerfEnd('cache:restoreThreadSnapshot:hit', restoreStart, 'thread=' + threadId + ' messages=' + this.messages.length.toString() + ' cachedAge=' + (Date.now() - snapshot.cachedAt).toString() + 'ms')
					return true
				}
				this.logStartupPerfEnd('cache:restoreThreadSnapshot:miss', restoreStart, 'thread=' + threadId)
				return false
			},
			restoreProjectAndThreadCache() {
				const restoreStart = Date.now()
				const cachedProjects = this.readCachedProjects()
				const cachedThreads = this.readCachedThreads()
				if (cachedProjects.length > 0) {
					this.projects = cachedProjects
					this.syncActiveProjectPath()
				}
				if (cachedThreads.length > 0) {
					for (let index: Int = 0; index < cachedThreads.length; index++) {
						this.normalizeAssistantThreadSummary(cachedThreads[index])
					}
					this.threads = cachedThreads
					this.sortThreads()
					this.rebuildProjectGroups()
					if (this.activeRailMode != 'assistant') {
						const activeThread = this.findThreadById(this.activeThreadId)
						if (activeThread != null) this.applyThreadSummary(activeThread)
					}
				}
				if (cachedProjects.length > 0 || cachedThreads.length > 0) this.projectThreadRefreshAt = Date.now()
				this.logStartupPerfEnd('cache:restoreProjectAndThreadCache:done', restoreStart, 'projects=' + cachedProjects.length.toString() + ' threads=' + cachedThreads.length.toString() + ' groups=' + this.projectGroups.length.toString())
			},
		refreshProjectAndThreadLists(force: boolean) {
			const now = Date.now()
			if (!force && this.projectThreadRefreshAt > 0 && now - this.projectThreadRefreshAt < LIST_REFRESH_MIN_INTERVAL_MS) {
				this.logStartupPerf('listRefresh:skip-cache-window', 'age=' + (now - this.projectThreadRefreshAt).toString() + 'ms')
				return
			}
			this.projectThreadRefreshAt = now
			this.logStartupPerf('listRefresh:start', 'force=' + (force ? '1' : '0'))
			this.loadProjects(force)
			this.loadThreads(force)
		},
			isProjectExpanded(projectId: string): boolean {
				for (let index: Int = 0; index < this.expandedProjectIds.length; index++) {
					if (this.expandedProjectIds[index] == projectId) return true
				}
				return false
			},
			isProjectCollapsed(projectId: string): boolean {
				return !this.isProjectExpanded(projectId)
			},
			selectedProjectId(): string {
				if (this.activeRailMode == 'assistant' || this.activeRailMode == 'settings') return ''
				const activeThread = this.findThreadById(this.activeThreadId)
				if (activeThread != null) {
					const projectId = activeThread.projectId
					if (projectId.length > 0 && projectId != CODEX_DIRECT_PROJECT_ID) return projectId
					return ''
				}
				return this.activeProjectId
			},
				isProjectActive(projectId: string): boolean {
					if (projectId.length == 0) return false
					return this.isProjectExpanded(projectId)
				},
			isThreadActive(threadId: string): boolean {
				if (threadId.length == 0) return false
				return this.activeThreadId == threadId
			},
			projectTitleStateClass(group: ProjectThreadGroup): string {
				if (group.kind == 'conversation') return ''
				const classes = new Array<string>()
				if (this.isProjectActive(group.project.id)) classes.push('project-title-active')
				return classes.join(' ')
			},
			toggleProjectGroup(index: number) {
				const groupIndex = index.toInt()
				if (groupIndex < 0 || groupIndex >= this.projectGroups.length) return
				if (this.projectGroups[groupIndex].kind == 'conversation') return
				const projectId = this.projectGroups[groupIndex].project.id
				if (this.isProjectExpanded(projectId)) {
					const next = new Array<string>()
					for (let i: Int = 0; i < this.expandedProjectIds.length; i++) {
						if (this.expandedProjectIds[i] != projectId) next.push(this.expandedProjectIds[i])
					}
					this.expandedProjectIds = next
				} else {
					this.expandedProjectIds.push(projectId)
				}
				this.saveExpandedProjectIds()
				this.rebuildProjectGroups()
				this.requestThreadListScrollToProject(projectId)
			},
			requestThreadListScrollToProject(projectId: string) {
				if (projectId.length == 0 || projectId == CODEX_DIRECT_PROJECT_ID) return
				this.threadListScrollTargetTop = this.threadListProjectScrollTop(projectId)
				this.threadListScrollRequestKey = this.threadListScrollRequestKey + 1
			},
			threadListProjectScrollTop(projectId: string): number {
				let offset = 18
				for (let index: Int = 0; index < this.projectGroups.length; index++) {
					const group = this.projectGroups[index]
					if (group.kind != 'conversation' && group.project.id == projectId) {
						return offset > 18 ? offset : 0
					}
					offset = offset + this.threadListGroupHeight(group)
				}
				return 0
			},
			threadListGroupHeight(group: ProjectThreadGroup): number {
				if (group.kind == 'conversation') {
					return 44 + group.threads.length * 40 + 18
				}
				let height = 60 + 18
				if (!group.collapsed) height = height + 2 + group.threads.length * 40
				return height
			},
			loadProjects(forceSync: boolean = false) {
				this.projectListRequestSeq = this.projectListRequestSeq + 1
				const requestSeq = this.projectListRequestSeq
				const requestStart = Date.now()
				this.logStartupPerf('projects:start', 'forceSync=' + (forceSync ? '1' : '0') + ' seq=' + requestSeq.toString())
				const done = (ok: boolean, projects: Array<ProjectInfo>, error: string) => {
					if (requestSeq != this.projectListRequestSeq) {
						this.logStartupPerfEnd('projects:stale-response', requestStart, 'seq=' + requestSeq.toString())
						return
					}
					this.logStartupPerfEnd('projects:end', requestStart, 'ok=' + (ok ? '1' : '0') + ' count=' + projects.length.toString() + ' error=' + error)
					if (!ok) {
					this.statusText = error
					return
					}
					this.projects = projects
					if (forceSync) {
						this.saveProjectsCache(projects)
						uni.showToast({ title: '已缓存项目 ' + projects.length.toString() + ' 个', icon: 'none' })
					}
					this.syncActiveProjectPath()
					this.rebuildProjectGroups()
					if (this.activeProjectPath.length > 0) this.reloadTree()
				}
				if (forceSync) apiProjectsWithSync(true, done)
				else apiProjects(done)
			},
		applyProject(index: Int, keepThread: boolean) {
			if (index < 0 || index >= this.projects.length) return
			const project = this.projects[index]
			this.activeProjectId = project.id
			this.activeProjectPath = project.path
			setActiveProjectId(project.id)
			if (!keepThread) {
				this.clearActiveThread()
			}
			this.selectedPath = ''
			this.fileText = ''
			this.originalText = ''
				this.loadThreads()
				this.reloadTree()
			},
			applyProjectInfo(project: ProjectInfo, keepThread: boolean) {
				this.activeProjectId = project.id
				this.activeProjectPath = project.path
				setActiveProjectId(project.id)
				if (!keepThread) {
					this.clearActiveThread()
				}
				this.selectedPath = ''
				this.fileText = ''
				this.originalText = ''
				this.reloadTree()
			},
		threadSortScore(thread: CodexThread): number {
			const stamp = thread.lastMessageAt.length > 0 ? thread.lastMessageAt : thread.updatedAt
			const score = Date.parse(stamp)
			return score > 0 ? score : 0
		},
		sortThreads() {
			for (let i: Int = 0; i < this.threads.length; i++) {
				for (let j: Int = i + 1; j < this.threads.length; j++) {
					if (this.threadSortScore(this.threads[j]) > this.threadSortScore(this.threads[i])) {
						const current = this.threads[i]
						this.threads[i] = this.threads[j]
						this.threads[j] = current
					}
				}
			}
		},
		threadSummarySignature(thread: CodexThread): string {
			return thread.id + '|' + thread.title + '|' + thread.projectId + '|' + thread.projectName + '|' + thread.cwd + '|' + thread.updatedAt + '|' + thread.lastMessageAt + '|' + thread.messageCount.toString() + '|' + thread.sessionFile + '|' + thread.runtimeStatus + '|' + (thread.runtimeActive ? '1' : '0') + '|' + thread.preview + '|' + thread.previewRole
		},
		upsertThreadSummary(summary: CodexThread, shouldPersistCache: boolean = false): boolean {
			if (summary.id.length == 0) return false
			let found = false
			for (let index: Int = 0; index < this.threads.length; index++) {
				if (this.threads[index].id == summary.id) {
					if (this.threadSummarySignature(this.threads[index]) == this.threadSummarySignature(summary)) return false
					this.threads[index] = summary
					found = true
					break
				}
			}
			if (!found) this.threads.push(summary)
			this.sortThreads()
			this.rebuildProjectGroups()
			if (shouldPersistCache) this.saveThreadsCache()
			return true
		},
		applyThreadSummary(summary: CodexThread) {
			if (summary.id.length == 0) return
				const normalized = this.normalizeAssistantThreadSummary(summary)
				this.activeThreadId = summary.id
				this.mainTitle = normalized.title
				setActiveThreadId(summary.id)
				if (this.isAssistantThread(normalized.id)) {
					this.setContentRailMode('assistant')
					this.activeProjectId = ''
					this.activeProjectPath = ''
					setActiveProjectId('')
					return
				}
				this.setContentRailMode('conversation')
				if (normalized.projectId.length > 0) {
					this.activeProjectId = normalized.projectId
					setActiveProjectId(normalized.projectId)
				this.syncActiveProjectPath()
			}
		},
		loadThreads(forceSync: boolean = false) {
			this.threadListRequestSeq = this.threadListRequestSeq + 1
			const requestSeq = this.threadListRequestSeq
			const requestStart = Date.now()
			this.logStartupPerf('threads:start', 'forceSync=' + (forceSync ? '1' : '0') + ' seq=' + requestSeq.toString())
			const done = (ok: boolean, threads: Array<CodexThread>, error: string) => {
				if (requestSeq != this.threadListRequestSeq) {
					this.logStartupPerfEnd('threads:stale-response', requestStart, 'seq=' + requestSeq.toString())
					return
				}
				this.logStartupPerfEnd('threads:end', requestStart, 'ok=' + (ok ? '1' : '0') + ' count=' + threads.length.toString() + ' error=' + error)
				if (!ok) {
					this.statusText = error
					return
				}
				let assistantNeedsRepair = false
				for (let index: Int = 0; index < threads.length; index++) {
					const thread = threads[index]
					if (this.isAssistantThread(thread.id) && (thread.projectId != CODEX_DIRECT_PROJECT_ID || thread.cwd.length > 0)) {
						assistantNeedsRepair = true
					}
					this.normalizeAssistantThreadSummary(thread)
				}
				this.threads = threads
				this.sortThreads()
				this.rebuildProjectGroups()
				if (forceSync) {
					this.saveThreadsCache()
					uni.showToast({ title: '已缓存会话 ' + this.threads.length.toString() + ' 条', icon: 'none' })
				}
				if (assistantNeedsRepair) this.repairAssistantThreadScope(this.assistantThreadId)
				if (this.conversationOpenPending) {
					this.conversationOpenPending = false
					if (this.selectRecentNormalThread()) return
					if (this.isAssistantThread(this.activeThreadId)) this.clearActiveThread()
					return
				}
				const activeThread = this.findThreadById(this.activeThreadId)
				if (activeThread != null) {
					this.applyThreadSummary(activeThread)
					if (this.messages.length == 0 && this.processEvents.length == 0) {
						if (!this.restoreCachedThreadSnapshot(activeThread.id)) this.loadThreadSnapshot(activeThread.id, activeThread.runtimeActive)
					}
					return
				}
				if (this.activeThreadId.length > 0) this.clearActiveThread()
				this.ensureDefaultChatThread('threads_loaded')
			}
			if (forceSync) apiCodexThreadsWithSync('', true, done)
			else apiCodexThreads('', done)
		},
		findThreadById(threadId: string): CodexThread | null {
			if (threadId.length == 0) return null
			for (let index: Int = 0; index < this.threads.length; index++) {
				if (this.threads[index].id == threadId) return this.threads[index]
			}
			return null
		},
		findRecentNormalThread(): CodexThread | null {
			const recentId = this.recentDropThreadId()
			if (recentId.length > 0) {
				const recent = this.findThreadById(recentId)
				if (recent != null && !this.isAssistantThread(recent.id)) return recent
			}
			for (let index: Int = 0; index < this.threads.length; index++) {
				const thread = this.threads[index]
				if (!this.isAssistantThread(thread.id)) return thread
			}
			return null
		},
		selectRecentNormalThread(): boolean {
			const thread = this.findRecentNormalThread()
			if (thread == null) return false
			this.selectThreadById(thread.id)
			return true
		},
		ensureDefaultChatThread(reason: string): boolean {
			if (this.rightMode != 'chat') return false
			if (this.activeThreadId.length > 0) return true
			if (this.selectRecentNormalThread()) {
				console.log('[vibego-startup]', 'default-thread-selected', reason)
				return true
			}
			if (this.hasAssistantBinding()) {
				console.log('[vibego-startup]', 'default-assistant-selected', reason)
				this.openAssistantOnLaunch()
				return true
			}
			if (this.threads.length > 0) {
				console.log('[vibego-startup]', 'fallback-first-thread-selected', reason)
				this.selectThreadById(this.threads[0].id)
				return true
			}
			return false
		},
			syncActiveProjectPath() {
				this.activeProjectPath = ''
				for (let index: Int = 0; index < this.projects.length; index++) {
					if (this.projects[index].id == this.activeProjectId) {
						this.activeProjectPath = this.projects[index].path
						return
					}
				}
				for (let groupIndex: Int = 0; groupIndex < this.projectGroups.length; groupIndex++) {
					const project = this.projectGroups[groupIndex].project
					if (project.id == this.activeProjectId) {
						this.activeProjectPath = project.path
						return
					}
				}
			},
			clearActiveThread() {
				this.stopPolling()
				this.activeThreadId = ''
				this.mainTitle = ''
				this.setContentRailMode('conversation')
				this.messages = new Array<ChatMessage>()
			this.resetMessageViews()
			this.processEvents = new Array<CodexProcessEvent>()
			this.codexRunning = false
			setActiveThreadId('')
			this.clearCursor()
			this.clearWatch()
		},
			rebuildProjectGroups() {
				const groups = new Array<ProjectThreadGroup>()
				const conversationThreads = new Array<CodexThread>()
				for (let threadIndex: Int = 0; threadIndex < this.threads.length; threadIndex++) {
					const thread = this.threads[threadIndex]
					const projectId = thread.projectId.length > 0 ? thread.projectId : CODEX_DIRECT_PROJECT_ID
					if (projectId == CODEX_DIRECT_PROJECT_ID) {
						conversationThreads.push(thread)
						continue
					}
					let groupIndex: Int = -1
					for (let index: Int = 0; index < groups.length; index++) {
						if (groups[index].project.id == projectId) {
							groupIndex = index
							break
						}
					}
					if (groupIndex < 0) {
						const project: ProjectInfo = {
							id: projectId,
							name: thread.projectName.length > 0 ? thread.projectName : (thread.cwd.length > 0 ? this.baseName(thread.cwd) : '对话'),
							path: thread.cwd,
						}
						const projectThreads = new Array<CodexThread>()
						projectThreads.push(thread)
						groups.push({ project, threads: projectThreads, collapsed: this.isProjectCollapsed(project.id), kind: 'project' })
					} else {
						groups[groupIndex].threads.push(thread)
					}
				}
				for (let projectIndex: Int = 0; projectIndex < this.projects.length; projectIndex++) {
					const project = this.projects[projectIndex]
					if (project.id.length == 0 || project.id == CODEX_DIRECT_PROJECT_ID) continue
					let exists = false
					for (let groupIndex: Int = 0; groupIndex < groups.length; groupIndex++) {
						if (groups[groupIndex].project.id == project.id) {
							exists = true
							break
						}
					}
				if (!exists) groups.push({ project, threads: new Array<CodexThread>(), collapsed: this.isProjectCollapsed(project.id), kind: 'project' })
				}
				if (conversationThreads.length > 0) {
					const conversationProject: ProjectInfo = {
						id: CODEX_DIRECT_PROJECT_ID,
						name: '对话',
						path: '',
					}
					groups.push({ project: conversationProject, threads: conversationThreads, collapsed: false, kind: 'conversation' })
					}
					this.projectGroups = groups
				},
		selectThreadById(threadId: string) {
			for (let index: Int = 0; index < this.threads.length; index++) {
				if (this.threads[index].id == threadId) {
					const thread = this.threads[index]
					this.triggerThreadSwitchMotion()
					this.stopPolling()
					this.clearWatch()
					this.clearCursor()
					this.threadLoading = true
					this.messages = new Array<ChatMessage>()
					this.resetMessageViews()
					this.processEvents = new Array<CodexProcessEvent>()
					this.applyThreadSummary(thread)
					this.rememberRecentNormalThread(thread.id)
					this.showChat()
					if (!this.restoreCachedThreadSnapshot(thread.id)) this.loadThreadSnapshot(thread.id, thread.runtimeActive)
					return
				}
			}
		},
		selectThreadByIdFromCompactDrawer(threadId: string) {
			this.closeCompactDrawer()
			this.selectThreadById(threadId)
		},
		loadHistory(threadId: string) {
			this.loadThreadSnapshot(threadId, false)
		},
		resumeThreadIfRunning(threadId: string) {
			if (threadId.length == 0) return
			for (let index: Int = 0; index < this.threads.length; index++) {
				const thread = this.threads[index]
				if (thread.id == threadId && thread.runtimeActive) {
					this.startUpdatesPolling(threadId)
					break
				}
			}
		},
			startProjectThread(project: ProjectInfo) {
				this.triggerThreadSwitchMotion()
				this.stopPolling()
				this.clearWatch()
				this.clearCursor()
				this.setContentRailMode('conversation')
				this.activeProjectId = project.id
				this.activeProjectPath = project.path
			setActiveProjectId(project.id)
			this.activeThreadId = ''
			setActiveThreadId('')
			this.messages = new Array<ChatMessage>()
			this.resetMessageViews()
			this.processEvents = new Array<CodexProcessEvent>()
			this.codexRunning = false
			this.mainTitle = ''
			this.setPromptForActiveComposer('')
			this.clearComposerAttachment()
			this.showChat()
			this.scheduleChatBottom()
			this.prepareCodexNewThread('project', project.id)
		},
		startProjectThreadFromCompactDrawer(project: ProjectInfo) {
			this.closeCompactDrawer()
			this.startProjectThread(project)
		},
			newThread() {
				this.triggerThreadSwitchMotion()
				this.stopPolling()
				this.clearWatch()
				this.clearCursor()
				this.setContentRailMode('conversation')
				this.activeProjectId = ''
				this.activeProjectPath = ''
			setActiveProjectId('')
			this.activeThreadId = ''
			setActiveThreadId('')
			this.messages = new Array<ChatMessage>()
			this.resetMessageViews()
			this.processEvents = new Array<CodexProcessEvent>()
			this.selectedPath = ''
			this.fileText = ''
			this.originalText = ''
			this.dirty = false
			this.codexRunning = false
			this.mainTitle = ''
			this.setPromptForActiveComposer('')
			this.clearComposerAttachment()
			this.showChat()
				this.scheduleChatBottom()
				this.prepareCodexNewThread('direct', '')
			},
		prepareCodexNewThread(scope: string, projectId: string) {
			const clientRequestId = Date.now().toString() + '-new-thread-' + Math.floor(Math.random() * 100000).toString()
			apiCodexCreateThread(scope, projectId, clientRequestId, (ok: boolean, result: CodexCreateThreadResult, error: string) => {
				if (ok) {
					this.statusText = result.scope == 'project' ? '项目新会话已准备' : '新会话已准备'
					return
				}
				this.statusText = error
				uni.showToast({ title: error, icon: 'none' })
			})
		},
		newThreadFromCompactDrawer() {
			this.closeCompactDrawer()
			this.newThread()
		},
			activateSearch() {
				this.settingsOpen = false
				this.setContentRailMode('search')
			},
			canSendPrompt(): boolean {
			return this.prompt.trim().length > 0 || this.hasComposerAttachment()
		},
			sendIconSrc(): string {
			if (this.canSendPrompt()) return '/static/icons/send.svg'
			return this.isNightTheme() ? '/static/icons/send-disabled-night.svg' : '/static/icons/send-disabled.svg'
		},
		uploadIconSrc(): string {
			return this.isNightTheme() ? '/static/icons/plus-night.svg' : '/static/icons/plus.svg'
		},
		settingsCloseIconSrc(): string {
			return this.isNightTheme() ? '/static/icons/annotate-close-night.svg' : '/static/icons/annotate-close.svg'
		},
		shouldQueueAssistantPrompt(): boolean {
			return this.activeRailMode == 'assistant' && (!this.hasAssistantBinding() || this.assistantInitializing || this.pendingAssistantPromptWaiting)
		},
		queueAssistantPrompt(text: string) {
			const clean = text.trim()
			if (clean.length == 0) return
			if (this.pendingAssistantPrompt.length > 0) {
				this.pendingAssistantPrompt = this.pendingAssistantPrompt + '\n' + clean
			} else {
				this.pendingAssistantPrompt = clean
			}
			this.pendingAssistantPromptWaiting = true
				this.setWorkspaceState('assistant', 'chat')
				this.setPromptForActiveComposer('')
				this.clearComposerAttachment()
				this.showChat()
				this.processEvents = new Array<CodexProcessEvent>()
				this.pushLocalProcessEvent('send_step', '正在创建助手，完成后自动发送你的消息…', 'assistant_wait_user_message')
			this.codexRunning = true
			this.scheduleChatBottom()
					if (!this.assistantInitializing && !this.hasAssistantBinding()) this.createAssistantInMode(true)
					this.tryFlushPendingAssistantPrompt()
			},
		canFlushPendingAssistantPrompt(): boolean {
			if (this.pendingAssistantPrompt.length == 0) return false
			if (!this.hasAssistantBinding()) return false
			if (this.assistantInitializing) return false
			if (this.codexRunning) return false
			return true
		},
		tryFlushPendingAssistantPrompt() {
			if (!this.canFlushPendingAssistantPrompt()) return
			const text = this.pendingAssistantPrompt
			this.pendingAssistantPrompt = ''
			this.pendingAssistantPromptWaiting = false
			this.setWorkspaceState('assistant', 'chat')
			this.activeThreadId = this.assistantThreadId
			setActiveThreadId(this.assistantThreadId)
			this.activeProjectId = ''
			this.activeProjectPath = ''
			setActiveProjectId('')
			this.mainTitle = this.assistantThreadTitle()
			this.sendPromptText(text)
		},
		newThreadScopeForSend(): string {
			if (this.activeThreadId.length > 0) return ''
			if (this.activeProjectId.length > 0 && this.activeProjectId != CODEX_DIRECT_PROJECT_ID) return 'project'
			return 'direct'
		},
		attachmentPathInstruction(path: string): string {
			if (path.length == 0) return ''
			return '附件文件路径（仅用于读取本次上传/截图素材，不代表项目根目录）：' + path + '\n请以当前 Codex 会话的工作目录作为项目根目录；不要因为附件路径位于 VibeGo/server/uploads 而切换项目。'
		},
		projectIdForActiveSend(): string {
			if (this.activeThreadId.length > 0) {
				const thread = this.findThreadById(this.activeThreadId)
				if (thread != null) {
					if (this.isAssistantThread(thread.id)) return ''
					if (thread.projectId.length > 0 && thread.projectId != CODEX_DIRECT_PROJECT_ID) return thread.projectId
					return ''
				}
			}
			return this.activeProjectId
		},
		appendProcessEvent(event: CodexProcessEvent): boolean {
			for (let index: Int = 0; index < this.processEvents.length; index++) {
				if (this.processEvents[index].id == event.id) return false
			}
			this.processEvents.push(event)
			return true
		},
		appendProcessEvents(events: Array<CodexProcessEvent>, shouldScheduleScroll: boolean = true): boolean {
			if (events.length == 0) return false
			let changed = false
			for (let index: Int = 0; index < events.length; index++) {
				if (this.appendProcessEvent(events[index])) changed = true
				}
				if (!changed) return false
				if (changed && shouldScheduleScroll) this.scheduleChatBottom()
				return changed
			},
		recentProcessEvents(events: Array<CodexProcessEvent>): Array<CodexProcessEvent> {
			const limit: Int = 80
			if (events.length <= limit) return events
			const recent = new Array<CodexProcessEvent>()
			const start: Int = (events.length - limit).toInt()
			for (let index: Int = start; index < events.length; index++) {
				recent.push(events[index])
			}
			return recent
		},
		replacementLocalMessageIndex(message: ChatMessage): Int {
			if (message.role != 'user' || message.text.length == 0) return -1
			let start: Int = 0
			if (this.messages.length > 12) start = (this.messages.length - 12).toInt()
			for (let index: Int = (this.messages.length - 1).toInt(); index >= start; index--) {
				const current = this.messages[index]
				if (current.id.startsWith('local-user-') && current.role == message.role && current.text == message.text) return index
			}
			return -1
		},
		appendMessages(messages: Array<ChatMessage>, shouldScheduleScroll: boolean = true): boolean {
			if (messages.length == 0) return false
			let changed = false
			for (let index: Int = 0; index < messages.length; index++) {
				const message = messages[index]
				let exists = false
				for (let currentIndex: Int = (this.messages.length - 1).toInt(); currentIndex >= 0; currentIndex--) {
					const current = this.messages[currentIndex]
					if (message.id.length > 0 && current.id == message.id) {
						exists = true
						break
					}
					if (current.id.length == 0 && current.role == message.role && current.text == message.text && current.timestamp == message.timestamp) {
						exists = true
						break
					}
				}
				if (!exists) {
					const replaceIndex = this.replacementLocalMessageIndex(message)
					if (replaceIndex >= 0) {
						const oldMessageId = this.messages[replaceIndex].id
						this.removeMessageViewCache(oldMessageId)
						this.messages[replaceIndex] = message
						this.replaceMessageView(oldMessageId, message)
					} else {
						this.messages.push(message)
						this.appendMessageView(message)
					}
					changed = true
				}
			}
				if (changed && shouldScheduleScroll) {
					const latestAssistantId = this.latestAssistantMessageId(messages)
					if (latestAssistantId.length > 0) this.scheduleChatMessageTop(latestAssistantId)
					else this.scheduleChatBottom()
				}
				return changed
			},
			pushLocalProcessEvent(kind: string, text: string, step: string) {
				const stamp = new Date().toISOString()
				this.appendProcessEvent({
					id: 'local-' + stamp + '-' + kind,
					kind,
					type: kind,
					text,
				time: stamp,
				step,
				callId: '',
				name: '',
				status: '',
			})
		},
		applyStatusEvents(events: Array<CodexEvent>) {
			const mapped = new Array<CodexProcessEvent>()
			for (let index: Int = 0; index < events.length; index++) {
				const item = events[index]
				mapped.push({
					id: 'status-' + item.kind + '-' + item.time + '-' + index.toString(),
					kind: item.kind,
					type: item.type,
					text: item.text,
					time: item.time,
					step: item.step,
					callId: '',
					name: '',
					status: '',
				})
			}
			this.appendProcessEvents(mapped)
		},
		currentCursor(): CodexCursor {
			return {
				threadId: this.cursorThreadId,
				sessionFile: this.cursorSessionFile,
				messageCount: this.cursorMessageCount,
				processCount: this.cursorProcessCount,
				fileSize: this.cursorFileSize,
				byteOffset: this.cursorByteOffset,
				updatedAt: '',
				openTurnStartedAt: this.cursorOpenTurnStartedAt,
				openTurnHasAssistantFinal: this.cursorOpenTurnHasAssistantFinal,
			}
		},
		applyCursor(cursor: CodexCursor) {
			this.cursorThreadId = cursor.threadId
			this.cursorSessionFile = cursor.sessionFile
			this.cursorMessageCount = cursor.messageCount
			this.cursorProcessCount = cursor.processCount
			this.cursorFileSize = cursor.fileSize
			this.cursorByteOffset = cursor.byteOffset
			this.cursorOpenTurnStartedAt = cursor.openTurnStartedAt
			this.cursorOpenTurnHasAssistantFinal = cursor.openTurnHasAssistantFinal
		},
		clearCursor() {
			this.cursorThreadId = ''
			this.cursorSessionFile = ''
			this.cursorMessageCount = 0
			this.cursorProcessCount = 0
			this.cursorFileSize = 0
			this.cursorByteOffset = 0
			this.cursorOpenTurnStartedAt = ''
			this.cursorOpenTurnHasAssistantFinal = false
		},
		loadThreadSnapshot(threadId: string, startLive: boolean) {
			if (threadId.length == 0) return
			if (this.snapshotLoadingThreadId == threadId) {
				this.logStartupPerf('snapshot:skip-duplicate', 'thread=' + threadId + ' runningFor=' + (Date.now() - this.snapshotLoadingStartedAt).toString() + 'ms startLive=' + (startLive ? '1' : '0'))
				return
			}
			const requestThreadId = threadId
			const requestStart = Date.now()
			this.snapshotLoadingThreadId = threadId
			this.snapshotLoadingStartedAt = requestStart
			const hasVisibleSnapshot = this.messages.length > 0 || this.processEvents.length > 0
			if (hasVisibleSnapshot) this.activeThreadSnapshotStale = true
			else this.threadLoading = true
			this.logStartupPerf('snapshot:start', 'thread=' + threadId + ' startLive=' + (startLive ? '1' : '0') + ' hasVisible=' + (hasVisibleSnapshot ? '1' : '0'))
			apiCodexThreadSnapshotWithProcessLimit(threadId, -1, (ok, snapshot, error) => {
				if (this.activeThreadId.length > 0 && this.activeThreadId != requestThreadId) {
					if (this.snapshotLoadingThreadId == requestThreadId) {
						this.snapshotLoadingThreadId = ''
						this.snapshotLoadingStartedAt = 0
					}
					this.logStartupPerfEnd('snapshot:stale-response', requestStart, 'requestThread=' + requestThreadId + ' activeThread=' + this.activeThreadId)
					return
				}
				if (this.snapshotLoadingThreadId == requestThreadId) {
					this.snapshotLoadingThreadId = ''
					this.snapshotLoadingStartedAt = 0
				}
				this.threadLoading = false
				this.activeThreadSnapshotStale = false
				this.logStartupPerfEnd('snapshot:end', requestStart, 'ok=' + (ok ? '1' : '0') + ' available=' + (snapshot.available ? '1' : '0') + ' messages=' + snapshot.messages.length.toString() + ' processes=' + snapshot.processEvents.length.toString() + ' error=' + error)
				if (!ok || !snapshot.available) {
					this.statusText = error.length > 0 ? error : snapshot.error
					return
				}
				const summary = this.normalizeAssistantThreadSummary(snapshot.summary)
				this.applyThreadSummary(summary)
				this.upsertThreadSummary(summary, false)
				this.messages = snapshot.messages
				this.visibleMessageCount = this.messageViewStep.toInt()
				this.clearMessageViewCache()
				this.rebuildMessageViews()
				this.processEvents = snapshot.processEvents
				this.applyCursor(snapshot.cursor)
				this.codexRunning = snapshot.active
					this.tryFlushPendingAssistantPrompt()
					const latestAssistantId = this.latestAssistantMessageId(snapshot.messages)
					if (startLive && !snapshot.active && latestAssistantId.length > 0) this.scheduleChatMessageTop(latestAssistantId)
					else this.scheduleChatBottom()
				this.saveActiveThreadSnapshotCache()
				if (startLive || snapshot.active) this.startUpdatesPolling(snapshot.threadId)
				else if (this.pollMode == 'updates') this.stopPolling()
			})
		},
			sendPrompt() {
				const text = this.composerSendText()
				if (text.length == 0) return
				if (this.shouldQueueAssistantPrompt()) {
					this.queueAssistantPrompt(text)
					return
				}
				this.sendPromptText(text)
			},
			sendPromptText(text: string) {
				if (text.length == 0) return
					const sentAt = new Date().toISOString()
					const localMessage: ChatMessage = { id: 'local-user-' + sentAt, role: 'user', label: 'You', text, timestamp: sentAt }
					this.processEvents = new Array<CodexProcessEvent>()
					this.messages.push(localMessage)
					this.appendMessageView(localMessage)
					this.triggerSendPulse()
				this.pushLocalProcessEvent('send_step', '正在送达 Codex…', 'prepare')
				this.codexRunning = true
				this.setPromptForActiveComposer('')
				this.clearComposerAttachment()
			this.showChat()
			this.scheduleChatBottom()
			const clientRequestId = Date.now().toString() + '-' + Math.floor(Math.random() * 100000).toString()
			apiCodexSend(this.projectIdForActiveSend(), this.activeThreadId, text, clientRequestId, this.newThreadScopeForSend(), (ok, result, error) => {
				if (ok) {
					this.applyWatch(result.watch)
					this.applyStatusEvents(result.events)
					if (result.threadId.length > 0) {
						this.activeThreadId = result.threadId
						setActiveThreadId(result.threadId)
						if (!this.isAssistantThread(result.threadId)) this.rememberRecentNormalThread(result.threadId)
					}
					if (result.accepted && result.threadId.length > 0) {
						this.clearWatch()
						this.loadThreadSnapshot(result.threadId, true)
					} else {
						this.startStatusPolling()
					}
						} else {
							this.statusText = error
							this.codexRunning = false
							this.applyStatusEvents(result.events)
							this.pushLocalProcessEvent('task_error', '发送失败：' + error, 'send_failed')
						}
			})
			this.scheduleActiveThreadSnapshotCache()
		},
		applyWatch(watch: CodexWatch) {
			this.watchSendId = watch.sendId
			this.watchSince = watch.since
			this.watchThreadId = watch.threadId
			this.watchSessionFile = watch.sessionFile
			this.watchExpectNewThread = watch.expectNewThread
			this.watchExcludeThreadId = watch.excludeThreadId
			this.watchCwd = watch.cwd
		},
		currentWatch(): CodexWatch {
			return {
				sendId: this.watchSendId,
				since: this.watchSince,
				threadId: this.watchThreadId.length > 0 ? this.watchThreadId : this.activeThreadId,
				sessionFile: this.watchSessionFile,
				expectNewThread: this.watchExpectNewThread,
				excludeThreadId: this.watchExcludeThreadId,
				cwd: this.watchCwd,
			}
		},
		clearWatch() {
			this.watchSendId = ''
			this.watchSince = ''
			this.watchThreadId = ''
			this.watchSessionFile = ''
			this.watchExpectNewThread = false
			this.watchExcludeThreadId = ''
			this.watchCwd = ''
		},
		applyAnnotationWatch(watch: CodexWatch) {
			this.annotationWatchSendId = watch.sendId
			this.annotationWatchSince = watch.since
			this.annotationWatchThreadId = watch.threadId
			this.annotationWatchSessionFile = watch.sessionFile
			this.annotationWatchExpectNewThread = watch.expectNewThread
			this.annotationWatchExcludeThreadId = watch.excludeThreadId
			this.annotationWatchCwd = watch.cwd
		},
		currentAnnotationWatch(): CodexWatch {
			return {
				sendId: this.annotationWatchSendId,
				since: this.annotationWatchSince,
				threadId: this.annotationWatchThreadId.length > 0 ? this.annotationWatchThreadId : this.annotationSourceThreadId,
				sessionFile: this.annotationWatchSessionFile,
				expectNewThread: this.annotationWatchExpectNewThread,
				excludeThreadId: this.annotationWatchExcludeThreadId,
				cwd: this.annotationWatchCwd,
			}
		},
		clearAnnotationWatch() {
			this.annotationWatchSendId = ''
			this.annotationWatchSince = ''
			this.annotationWatchThreadId = ''
			this.annotationWatchSessionFile = ''
			this.annotationWatchExpectNewThread = false
			this.annotationWatchExcludeThreadId = ''
			this.annotationWatchCwd = ''
		},
		currentAnnotationCursor(): CodexCursor {
			return {
				threadId: this.annotationCursorThreadId,
				sessionFile: this.annotationCursorSessionFile,
				messageCount: this.annotationCursorMessageCount,
				processCount: this.annotationCursorProcessCount,
				fileSize: this.annotationCursorFileSize,
				byteOffset: this.annotationCursorByteOffset,
				updatedAt: '',
				openTurnStartedAt: this.annotationCursorOpenTurnStartedAt,
				openTurnHasAssistantFinal: this.annotationCursorOpenTurnHasAssistantFinal,
			}
		},
		applyAnnotationCursor(cursor: CodexCursor) {
			this.annotationCursorThreadId = cursor.threadId
			this.annotationCursorSessionFile = cursor.sessionFile
			this.annotationCursorMessageCount = cursor.messageCount
			this.annotationCursorProcessCount = cursor.processCount
			this.annotationCursorFileSize = cursor.fileSize
			this.annotationCursorByteOffset = cursor.byteOffset
			this.annotationCursorOpenTurnStartedAt = cursor.openTurnStartedAt
			this.annotationCursorOpenTurnHasAssistantFinal = cursor.openTurnHasAssistantFinal
		},
		clearAnnotationCursor() {
			this.annotationCursorThreadId = ''
			this.annotationCursorSessionFile = ''
			this.annotationCursorMessageCount = 0
			this.annotationCursorProcessCount = 0
			this.annotationCursorFileSize = 0
			this.annotationCursorByteOffset = 0
			this.annotationCursorOpenTurnStartedAt = ''
			this.annotationCursorOpenTurnHasAssistantFinal = false
		},
		startAnnotationPolling(mode: string) {
			if (this.annotationPollTimer != 0) {
				clearInterval(this.annotationPollTimer)
				this.annotationPollTimer = 0
			}
			this.annotationPollMisses = 0
			this.annotationPollMode = mode
			this.annotationPollTimer = setInterval(() => {
				this.pollAnnotationCurrentState()
			}, 900)
			this.pollAnnotationCurrentState()
		},
		startAnnotationStatusPolling() {
			this.startAnnotationPolling('status')
		},
		startAnnotationUpdatesPolling(threadId: string) {
			if (threadId.length > 0) {
				this.annotationWatchThreadId = threadId
				this.annotationCursorThreadId = threadId
			}
			this.startAnnotationPolling('updates')
		},
		stopAnnotationMonitoring() {
			if (this.annotationPollTimer != 0) {
				clearInterval(this.annotationPollTimer)
				this.annotationPollTimer = 0
			}
			this.annotationPollMode = ''
			this.annotationPollMisses = 0
			this.clearAnnotationWatch()
			this.clearAnnotationCursor()
		},
		pollAnnotationCurrentState() {
			if (this.annotationPollMode == 'status') {
				this.pollAnnotationSendStatus()
				return
			}
			if (this.annotationPollMode == 'updates') this.pollAnnotationThreadUpdates()
		},
		finishAnnotationMonitoring(status: string) {
			this.stopAnnotationMonitoring()
			this.annotationSendStatus = status
		},
		pollAnnotationSendStatus() {
			const watch = this.currentAnnotationWatch()
			if (watch.sendId.length == 0) {
				this.finishAnnotationMonitoring('failed')
				return
			}
			apiCodexStatus(watch, (status) => {
				if (status.sessionFile.length > 0) this.annotationWatchSessionFile = status.sessionFile
				if (status.threadId.length > 0) this.annotationWatchThreadId = status.threadId
				if (status.accepted) this.annotationWatchExpectNewThread = false
				if (status.status == 'offline' || status.status == 'parse-failed') {
					this.annotationPollMisses = this.annotationPollMisses + 1
				} else {
					this.annotationPollMisses = 0
				}
				if (status.accepted && status.threadId.length > 0) {
					this.annotationSendStatus = 'waiting'
					this.startAnnotationUpdatesPolling(status.threadId)
					return
				}
				if (this.annotationPollMisses >= 6 || (!status.active && status.status == 'error')) {
					this.finishAnnotationMonitoring('failed')
				}
			})
		},
		pollAnnotationThreadUpdates() {
			const threadId = this.annotationWatchThreadId.length > 0 ? this.annotationWatchThreadId : this.annotationSourceThreadId
			if (threadId.length == 0) {
				this.finishAnnotationMonitoring('failed')
				return
			}
			apiCodexThreadUpdates(threadId, this.currentAnnotationCursor(), (ok, delta, _error) => {
				if (!ok) {
					this.annotationPollMisses = this.annotationPollMisses + 1
					if (this.annotationPollMisses >= 6) this.finishAnnotationMonitoring('failed')
					return
				}
				this.annotationPollMisses = 0
				if (delta.threadId.length > 0) this.annotationWatchThreadId = delta.threadId
				if (delta.sessionFile.length > 0) this.annotationWatchSessionFile = delta.sessionFile
				if (delta.reset) {
					this.clearAnnotationCursor()
					return
				}
				this.applyAnnotationCursor(delta.cursor)
				if (!delta.active && delta.available && delta.status != 'running' && delta.status != 'waiting' && delta.status != 'pending') {
					if (delta.status == 'error') {
						this.finishAnnotationMonitoring('failed')
						return
					}
					this.finishAnnotationMonitoring('')
				}
			})
		},
			scheduleChatBottom() {
				this.chatScrollRequestId = this.chatScrollRequestId + 1
				if (this.chatScrollTimer != 0) return
				this.chatScrollTimer = setTimeout(() => {
					this.applyChatBottom(this.chatScrollRequestId)
				this.chatScrollTimer = 0
			}, 80)
		},
		applyChatBottom(requestId: number) {
			if (requestId != this.chatScrollRequestId) return
			this.chatScrollTop = this.chatScrollTop + 100000
			this.chatScrollIntoView = ''
			setTimeout(() => {
				if (requestId != this.chatScrollRequestId) return
					this.chatScrollIntoView = 'chat-bottom-anchor'
				}, 10)
			},
			chatMessageDomId(messageId: string): string {
				let value = messageId
				value = value.split(':').join('-')
				value = value.split('.').join('-')
				value = value.split('/').join('-')
				value = value.split(' ').join('-')
				return 'chat-message-' + value
			},
				latestAssistantMessageId(messages: Array<ChatMessage>): string {
					if (messages.length == 0) return ''
					for (let index: Int = (messages.length - 1).toInt(); index >= 0; index--) {
						const message = messages[index]
						if (message.role == 'assistant' && message.id.length > 0) return message.id
				}
				return ''
			},
			scheduleChatMessageTop(messageId: string) {
				if (messageId.length == 0) {
					this.scheduleChatBottom()
					return
				}
				this.chatScrollRequestId = this.chatScrollRequestId + 1
				if (this.chatScrollTimer != 0) {
					clearTimeout(this.chatScrollTimer)
					this.chatScrollTimer = 0
				}
				const requestId = this.chatScrollRequestId
				this.chatScrollIntoView = ''
				this.chatScrollTimer = setTimeout(() => {
					this.applyChatMessageTop(requestId, messageId)
					this.chatScrollTimer = 0
				}, 80)
			},
			applyChatMessageTop(requestId: number, messageId: string) {
				if (requestId != this.chatScrollRequestId) return
				const target = this.chatMessageDomId(messageId)
				this.chatScrollIntoView = ''
				setTimeout(() => {
					if (requestId != this.chatScrollRequestId) return
					this.chatScrollIntoView = target
				}, 10)
			},
		startPolling(mode: string) {
			this.stopPolling()
			this.pollMisses = 0
			this.pollMode = mode
			this.pollTimer = setInterval(() => {
				this.pollCurrentState()
			}, 900)
			this.pollCurrentState()
		},
		startStatusPolling() {
			this.startPolling('status')
		},
		startUpdatesPolling(threadId: string) {
			if (threadId.length > 0) this.cursorThreadId = threadId
			this.startPolling('updates')
		},
		stopPolling() {
			if (this.pollTimer != 0) {
				clearInterval(this.pollTimer)
				this.pollTimer = 0
			}
			this.pollMode = ''
		},
		pollCurrentState() {
			if (this.pollMode == 'status') {
				this.pollSendStatus()
				return
			}
			if (this.pollMode == 'updates') this.pollThreadUpdates()
		},
		pollSendStatus() {
			const watch = this.currentWatch()
			apiCodexStatus(watch, (status) => {
				this.codexRunning = status.active
				if (status.sessionFile.length > 0) this.watchSessionFile = status.sessionFile
				if (status.threadId.length > 0) this.watchThreadId = status.threadId
				if (status.accepted) this.watchExpectNewThread = false
				this.applyStatusEvents(status.events)
				if (status.status == 'offline' || status.status == 'parse-failed') {
					this.pollMisses = this.pollMisses + 1
				} else {
					this.pollMisses = 0
				}
				if (status.threadId.length > 0 && status.accepted) {
					if (this.assistantInitializing) {
						this.bindAssistantThread(status.threadId, this.assistantPendingProjectId)
						uni.showToast({ title: '助手已创建', icon: 'success' })
					}
					this.stopPolling()
					this.clearWatch()
					this.loadThreadSnapshot(status.threadId, status.active || status.status == 'running' || status.status == 'waiting' || status.status == 'pending')
					return
				}
				if (this.pollMisses >= 6 || (!status.active && status.status == 'error')) {
					if (this.assistantInitializing) {
						this.assistantInitializing = false
						this.assistantPendingProjectId = ''
						this.pendingAssistantPromptWaiting = false
						if (this.pendingAssistantPrompt.length > 0 && this.prompt.trim().length == 0) {
							this.setPromptForActiveComposer(this.pendingAssistantPrompt)
						}
					}
					this.stopPolling()
					this.clearWatch()
				}
			})
		},
		pollThreadUpdates() {
			const threadId = this.activeThreadId.length > 0 ? this.activeThreadId : this.cursorThreadId
			if (threadId.length == 0) return
			apiCodexThreadUpdates(threadId, this.currentCursor(), (ok, delta, error) => {
				if (!ok) {
					this.pollMisses = this.pollMisses + 1
					if (this.pollMisses >= 6) {
						this.stopPolling()
						this.statusText = error
					}
					return
				}
				this.pollMisses = 0
				if (delta.reset) {
					this.loadThreadSnapshot(threadId, true)
					return
				}
				this.codexRunning = delta.active
				if (delta.summary.id.length > 0) {
					const summary = this.normalizeAssistantThreadSummary(delta.summary)
					this.upsertThreadSummary(summary, false)
					if (this.activeThreadId == summary.id) this.applyThreadSummary(summary)
				}
				let shouldScroll = false
					const latestAssistantId = this.latestAssistantMessageId(delta.messagesDelta)
					if (this.appendMessages(delta.messagesDelta, false)) shouldScroll = true
					if (this.appendProcessEvents(delta.processEventsDelta, false)) shouldScroll = true
					this.applyCursor(delta.cursor)
					this.tryFlushPendingAssistantPrompt()
					if (shouldScroll || delta.summary.id.length > 0) this.saveActiveThreadSnapshotCache()
					if (shouldScroll) {
						if (latestAssistantId.length > 0) this.scheduleChatMessageTop(latestAssistantId)
						else this.scheduleChatBottom()
					}
				if (!delta.active && delta.available && delta.status != 'running' && delta.status != 'waiting' && delta.status != 'pending') {
					this.stopPolling()
				}
			})
		},
			showFiles() {
				this.triggerWorkspaceMotion()
				this.settingsOpen = false
				this.setRightModePersisted('files')
			},
			showChat() {
				this.setRightModePersisted('chat')
			},
		reloadTree() {
			this.nodes = new Array<TreeNode>()
			if (this.activeProjectPath.length == 0) return
			this.nodes.push({ path: this.activeProjectPath, name: this.baseName(this.activeProjectPath), type: 'dir', size: 0, level: 0, expanded: false })
			this.expandDir(0)
		},
		onNodeTap(index: number) {
			const nodeIndex: Int = index.toInt()
			if (nodeIndex < 0 || nodeIndex >= this.nodes.length) return
			const node = this.nodes[nodeIndex]
			if (node.type == 'dir') this.expandDir(nodeIndex)
			else this.openFile(node.path)
		},
		expandDir(index: Int) {
			const node = this.nodes[index]
			if (node.expanded) {
				this.collapseDir(index)
				return
			}
			apiListProject(this.activeProjectId, node.path, (ok, entries, error) => {
				if (!ok) {
					this.statusText = error
					return
				}
				const children = new Array<TreeNode>()
				for (let entryIndex: Int = 0; entryIndex < entries.length; entryIndex++) children.push(this.entryToNode(node.path, entries[entryIndex], node.level + 1))
				const next = new Array<TreeNode>()
				for (let before: Int = 0; before <= index; before++) {
					const item = this.nodes[before]
					if (before == index) item.expanded = true
					next.push(item)
				}
				for (let childIndex: Int = 0; childIndex < children.length; childIndex++) next.push(children[childIndex])
				const afterStart: Int = (index + 1).toInt()
				for (let after: Int = afterStart; after < this.nodes.length; after++) next.push(this.nodes[after])
				this.nodes = next
			})
		},
		collapseDir(index: Int) {
			const node = this.nodes[index]
			const next = new Array<TreeNode>()
			for (let i: Int = 0; i <= index; i++) {
				const item = this.nodes[i]
				if (i == index) item.expanded = false
				next.push(item)
			}
			const afterStart: Int = (index + 1).toInt()
			for (let i: Int = afterStart; i < this.nodes.length; i++) {
				const item = this.nodes[i]
				if (item.level <= node.level) next.push(item)
			}
			this.nodes = next
		},
		openFile(path: string) {
			this.selectedPath = path
			this.setRightModePersisted('files')
			apiReadProject(this.activeProjectId, path, (ok, result, error) => {
				if (ok && result != null) {
					this.fileText = result.text
					this.originalText = result.text
					this.dirty = false
				} else {
					this.fileText = ''
					this.originalText = ''
					this.statusText = error
				}
			})
		},
		saveFile() {
			if (this.selectedPath.length == 0) return
			apiWriteProject(this.activeProjectId, this.selectedPath, this.fileText, (ok, error) => {
				if (ok) {
					this.originalText = this.fileText
					this.dirty = false
					uni.showToast({ title: '已保存', icon: 'success' })
				} else {
					this.statusText = error
					uni.showToast({ title: error, icon: 'none' })
				}
			})
		},
		onEditorInput() {
			this.dirty = this.fileText != this.originalText
		},
		sendFileToCodex() {
			if (this.selectedPath.length == 0) return
			this.setPromptForActiveComposer('请阅读并修改这个文件：' + this.selectedPath)
			this.showChat()
		},
		entryToNode(parent: string, entry: FsEntry, level: number): TreeNode {
			return { path: this.joinPath(parent, entry.name), name: entry.name, type: entry.type, size: entry.size, level, expanded: false }
		},
		joinPath(parent: string, name: string): string {
			if (parent.endsWith('/')) return parent + name
			return parent + '/' + name
		},
		baseName(path: string): string {
			let value = path
			while (value.endsWith('/') && value.length > 1) value = value.substring(0, value.length - 1)
			const index = value.lastIndexOf('/')
			if (index < 0) return value
			return value.substring(index + 1)
		},
		indentText(level: number): string {
			let text = ''
			for (let index: Int = 0; index < level; index++) text = text + '  '
			return text
		},
		relativeTime(value: string): string {
			const parsed = Date.parse(value)
			if (parsed <= 0) return ''
			const minutes = Math.floor((Date.now() - parsed) / 60000)
			if (minutes < 1) return '1 分'
			if (minutes < 60) return minutes.toString() + ' 分'
			const hours = Math.floor(minutes / 60)
			if (hours < 24) return hours.toString() + ' 小时'
			const days = Math.floor(hours / 24)
			if (days < 30) return days.toString() + ' 天'
			return Math.floor(days / 30).toString() + ' 个月'
		},
			checkExternalUrl(url: string) {
				// #ifdef WEB
				this.isExternalUrl = false
				if (url.length > 0) {
					const host = window.location.host
					if (host.length > 0 && url.indexOf('://' + host) < 0 && url.indexOf(host + '/') < 0) {
						this.isExternalUrl = true
					}
				}
				// #endif
				// #ifndef WEB
				this.isExternalUrl = false
				// #endif
			},
			goWeb() {
				this.triggerWorkspaceMotion()
				this.settingsOpen = false
				this.setWorkspaceState('annotate', 'web')
				if (this.embeddedWebUrl.length == 0) this.setEmbeddedWebUrl(getDevUrl())
				this.checkExternalUrl(this.embeddedWebUrl)
				this.webNavCanGoBack = false
				this.webNavCanGoForward = false
				setTimeout(() => {
					this.refreshEmbeddedWebNavStatus()
				}, 600)
			},
		goWebFromCompactDrawer() {
			this.closeCompactDrawer()
			this.goWeb()
		},
			startAnnotationFromIndex() {
				this.settingsOpen = false
				this.startWebAnnotationFromIndex()
			},
			webCaptureLeft(): number {
				if (this.isCompactChat) return 0
				const rail = this.railCompact() ? this.collapsedRailWidth() : this.railWidth()
				return rail + this.interPaneGap()
			},
			webCaptureTop(): number {
				if (this.isCompactChat) return 0
				return this.cardTopInset()
			},
			syncAnnotationStageSize() {
				this.annotationStageWidth = this.embeddedWebWidth()
				this.annotationStageHeight = this.embeddedWebContentHeight()
			},
			captureEmbeddedWebRegion(done: (result: ScreenshotResult) => void) {
				// #ifdef APP-ANDROID
				captureCurrentWindowLayoutRegion(this.webCaptureLeft(), this.webCaptureTop(), this.embeddedWebWidth(), this.embeddedWebContentHeight(), this.windowWidth, this.windowHeight, done)
				// #endif

				// #ifndef APP-ANDROID
				done({ ok: false, path: '', error: '当前平台不支持 Android 原生截图' })
				// #endif
			},
			controlEmbeddedWeb(action: string) {
				if (this.webNavBusy) return
				if (this.embeddedWebUrl.length == 0) return
				this.webNavBusy = true
				setTimeout(() => {
					const result = controlEmbeddedWebView(
						action,
						this.webCaptureLeft(),
						this.webCaptureTop(),
						this.embeddedWebWidth(),
						this.embeddedWebContentHeight(),
						this.windowWidth,
						this.windowHeight
					)
					this.webNavCanGoBack = result.canGoBack
					this.webNavCanGoForward = result.canGoForward
					this.webNavBusy = false
					setTimeout(() => {
						this.refreshEmbeddedWebNavStatus()
					}, 360)
					if (!result.ok && action == 'reload') {
						uni.showToast({ title: result.error.length > 0 ? result.error : '刷新失败', icon: 'none' })
					}
				}, 0)
			},
			startWebAnnotationFromIndex() {
				this.settingsOpen = false
				if (this.embeddedWebUrl.length == 0) {
					this.setEmbeddedWebUrl(getDevUrl())
				}
				this.checkExternalUrl(this.embeddedWebUrl)
				if (this.embeddedWebUrl.length == 0) {
					uni.showToast({ title: '请先打开一个网页链接', icon: 'none' })
					return
				}
				if (this.annotationBusy) return
				this.annotationBusy = true
				this.isCapturingScreenshot = true
				setTimeout(() => {
					this.captureEmbeddedWebRegion((result) => {
						this.annotationBusy = false
						this.isCapturingScreenshot = false
						if (!result.ok) {
							uni.showToast({ title: result.error.length > 0 ? result.error : '截图失败', icon: 'none' })
							return
						}
						this.startInlineWebAnnotation(result.path)
					})
				}, 80)
			},
			startInlineWebAnnotation(imagePath: string) {
				this.stopAnnotationMonitoring()
				this.annotationImagePath = imagePath
				this.annotationPreviewSrc = imagePath
				this.annotationDots = new Array<Point>()
				this.annotationSegments = new Array<Segment>()
				this.annotationStrokeGroups = new Array<number>()
				this.annotationStrokeSegmentGroups = new Array<number>()
				this.annotationStrokePointCount = 0
				this.annotationStrokeSegmentCount = 0
				this.annotationDrawing = false
				this.annotationLastPoint = null
				this.pendingAnnotationVoiceText = ''
				this.annotationSendStatus = ''
				this.syncAnnotationStageSize()
				this.showAnnotationPill = true
				this.isAnnotating = true
			},
			closeAnnotation() {
				if (this.annotationBusy) return
				this.stopAnnotationMonitoring()
				this.isAnnotating = false
				this.showAnnotationPill = false
				this.isCapturingScreenshot = false
				this.annotationSubmitting = false
				this.annotationDrawing = false
				this.annotationStrokePointCount = 0
				this.annotationImagePath = ''
				this.annotationPreviewSrc = ''
				this.annotationDots = new Array<Point>()
				this.annotationSegments = new Array<Segment>()
				this.annotationStrokeGroups = new Array<number>()
				this.annotationStrokeSegmentGroups = new Array<number>()
				this.annotationStrokeSegmentCount = 0
				this.annotationLastPoint = null
				this.pendingAnnotationVoiceText = ''
				this.annotationSendStatus = ''
			},
			annotationPoint(event: UniTouchEvent): Point | null {
				if (event.touches.length <= 0) return null
				const touch: UniTouch = event.touches[0]
				const width = this.annotationStageWidth > 0 ? this.annotationStageWidth : this.embeddedWebWidth()
				const height = this.annotationStageHeight > 0 ? this.annotationStageHeight : this.embeddedWebContentHeight()
				if (width <= 0 || height <= 0) return null
				let x = (touch.clientX - this.webCaptureLeft()) / width
				let y = (touch.clientY - this.webCaptureTop()) / height
				if (x < 0) x = 0
				if (x > 1) x = 1
				if (y < 0) y = 0
				if (y > 1) y = 1
				return { x, y }
			},
			appendAnnotationPoint(point: Point | null) {
				if (point == null) return
				if (this.annotationLastPoint != null) {
					const lastPoint = this.annotationLastPoint
					if (lastPoint != null) {
						this.annotationSegments.push({
							x1: lastPoint.x,
							y1: lastPoint.y,
							x2: point.x,
							y2: point.y,
						})
						this.annotationStrokeSegmentCount = this.annotationStrokeSegmentCount + 1
					}
				}
				this.annotationDots.push(point)
				this.annotationStrokePointCount = this.annotationStrokePointCount + 1
				this.annotationLastPoint = point
			},
			onAnnotationTouchStart(event: UniTouchEvent) {
				if (!this.isAnnotating || this.annotationBusy) return
				this.annotationDrawing = true
				this.annotationStrokePointCount = 0
				this.annotationStrokeSegmentCount = 0
				this.annotationLastPoint = null
				this.appendAnnotationPoint(this.annotationPoint(event))
			},
			onAnnotationTouchMove(event: UniTouchEvent) {
				if (!this.isAnnotating || !this.annotationDrawing || this.annotationBusy) return
				this.appendAnnotationPoint(this.annotationPoint(event))
			},
			onAnnotationTouchEnd(_: UniTouchEvent) {
				if (!this.isAnnotating) return
				if (this.annotationDrawing && this.annotationStrokePointCount > 0) {
					this.annotationStrokeGroups.push(this.annotationStrokePointCount)
					this.annotationStrokeSegmentGroups.push(this.annotationStrokeSegmentCount)
				}
				this.annotationDrawing = false
				this.annotationStrokePointCount = 0
				this.annotationStrokeSegmentCount = 0
				this.annotationLastPoint = null
			},
			canUndoAnnotation(): boolean {
				return this.isAnnotating && !this.annotationBusy && !this.annotationDrawing && this.annotationStrokeGroups.length > 0
			},
			undoAnnotation() {
				if (this.annotationBusy) return
				if (this.annotationDrawing) return
				if (this.annotationStrokeGroups.length <= 0) return
				const pointCount = this.annotationStrokeGroups.pop()
				const segmentCount = this.annotationStrokeSegmentGroups.pop()
				if (pointCount == null || segmentCount == null) return
				for (let index: Int = 0; index < pointCount; index++) {
					if (this.annotationDots.length > 0) this.annotationDots.pop()
				}
				for (let index: Int = 0; index < segmentCount; index++) {
					if (this.annotationSegments.length > 0) this.annotationSegments.pop()
				}
			},
			clearAnnotation() {
				if (this.annotationBusy) return
				if (this.annotationDrawing) return
				this.annotationDots = new Array<Point>()
				this.annotationSegments = new Array<Segment>()
				this.annotationStrokeGroups = new Array<number>()
				this.annotationStrokeSegmentGroups = new Array<number>()
				this.annotationStrokePointCount = 0
				this.annotationStrokeSegmentCount = 0
				this.annotationLastPoint = null
			},
			buildAnnotationSendText(imagePath: string): string {
				const lines = new Array<string>()
				const voiceText = this.pendingAnnotationVoiceText.trim()
				if (this.annotationSourceIsAssistant) {
					lines.push('请根据标注截图中的红色标注位置，以及语音说明，判断需要修改的页面或组件，并直接给出对应修改。')
				} else {
					lines.push('请根据标注截图中的红色标注位置，以及语音说明，直接修改当前项目中与来源链接对应的页面或组件代码。')
					lines.push('当前任务目标是修改这个项目里的页面实现，不要只给建议或解释。')
				}
				lines.push('优先按截图标注理解具体改动位置，不要只解释截图内容。')
				lines.push('如果能定位到对应页面，请直接修改；如果不能精确定位，再根据来源链接和项目上下文搜索相关页面。')
				if (voiceText.length > 0) {
					lines.push('请同时结合语音说明执行修改。')
				} else {
					lines.push('如果语音说明为空，按截图标注本身执行修改。')
				}
				lines.push('完成后说明你改了哪些文件、改了什么。')
				lines.push('')
				lines.push('以下是本次任务的素材：')
				if (this.embeddedWebUrl.length > 0) {
					lines.push('来源链接：' + this.embeddedWebUrl)
					lines.push('来源链接用于帮助你定位需要修改的页面。')
				}
				if (voiceText.length > 0) lines.push('语音说明：' + voiceText)
				lines.push(this.attachmentPathInstruction(imagePath))
				return lines.join('\n')
			},
			clearInlineAnnotationAfterSend() {
				this.isAnnotating = false
				this.showAnnotationPill = false
				this.isCapturingScreenshot = false
				this.annotationSubmitting = false
				this.annotationDrawing = false
				this.annotationStrokePointCount = 0
				this.annotationImagePath = ''
				this.annotationPreviewSrc = ''
				this.annotationDots = new Array<Point>()
				this.annotationSegments = new Array<Segment>()
				this.annotationStrokeGroups = new Array<number>()
				this.annotationStrokeSegmentGroups = new Array<number>()
				this.annotationStrokeSegmentCount = 0
				this.annotationLastPoint = null
				this.pendingAnnotationVoiceText = ''
			},
			sendCurrentAnnotationToSourceThread() {
				if (this.annotationBusy) return
				if (!this.resolveAnnotationSourceFallback()) {
					uni.showToast({ title: '无法找到来源会话', icon: 'none' })
					return
				}
				if (this.annotationImagePath.length == 0) {
					uni.showToast({ title: '截图不可用', icon: 'none' })
					return
				}
				if (this.annotationDrawing) {
					uni.showToast({ title: '请先松开标注手势', icon: 'none' })
					return
				}
				if (this.annotationDots.length == 0 && this.annotationSegments.length == 0) {
					uni.showToast({ title: '请先标注', icon: 'none' })
					return
				}
				const sourceProjectId = this.annotationSourceProjectId
				const sourceThreadId = this.annotationSourceThreadId
				this.annotationBusy = true
				this.annotationSubmitting = true
				this.isCapturingScreenshot = true
				this.annotationSendStatus = 'sending'
				setTimeout(() => {
					this.captureEmbeddedWebRegion((result) => {
						if (!result.ok) {
							this.annotationBusy = false
							this.annotationSubmitting = false
							this.isCapturingScreenshot = false
							this.annotationSendStatus = 'failed'
							uni.showToast({ title: result.error.length > 0 ? result.error : '合成截图失败', icon: 'none' })
							return
						}
						const annotatedPath = result.path
						const payload = JSON.stringify({
							sourceType: 'web',
							sourcePage: 'pages/index/index',
							sourceTitle: '阅注',
							sourceUrl: this.embeddedWebUrl,
							sourceProjectId,
							sourceThreadId,
							sourceThreadTitle: this.annotationSourceTitle,
							baseImagePath: this.annotationImagePath,
							annotatedImagePath: annotatedPath,
							voiceText: this.pendingAnnotationVoiceText.trim(),
							annotations: {
								rects: new Array<any>(),
								dots: this.annotationDots,
								segments: this.annotationSegments,
								texts: new Array<any>(),
							},
							createdAt: new Date().toISOString(),
						})
						uploadAnnotation(annotatedPath, payload, (ok, record, error) => {
							if (!ok) {
								this.annotationBusy = false
								this.annotationSubmitting = false
								this.isCapturingScreenshot = false
								this.annotationSendStatus = 'failed'
								uni.showToast({ title: error, icon: 'none' })
								return
							}
							let imageRef = annotatedPath
							if (record != null && record.imagePath.length > 0) imageRef = record.imagePath
							const text = this.buildAnnotationSendText(imageRef)
							const clientRequestId = Date.now().toString() + '-' + Math.floor(Math.random() * 100000).toString()
							apiCodexSend(sourceProjectId, sourceThreadId, text, clientRequestId, '', (sendOk, sendResult, sendError) => {
								this.annotationBusy = false
								if (sendOk) {
									this.applyAnnotationWatch(sendResult.watch)
									this.clearInlineAnnotationAfterSend()
									this.annotationSendStatus = 'waiting'
									if (sendResult.accepted && sendResult.threadId.length > 0) {
										this.annotationWatchThreadId = sendResult.threadId
										this.startAnnotationUpdatesPolling(sendResult.threadId)
									} else {
										this.startAnnotationStatusPolling()
									}
									return
								}
								this.stopAnnotationMonitoring()
								this.annotationSubmitting = false
								this.isCapturingScreenshot = false
								this.annotationSendStatus = 'failed'
								uni.showToast({ title: sendError.length > 0 ? sendError : '发送标注失败', icon: 'none' })
							})
						})
					})
				}, 80)
			},
			submitAnnotation() {
				if (this.annotationBusy) return
				if (this.annotationImagePath.length == 0) {
					uni.showToast({ title: '截图不可用', icon: 'none' })
					return
				}
				if (this.annotationDots.length == 0 && this.annotationSegments.length == 0) {
					uni.showToast({ title: '请先标注', icon: 'none' })
					return
				}
				this.annotationBusy = true
				this.annotationSubmitting = true
				this.isCapturingScreenshot = true
				setTimeout(() => {
					this.captureEmbeddedWebRegion((result) => {
						this.annotationSubmitting = false
						this.isCapturingScreenshot = false
						if (!result.ok) {
							this.annotationBusy = false
							uni.showToast({ title: result.error.length > 0 ? result.error : '合成截图失败', icon: 'none' })
							return
						}
						const annotatedPath = result.path
						const payload = JSON.stringify({
							sourceType: 'web',
							sourcePage: 'pages/index/index',
							sourceTitle: '阅注',
							sourceUrl: this.embeddedWebUrl,
							baseImagePath: this.annotationImagePath,
							annotatedImagePath: annotatedPath,
							voiceText: this.pendingAnnotationVoiceText.trim(),
							annotations: {
								rects: new Array<any>(),
								dots: this.annotationDots,
								segments: this.annotationSegments,
								texts: new Array<any>(),
							},
							createdAt: new Date().toISOString(),
						})
						uploadAnnotation(annotatedPath, payload, (ok, _record, error) => {
							this.annotationBusy = false
							if (ok) {
								uni.showToast({ title: '标注已上传', icon: 'success' })
								this.closeAnnotation()
							} else {
								uni.showToast({ title: error, icon: 'none' })
							}
						})
					})
				}, 80)
			},
			toggleAnnotationPill() {
				if (this.showAnnotationPill) {
					this.closeAnnotation()
				} else {
					this.startWebAnnotationFromIndex()
				}
			},
			onMicClick() {
				toggleGlobalVoiceFromButton()
				this.globalVoiceActive = isGlobalVoiceActive()
			},
		toggleSettingsFromCompactDrawer() {
			this.closeCompactDrawer()
			this.toggleSettings()
		},
			goBackgroundTest() {
				this.settingsOpen = false
				uni.navigateTo({ url: '/pages/background-test/index' })
			},
		goBackgroundTestFromCompactDrawer() {
			this.closeCompactDrawer()
			this.goBackgroundTest()
		},
		triggerScreenCaptureFromCompactDrawer() {
			this.closeCompactDrawer()
			this.triggerScreenCaptureFromMenu()
		},
	},
}
</script>

<style>
	@import './parts/index-workbench.css';
</style>
